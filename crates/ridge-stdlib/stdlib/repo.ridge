-- std.repo — a typed repository over the storage Adapter seam.
--
-- The Adapter (std.data) is the untyped storage seam: rows cross it as
-- `Map Text SqlValue` and a predicate is written against that row map. A
-- repository is the typed layer one step up. A `Repo e a` pairs a storage
-- adapter `a` with the name of the table that holds entity `e`; its read
-- methods run the adapter primitives and decode each row back into `e` through
-- `deriving (Row)`, so a query answers `List User` rather than a list of raw
-- column maps.
--
-- The entity `e` is a phantom parameter: it names what the repository stores
-- without appearing in the stored fields, the same way `Quote f` names the
-- quoted function it wraps. Pin it once where the repository is created —
-- `let users: Repo User MemAdapter = repo conn "users"` — and every query
-- auto-decodes to that record with no further annotation.
--
-- Methods take the repository last, so a query reads as a pipeline:
--   users |> Repo.findBy (fn (u: User) -> u.age >= 18)
-- A predicate is quoted exactly as at the adapter seam: the parameter
-- annotation pins the row type and the body is captured as a query tree.

import std.data as Db
import std.sql (SqlValue)
import std.query (SortOrder, ascending, QueryPlan, planScan, planCombine, planRefine, planJoin, planProject, planAggregate, planGroup)
import std.map (fromList, toList)

-- A repository: entity `e` stored in `table` through adapter `a`. Opaque, so it
-- is built only through `repo` and threaded as a handle, never destructured.
pub opaque type Repo e a = { adapter: a, table: Text }

-- Bind a repository to a table on an open adapter. The entity type is pinned by
-- the annotation on the binding, not by any stored value.
pub fn repo (adapter: a) (table: Text) -> Repo e a =
    Repo { adapter = adapter, table = table }

-- Decode a list of raw rows into entities, stopping at the first decode failure.
fn decodeRows (rows: List (Map Text SqlValue)) -> Result (List e) Error where Row e =
    match rows
        []        -> Ok []
        r :: rest ->
            match fromRow r
                Err err -> Err err
                Ok x    ->
                    match decodeRows rest
                        Err err -> Err err
                        Ok xs   -> Ok (x :: xs)

-- The head of a row list, decoded; `None` when the list is empty. The single-
-- result verbs (`find`, `get`) share it.
fn firstDecoded (rows: List (Map Text SqlValue)) -> Result (Option e) Error where Row e =
    match rows
        []       -> Ok None
        row :: _ ->
            match fromRow row
                Err err -> Err err
                Ok x    -> Ok (Some x)

-- A quoted predicate that keeps every row — an always-true tree. The aggregate
-- and full-table verbs run `selectRows` with it, so they reach the rows through the
-- one seam primitive (`selectRows`) rather than a second `all`/`get` entry point.
-- Built in the runtime: a `Quote`/`QExpr` literal cannot be written in Ridge
-- source (the compiler only captures quotations, it does not let code construct
-- the tree), so the always-true tree is assembled on the Erlang side.
@ffi("ridge_rt", "quote_keep_all", 1)
fn keepAll (_u: Unit) -> Quote (Map Text SqlValue -> Bool)

-- Combine two quoted predicates with a boolean AND. A `Quote`/`QExpr` literal
-- cannot be written in Ridge source, so the `QAnd` node is built in the runtime
-- from the two captured trees. The query builder folds each filter in with this.
-- The second tree's phantom function type is free (`Quote p`): the runtime ANDs
-- the captured trees regardless of their shape, so the unified `filter`'s
-- entity-typed predicate (`Quote (e -> Bool)`) folds into the row-typed query
-- field without a coercion.
@ffi("ridge_rt", "quote_and", 2)
fn quoteAnd (a: Quote (Map Text SqlValue -> Bool)) (b: Quote p) -> Quote (Map Text SqlValue -> Bool)

-- An always-true two-row predicate — the post-join `WHERE` default before
-- `filter` narrows a join. The always-true tree a `true` literal builds is
-- arity-agnostic, so this reuses `quote_keep_all`, typed over the two rows a
-- join condition ranges over.
@ffi("ridge_rt", "quote_keep_all", 1)
fn keepAll2 (_u: Unit) -> Quote (Map Text SqlValue -> Map Text SqlValue -> Bool)

-- Combine two quoted two-row predicates with a boolean AND — the two-row dual of
-- `quoteAnd`, reusing the same runtime `QAnd` builder (it ANDs two captured
-- trees independent of their arity). The second tree's phantom shape is free so
-- a join `filter`'s entity-typed predicate folds into the row-typed `WHERE`.
@ffi("ridge_rt", "quote_and", 2)
fn quoteAnd2 (a: Quote (Map Text SqlValue -> Map Text SqlValue -> Bool)) (b: Quote p) -> Quote (Map Text SqlValue -> Map Text SqlValue -> Bool)

-- The set-operation plan a query runs is built from `std.query`'s `planScan`/
-- `planCombine`/`planRefine` over the typed `QueryPlan` tree, threaded through the
-- builder's `plan` field and handed to a backend's `runPlan` — which interprets it
-- (the in-memory store) or compiles it to nested SQL (Postgres).

-- Every row of the table, decoded into entities.
pub fn all (r: Repo e a) -> Result (List e) Error where Adapter a, Row e =
    match selectRows r.adapter r.table (keepAll ())
        Err err  -> Err err
        Ok rows  -> decodeRows rows

-- The rows matching a quoted predicate, decoded into entities. The predicate is
-- written against the entity at the call site (`fn (u: User) -> ...`) and
-- captured as a query tree; the seam evaluates it against each stored row.
pub fn findBy (pred: Quote (Map Text SqlValue -> Bool)) (r: Repo e a) -> Result (List e) Error where Adapter a, Row e =
    match selectRows r.adapter r.table pred
        Err err  -> Err err
        Ok rows  -> decodeRows rows

-- The first entity matching a quoted predicate, or `None` when none match.
-- Fetched with a one-row limit, so the backend stops at the first match.
pub fn find (pred: Quote (Map Text SqlValue -> Bool)) (r: Repo e a) -> Result (Option e) Error where Adapter a, Row e =
    match fetch r.adapter r.table pred [] 1 0 false
        Err err  -> Err err
        Ok rows  -> firstDecoded rows

-- The entity whose `column` holds exactly `key`, or `None`. A lookup by an
-- exact column match (typically a primary key), decoded into the entity.
pub fn getBy (column: Text) (key: SqlValue) (r: Repo e a) -> Result (Option e) Error where Adapter a, Row e =
    match get r.adapter r.table column key
        Err err       -> Err err
        Ok None       -> Ok None
        Ok (Some row) ->
            match fromRow row
                Err err -> Err err
                Ok x    -> Ok (Some x)

-- `count` and `exists` are the methods of the `Countable q p | q -> p` class
-- (declared below, next to `Pageable`), so one `count`/`exists` serves a query, an
-- inner join, and a left join. They run off the query builder rather than the bare
-- repository: a whole-table count reads `users |> Repo.query |> Repo.count`, and a
-- count over a predicate folds a `filter` in first (`users |> Repo.query |>
-- Repo.filter pred |> Repo.count`) — the form the old `countBy` spelled directly.

-- Append a raw row to the table. The row is a column map built by hand through
-- `SqlType.toSql`; for a typed entity reach for `insert`, which derives the row.
pub fn insertRow (row: Map Text SqlValue) (r: Repo e a) -> Result Unit Error where Adapter a =
    appendRow r.adapter r.table row

-- Append a typed entity, encoding it to a row through `deriving (Row)`'s `toRow`.
-- The repository's table holds entity `e`, so its `Row` instance names the columns
-- and runs each field through `SqlType.toSql` — a nullable `Option` field writes
-- `None` as SQL NULL. This is the write-side dual of the decode every read verb
-- runs, so a record goes in the way one comes out.
pub fn insert (entity: e) (r: Repo e a) -> Result Unit Error where Adapter a, Row e =
    insertRow (toRow entity) r

-- Remove the rows matching a quoted predicate; answer how many were removed.
pub fn deleteWhere (pred: Quote (Map Text SqlValue -> Bool)) (r: Repo e a) -> Result Int Error where Adapter a =
    delete r.adapter r.table pred

-- Set the given columns on every row matching a quoted predicate; answer how many
-- rows changed. The `changes` map is a partial column map built through
-- `SqlType.toSql`, so one call can touch a subset of columns. To write a whole
-- record back, use `update`.
pub fn updateWhere (changes: Map Text SqlValue) (pred: Quote (Map Text SqlValue -> Bool)) (r: Repo e a) -> Result Int Error where Adapter a =
    updateRows r.adapter r.table changes pred

-- Overwrite every column of the rows matching a quoted predicate with a typed
-- entity, encoded through `toRow`. Reach for `updateWhere` when only some columns
-- change.
pub fn update (entity: e) (pred: Quote (Map Text SqlValue -> Bool)) (r: Repo e a) -> Result Int Error where Adapter a, Row e =
    updateWhere (toRow entity) pred r

-- A single typed column assignment, built by `set`: the target column and its
-- new value encoded to `SqlValue`. The entity `e` is a phantom that ties the
-- setter to the record whose column the accessor named, so a `List (Setter e)`
-- cannot mix entities and must match the repository's `e`. Opaque, so user code
-- builds one only through `set` and hands the list to `setWhere`/`applySet`.
pub opaque type Setter e = { column: Text, value: SqlValue }

-- Build a typed column assignment. The column is named by a quoted accessor
-- (`fn (u: User) -> u.status`), which pins the column's type, so the value must
-- match it — `set (fn (u: User) -> u.age) "x"` is a compile-time type error, the
-- same way a predicate's comparison is checked. The value is encoded to a
-- `SqlValue` through `SqlType.toSql`, so a nullable `Option` column writes `None`
-- as SQL NULL. This is the write-side analogue of an `orderBy` key: both quote a
-- single column, one to assign it, the other to sort by it.
pub fn set (col: Quote (e -> v)) (value: v) -> Setter e where SqlType v =
    Setter { column = setterColumn col, value = toSql value }

-- The column a setter's quoted accessor names. The accessor quote captures a
-- single column, so its tree is a `QCol`; anything else contributes no column,
-- the same shape as an ordering key's `orderColumn`.
fn setterColumn (col: Quote (e -> v)) -> Text =
    match col.tree
        QCol c -> c
        _      -> ""

-- Fold a list of setters into the `(column, value)` pairs the seam's partial
-- update map is built from.
fn setterPairs (setters: List (Setter e)) -> List (Text, SqlValue) =
    match setters
        []        -> []
        s :: rest -> (s.column, s.value) :: setterPairs rest

-- The partial column map a list of setters assigns — the typed dual of the raw
-- `changes` map `updateWhere` takes.
fn settersToMap (setters: List (Setter e)) -> Map Text SqlValue =
    fromList (setterPairs setters)

-- Set the columns named by typed setters on every row matching a quoted
-- predicate; answer how many rows changed. The typed front door to `updateWhere`:
-- each `set (fn (u: User) -> u.col) value` is checked so the value matches the
-- column, where `updateWhere` takes an unchecked `Map Text SqlValue`. Reach for
-- `updateWhere` only to write a column map assembled by hand.
pub fn setWhere (setters: List (Setter e)) (pred: Quote (Map Text SqlValue -> Bool)) (r: Repo e a) -> Result Int Error where Adapter a =
    updateRows r.adapter r.table (settersToMap setters) pred

-- Run `body` inside a database transaction on the connection. The body receives
-- the same connection, so every repository built on it (`repo conn "..."`) runs
-- within the transaction. It commits and returns the value when the body answers
-- `Ok`, and rolls back — leaving the store as it was — when the body answers
-- `Err`, so a multi-step write is all-or-nothing:
--   Repo.transaction conn (fn (tx) ->
--     let users: Repo User Postgres = repo tx "users"
--     match Repo.insert alice users
--       Err e -> Err e
--       Ok _  -> Repo.insert bob users)
-- Here both inserts land together or, if the second fails, neither does. A
-- `transaction` nested inside another opens a savepoint: an inner `Err` rolls
-- back only the inner work and the outer transaction carries on, so a failable
-- sub-step can be attempted without abandoning the whole transaction. A `commit`
-- or `rollback` that itself fails (a dropped connection, say) surfaces as the
-- result's `Err`; otherwise a rolled-back transaction returns the body's own error.
pub fn transaction (conn: a) (body: fn a -> Result r Error) -> Result r Error where Adapter a =
    match begin conn
        Err e -> Err e
        Ok _  ->
            match body conn
                Ok value ->
                    match commit conn
                        Ok _  -> Ok value
                        Err e -> Err e
                Err e ->
                    match rollback conn
                        Ok _   -> Err e
                        Err e2 -> Err e2

-- Run a body with the connection, then `close` it on every path — whether the body
-- answers `Ok` or `Err`. The result is the body's own; the close is guaranteed
-- teardown, so a scoped connection is never leaked even when the body returns early or
-- fails. This is the recommended way to hold a short-lived connection:
--   match connect cfg
--     Ok conn -> conn |> Repo.withConnection (fn c -> useTheConnection c)
--     Err e   -> Err e
-- where a bare `connect`/`close` pair leaks the connection on any path that skips the
-- close. For a long-running application, prefer to `connect` once and reuse the handle
-- (its pool reuses connections) over opening one per operation. Closing is
-- best-effort: a failure to close on teardown does not turn a successful body into an
-- error.
pub fn withConnection (conn: a) (body: fn a -> Result r Error) -> Result r Error where Adapter a =
    let outcome = body conn
    match close conn
        _ -> outcome

-- A query under construction over a repository: a filter, an ordering, a page
-- (offset and limit), a `distinct` flag, and an optional set-operation `plan`
-- accumulated before a terminal runs it. Opaque and threaded through the builder,
-- so it reads as a pipeline:
--   users |> Repo.query |> Repo.filter (...) |> Repo.orderBy Desc (...) |> Repo.toList
-- The ordering is a list of `(ascending?, column)` keys in major-to-minor order;
-- `lim` is negative for no limit and `off` is non-positive for no offset; `dist`
-- asks the terminal to drop duplicate rows (a `SELECT DISTINCT`). `plan` is `None`
-- for a plain single-table query and `Some` once a set operation (`union`/
-- `unionAll`/`intersect`/`except`) has combined two queries: it holds the captured
-- query plan the terminal runs in place of the single-table fetch, and the outer
-- fields (filter, ordering, page, distinct) then apply on top of the combined
-- result.
pub opaque type Query e a = { repo: Repo e a, pred: Quote (Map Text SqlValue -> Bool), orders: List (Bool, Text), lim: Int, off: Int, dist: Bool, plan: Option QueryPlan }

-- Start a query over a repository: every row, unordered, unpaged.
pub fn query (r: Repo e a) -> Query e a =
    Query { repo = r, pred = keepAll (), orders = [], lim = 0 - 1, off = 0, dist = false, plan = None }

-- One `filter` for both a query and a join. A query is narrowed by a one-row
-- predicate over its entity; a join by a two-row predicate over both. The class
-- ties the predicate's shape to the receiver through a functional dependency, so
-- `q` alone fixes `p`: a `Query e a` takes a `Quote (e -> Bool)` and a
-- `Join e f a`/`LeftJoin e f a` takes a `Quote (e -> f -> Bool)`. Writing a
-- two-row predicate on a query (or a one-row one on a join) is a compile-time
-- arity error, not a silent mismatch. (`filter`, not `where`, because `where`
-- introduces a constraint list in Ridge.)
pub class Refinable q p | q -> p =
    filter (pred: Quote p) (x: q) -> q

-- Project a query or join down to a chosen shape `s` — a `SELECT` whose list is
-- the columns the projection names, decoded into `s`. One verb across all three
-- receivers, the projection's arity following the receiver: a query projects one
-- entity (`fn (u: User) -> Summary { who = u.name }`), an inner join projects
-- both (`fn (u: User) (p: Post) -> Line { ... }`), a left join reads its right
-- side as `Option` (`fn (u: User) (p: Option Post) -> ...`). The result element
-- is the projection's own return type. `select` returns the whole list;
-- `selectFirst` returns the first row — a pushed-down `LIMIT 1` — or `None`.
pub class Projectable q p | q -> p =
    select      (proj: Quote p) (x: q) -> Result (List (Ret p))   Error
    selectFirst (proj: Quote p) (x: q) -> Result (Option (Ret p)) Error

-- One `orderBy` for a query and a join. A query orders by a one-row key over its
-- entity; a join by a two-row key over both, naming a column from either side
-- (`fn (u: User) (p: Post) -> p.title` orders by the right table). The class ties
-- the key's arity to the receiver through a functional dependency, so `q` alone
-- fixes `p`: a `Query e a` takes a `Quote (e -> k)` and a `Join e f a`/
-- `LeftJoin e f a` takes a `Quote (e -> f -> k)`. The key's column type `k` is
-- phantom — only the column it names is read — so a column of any type orders.
-- Keys order major-to-minor in the order added, each ascending or descending.
pub class Orderable q p | q -> p =
    orderBy (dir: SortOrder) (key: Quote p) (x: q) -> q

-- One set of scalar aggregates for a query and a join. `sumOf`/`minOf`/`maxOf`
-- fold the column an accessor names — a one-row accessor over a query
-- (`fn (u: User) -> u.age`), a two-row one over a join naming a column from
-- either side (`fn (u: User) (p: Post) -> p.amount` folds the right table) — and
-- answer that column's own type wrapped in `Option`, with `None` over an empty
-- match (a SQL aggregate of zero rows is NULL). `Ret p` is the column type — the
-- accessor's return — so a `Int` column answers `Option Int` and a `Text` column
-- `Option Text`. `avgOf` is always `Option Float`, since a SQL average is
-- fractional even over an integer column. The class ties the accessor's arity to
-- the receiver through the functional dependency `q -> p`, so one set of verbs
-- serves a query and a join alike and a wrong-arity accessor is a compile-time
-- error. Ordering and paging do not bound an aggregate — only the filter (and,
-- on a join, the join condition) narrows the folded rows.
pub class Aggregable q p | q -> p =
    sumOf (col: Quote p) (x: q) -> Result (Option (Ret p)) Error
    avgOf (col: Quote p) (x: q) -> Result (Option Float)   Error
    minOf (col: Quote p) (x: q) -> Result (Option (Ret p)) Error
    maxOf (col: Quote p) (x: q) -> Result (Option (Ret p)) Error

-- One pair of decode terminals for a query and a join. `toList` runs the
-- accumulated query (or join) and decodes every matching row; `first` runs it
-- for just the first row, decoded, or `None` when none match. The row shape
-- follows the receiver: a query decodes to its entity (`e`), an inner join to a
-- pair (`(e, f)`), and a left join to a pair whose right side is optional
-- (`(e, Option f)`) — a left row that matched no right row pairs with `None`.
-- `Rows q` is that row, a type-level projection over the receiver: it reduces to
-- `e` for a query, `(e, f)` for an inner join, and `(e, Option f)` for a left
-- join. The terminals take no quoted argument, so the row is named through this
-- projection on the receiver rather than a second class parameter — and because
-- `Rows (Query e a)` reduces to the bare entity, a query whose entity the call
-- site never pins still resolves it from the declared result type, exactly as the
-- old direct-`e` terminals did. It replaces the old per-receiver `toPairs`/
-- `toLeftPairs`, and gives a join a `first` it never had.
pub class Decodable q =
    toList (x: q) -> Result (List (Rows q))   Error
    first  (x: q) -> Result (Option (Rows q)) Error

-- One set of result-narrowing builder steps for a query and a join. `limit` keeps
-- at most `n` rows, `offset` skips the first `n`, and `distinct` drops duplicate
-- result rows (a `SELECT DISTINCT`); each answers the receiver, so they keep
-- composing in a pipeline. The class has the single receiver parameter and no
-- functional dependency: these verbs take no quoted argument and do not change the
-- row shape, so there is no second parameter to determine — a `Query e a`, a
-- `Join e f a`, and a `LeftJoin e f a` all carry the same three methods. On a join
-- the page and distinct apply to the joined rows a terminal decodes, the same way
-- a query's apply to its own rows. Two rows are duplicates when every selected
-- column matches, so `distinct` over whole entities removes exact repeats and over
-- a projection removes repeats of the projected columns; a second `distinct`
-- changes nothing. The backend pushes each down: `LIMIT`/`OFFSET`/`SELECT DISTINCT`
-- on Postgres, a take/drop/dedup on the in-memory store.
pub class Pageable q =
    limit    (n: Int) (x: q) -> q
    offset   (n: Int) (x: q) -> q
    distinct (x: q) -> q

-- The size-and-presence terminals for a query and a join. `count` answers how many
-- rows the receiver selects, `exists` whether it selects any at all — each counted
-- by the backend (a `COUNT(*)` push-down, or a one-row `LIMIT` for `exists`) rather
-- than by fetching the rows and measuring them. Neither takes a quoted argument, so
-- the receiver alone fixes the instance and the class has the single parameter `q`,
-- like `Pageable`/`Decodable`. Both reflect the receiver's filter (and, on a join,
-- its condition and post-join `WHERE`); like the scalar aggregates, ordering and
-- paging do not bound them, and a query's set-operation plan is honoured the way the
-- decode terminals honour it. An empty selection counts 0, so `exists` is false over
-- it. (LINQ's `Count`/`Any`.)
pub class Countable q =
    count  (x: q) -> Result Int Error
    exists (x: q) -> Result Bool Error

-- The universal-predicate terminal for a query and a join — the dual of `exists`.
-- `every` answers whether all the rows the receiver selects satisfy a further
-- predicate, comparing the receiver's row count against the count once the predicate
-- is folded in (so it is counted by the backend, never fetched). The predicate's
-- arity follows the receiver through the functional dependency `q -> p`, exactly as
-- `filter` does — a `Query e a` takes a one-row `Quote (e -> Bool)` and a
-- `Join e f a`/`LeftJoin e f a` a two-row `Quote (e -> f -> Bool)` — so a wrong-arity
-- predicate is a compile-time error. An empty selection is vacuously `true`. It sits
-- in its own class rather than beside `count`/`exists` because it carries the
-- predicate the dependency keys on, where they take no argument. (LINQ's `All`.)
pub class Every q p | q -> p =
    every (pred: Quote p) (x: q) -> Result Bool Error

-- `groupBy` over a query, an inner join, or a left join. The key accessor's arity
-- follows the receiver through the functional dependency `q -> p`, exactly as
-- `orderBy` does — a `Query e a` takes a one-row `Quote (e -> k)`, a `Join e f a`/
-- `LeftJoin e f a` a two-row `Quote (e -> f -> k)` naming a column from either side —
-- so a wrong-arity key is a compile-time error. It returns the unified `Grouped q p`
-- builder: both of its parameters are pinned here (the source `q` by the receiver,
-- the key accessor `p` by the lambda), so the result needs no projection. (LINQ's
-- `GroupBy`.)
pub class Groupable q p | q -> p =
    groupBy (key: Quote p) (x: q) -> Grouped q p

-- The per-source seam dispatch behind `summarize`. A single parameter, the source
-- `q` a `Grouped` builder groups, with no functional dependency (like `Countable`):
-- `summarize` is a plain function over `Grouped q p`, and its body calls `runGroups`
-- to run the `GROUP BY` (and any `HAVING`) against `q`'s own backend — a query's
-- `groupSummarize`, a join's `groupSummarizeJoin`/`groupSummarizeLeftJoin` — handing
-- it the key column and side, the projection tree, and the `HAVING` tree, and
-- returning the raw summarised rows for `summarize` to decode through `Row s`. It is
-- its own class so the seam call (one `Adapter a` context) stays separate from that
-- decode.
pub class Summarizable q =
    runGroups (src: q) (keyCol: Text) (keySide: Bool) (projTree: QExpr) (havingTree: QExpr) -> Result (List (Map Text SqlValue)) Error

-- `limit`/`offset`/`distinct` over a query, an inner join, or a left join are the
-- methods of the `Pageable q` class (declared above); the instances are defined
-- below, next to the `Refinable`/`Orderable`/`Decodable` ones. The query instance
-- sets the field on its `Query`, carrying every other field through.

-- The raw rows a query selects: a single-table `fetch` for a plain query, or the
-- captured set-operation plan run through `runPlan` once `union`/`intersect`/
-- `except` has combined two queries. Both answer the adapter-neutral row maps the
-- terminals decode.
fn queryRows (q: Query e a) -> Result (List (Map Text SqlValue)) Error where Adapter a =
    match q.plan
        None   -> fetch q.repo.adapter q.repo.table q.pred q.orders q.lim q.off q.dist
        Some _ -> runPlan q.repo.adapter (planOf q)

-- `toList` and `first` over a query are the methods of the `Decodable q p |
-- q -> p` class (declared above), so one pair of terminals decodes a query, an
-- inner join, or a left join. The instances are defined below, next to the
-- `Refinable`/`Projectable`/`Orderable`/`Aggregable` ones; the query instance
-- runs `queryRows` (a single-table fetch, or the captured set-operation plan)
-- and decodes through `decodeRows`/`firstDecoded`.

-- The query plan a query runs: for a plain single-table query, a `planScan` over
-- its table with the filter, ordering, page, and distinct it accumulated; for a
-- query a set operation already built, the stored combine plan wrapped in a
-- `planRefine` that re-applies the query's own outer filter, ordering, page, and
-- distinct on top of the combined result. A branch is captured this way, so
-- combining a combined query nests the plans — `(a ∪ b) ∪ c` runs as nested
-- operations.
fn planOf (q: Query e a) -> QueryPlan =
    match q.plan
        None   -> planScan q.repo.table q.pred.tree q.orders q.lim q.off q.dist
        Some p -> planRefine p q.pred.tree q.orders q.lim q.off q.dist

-- Combine two queries with a set operation into a new query that runs the combined
-- result. Each branch keeps its own filter, ordering, page, and distinct; the
-- result is a fresh query with empty outer state and the captured plan, so a
-- further `filter`/`orderBy`/`limit`/`offset`/`distinct` applies on top of the
-- combination and a terminal (`toList`/`first`) runs it.
fn combineWith (op: Text) (other: Query e a) (q: Query e a) -> Query e a =
    Query { repo = q.repo, pred = keepAll (), orders = [], lim = 0 - 1, off = 0, dist = false, plan = Some (planCombine op (planOf q) (planOf other)) }

-- Set union of two queries — every row in either, with duplicates removed
-- (`UNION`). Reads as a pipeline: `active |> Repo.union admins`. The result is a
-- query, so it keeps composing — `active |> Repo.union admins |> Repo.orderBy Asc
-- (fn (u: User) -> u.name) |> Repo.limit 10 |> Repo.toList` — and runs the
-- operation in the backend (a SQL `UNION` on Postgres, an in-memory combine for the
-- memory store), not by fetching both sides and merging in the caller. Both
-- branches range over the same entity and adapter, so the column shapes line up
-- and the type pins which backend runs it.
pub fn union (other: Query e a) (q: Query e a) -> Query e a =
    combineWith "UNION" other q

-- Set union keeping duplicates — every row in either branch, repeats and all
-- (`UNION ALL`). The multiset counterpart of `union`: where `union` drops the
-- duplicate rows the two branches share, `unionAll` keeps every one.
pub fn unionAll (other: Query e a) (q: Query e a) -> Query e a =
    combineWith "UNION ALL" other q

-- Set intersection — the rows present in both queries, with duplicates removed
-- (`INTERSECT`): `active |> Repo.intersect admins` keeps the users who are both.
pub fn intersect (other: Query e a) (q: Query e a) -> Query e a =
    combineWith "INTERSECT" other q

-- Set difference — the rows in the left query that are not in the right, with
-- duplicates removed (`EXCEPT`): `active |> Repo.except admins` keeps the active
-- non-admins. Order matters here, unlike `union`/`intersect`: the piped-in query
-- is the left side, the argument the right.
pub fn except (other: Query e a) (q: Query e a) -> Query e a =
    combineWith "EXCEPT" other q

-- Build an `Error` from a code and a message. A bare record literal cannot be
-- coerced to the nominal `Error` type in a plain function (only an instance-method
-- body, as the `SqlType` decoders are), so the unique-row terminals tag their
-- errors through this runtime helper, the same way the query trees are built by
-- `keepAll`/`quoteAnd`.
@ffi("ridge_rt", "mk_error", 2)
fn mkError (code: Text) (message: Text) -> Error

-- The one row the query selects, decoded; `None` when none match and an error
-- when more than one does. The lenient member of the pair: an empty result is
-- `Ok None`, not a failure — reach for `singleOrError` when "no row" should fail
-- too. Fetched with a two-row limit, so the backend stops the moment a second
-- match proves the result is not unique rather than scanning the whole table.
-- The filter and offset still apply; an ordering does not change which single row
-- is meant, only the error or the lone value. (LINQ's `SingleOrDefault`.)
pub fn single (q: Query e a) -> Result (Option e) Error where Adapter a, Row e =
    match fetch q.repo.adapter q.repo.table q.pred q.orders 2 q.off q.dist
        Err err -> Err err
        Ok rows ->
            match rows
                []          -> Ok None
                row :: rest ->
                    match rest
                        [] ->
                            match fromRow row
                                Err err -> Err err
                                Ok x    -> Ok (Some x)
                        _ -> Err (mkError "repo.single.many" "the query matched more than one row")

-- The one row the query selects, decoded, with the empty result an error rather
-- than `None`: this answers exactly one row or fails. The strict member of the
-- pair — `single` tolerates no match, this does not — for a query that is meant
-- to identify a unique row (a lookup by a key the schema makes unique). Like
-- `single` it fetches a second row only to detect a non-unique result.
-- (LINQ's `Single`.)
pub fn singleOrError (q: Query e a) -> Result e Error where Adapter a, Row e =
    match fetch q.repo.adapter q.repo.table q.pred q.orders 2 q.off q.dist
        Err err -> Err err
        Ok rows ->
            match rows
                []          -> Err (mkError "repo.single.empty" "the query matched no rows")
                row :: rest ->
                    match rest
                        [] ->
                            match fromRow row
                                Err err -> Err err
                                Ok x    -> Ok x
                        _ -> Err (mkError "repo.single.many" "the query matched more than one row")

-- `every` is the universal dual of `exists` and now joins it as a method of the
-- `Countable q p | q -> p` class (declared above), so one `every` tests a query, an
-- inner join, or a left join. Its instance compares the receiver's row count
-- against the count once the extra predicate is AND-folded in: they agree exactly
-- when no selected row fails it, and an empty selection is vacuously `true`.

-- Apply typed setters to the rows the query selects; answer how many changed.
-- The write terminal of the builder, mirroring how `Where(...).ExecuteUpdate(...)`
-- reads in LINQ: the accumulated filter picks the rows, the setters assign their
-- columns. Only the filter is used — ordering and paging do not constrain an
-- UPDATE — so it is the pipeline form of `setWhere`.
pub fn applySet (setters: List (Setter e)) (q: Query e a) -> Result Int Error where Adapter a =
    updateRows q.repo.adapter q.repo.table (settersToMap setters) q.pred

-- Decode the optional scalar a `SELECT func(col) …` aggregate returns into an
-- optional typed value. An aggregate over zero matching rows is SQL NULL: the
-- in-memory backend reports that as no row at all (`None` here), while the Postgres
-- renderer returns one row holding NULL. A present cell decodes through the column
-- type's `SqlType` codec; a NULL cell fails that typed decode and reads as `None`.
-- An aggregate cell is only ever its own type or SQL NULL — never a mismatched
-- value — so reading a failed decode as the empty fold is safe and folds both
-- backends to the same `None`.
fn decodeScalar (v: Option SqlValue) -> Result (Option w) Error where SqlType w =
    match v
        None    -> Ok None
        Some sv ->
            match fromSql sv
                Ok x  -> Ok (Some x)
                Err _ -> Ok None

-- The scalar aggregates `sumOf`/`avgOf`/`minOf`/`maxOf` are the methods of the
-- `Aggregable q p | q -> p` class (declared above), so one set of verbs folds a
-- column over a query (a one-row accessor) and over a join (a two-row accessor
-- naming a column from either side). The instances are defined below, next to the
-- `Refinable`/`Projectable`/`Orderable` ones; each runs the `aggregate` seam (for
-- a query) or the `aggregateJoin`/`aggregateLeftJoin` seam (for a join) and
-- decodes the scalar through `decodeScalar`.

-- A grouped builder under construction, unified across a query and a join. It is
-- threaded from `groupBy` through an optional `having` into `summarize`, so the
-- pipeline reads the same over either source:
--   users
--     |> Repo.query
--     |> Repo.groupBy (fn (u: User) -> u.dept)
--     |> Repo.having (fn g -> g.count > 3)
--     |> Repo.summarize (fn g -> DeptStats { dept = g.key, members = g.count })
-- `source` is the queryable it groups (a `Query`, `Join`, or `LeftJoin`); `keyCol`
-- and `keySide` name the group-key column and, for a join, which side it belongs to;
-- `having` is the captured `HAVING` tree, always-true until `having` narrows it. The
-- key-accessor type `p` is phantom — kept only so the `having`/`summarize` quotes can
-- read the key type `g.key` answers off it. Only the source's filter (and a join's
-- condition) bounds the rows: ordering and paging do not constrain a grouping, so the
-- source's ordering and page do not carry over. Opaque, never built by user code.
pub opaque type Grouped q p = { source: q, keyCol: Text, keySide: Bool, havingTree: QExpr }

-- `groupBy` over a query, an inner join, or a left join is the method of the
-- `Groupable q p | q -> p` class (instances below): the receiver fixes the key
-- accessor's arity, a one-row key for a query and a two-row key naming a column from
-- either side for a join. It returns the unified `Grouped q p` builder.

-- Keep only the groups whose aggregate condition holds — a SQL `HAVING`. The
-- predicate is written over the group with the same vocabulary as `summarize`:
--   |> Repo.having (fn g -> g.count > 3)
--   |> Repo.having (fn g -> g.sum (fn (u: User) -> u.salary) >= 100000)
-- Several conditions combine in one predicate with `&&`/`||`; a later `having`
-- replaces an earlier one. The quote ranges over the `Grouped q p` handle, so over a
-- join its column accessors name a column from either side.
pub fn having (pred: Quote (Grouped q p -> Bool)) (g: Grouped q p) -> Grouped q p =
    Grouped { source = g.source, keyCol = g.keyCol, keySide = g.keySide, havingTree = pred.tree }

-- Summarize each surviving group into a named record built from group aggregates:
--   fn g -> DeptStats { dept    = g.key
--                     , members = g.count
--                     , payroll = g.sum (fn (u: User) -> u.salary) }
-- Each field is a group aggregate — `g.key`, `g.count`, or `g.sum`/`avg`/`min`/
-- `max` over a column accessor — and the named record fixes the result shape `s`,
-- which `Row s` decodes. The `Summarizable q` instance runs the `GROUP BY` (and any
-- `HAVING`) against the source's own seam — a query, an inner join, or a left join —
-- and returns one row per group, ordered by the key; `summarize` then decodes each.
-- This is the grouped dual of `select`: a projection, but over groups instead of rows.
pub fn summarize (proj: Quote (Grouped q p -> s)) (g: Grouped q p) -> Result (List s) Error where Summarizable q, Row s =
    match runGroups g.source g.keyCol g.keySide proj.tree g.havingTree
        Err err -> Err err
        Ok rows -> decodeRows rows

-- A join under construction: the left query, the right repository, and a quoted
-- condition over both entities. Opaque and threaded from `joinOn` into a
-- terminal, so it reads as a pipeline:
--   users
--     |> Repo.query
--     |> Repo.joinOn posts (fn (u: User) (p: Post) -> u.id == p.authorId)
--     |> Repo.toList
-- The condition is written against both records at the call site: its left
-- columns range over the left entity and its right over the right, captured as a
-- query tree that tags each side so the two tables never collide.
pub opaque type Join e f a = { left: Query e a, right: Repo f a, cond: Quote (Map Text SqlValue -> Map Text SqlValue -> Bool), where2: Quote (Map Text SqlValue -> Map Text SqlValue -> Bool), orders: List (Bool, Bool, Text), lim: Int, off: Int, dist: Bool }

-- A join of three or more tables, built by chaining `joinOn` past the first.
-- The left side `source` is itself a join — a binary `Join` for the third table,
-- another `Joined` for the fourth and beyond — so the chain nests left as it
-- grows. The new right table `f` joins onto the whole composite on a condition
-- over every table so far, written as a positional lambda whose parameters range
-- over the leaves left to right (`fn u p c -> p.id == c.post`). Opaque and
-- threaded from `joinOn` into a terminal, exactly like the binary `Join`:
--   users
--     |> Repo.query
--     |> Repo.joinOn posts    (fn u p   -> u.id == p.author)
--     |> Repo.joinOn comments (fn u p c -> p.id == c.post)
--     |> Repo.toList
-- The result decodes into a left-nested pair `((User, Post), Comment)`, one level
-- of nesting per table past the first.
pub opaque type Joined q f a = { source: q, right: Repo f a, cond: Quote (Map Text SqlValue -> Map Text SqlValue -> Bool), where2: Quote (Map Text SqlValue -> Map Text SqlValue -> Bool), orders: List (Bool, Bool, Text), lim: Int, off: Int, dist: Bool }

-- A left outer join extending a composite of three or more tables, built by
-- chaining `leftJoinOn` past the first join. The same shape as `Joined`: the
-- `source` is the composite already accumulated and `right` the new table joined
-- onto it, but the terminal keeps every composite row and reads the new table as
-- `Option` — a composite row that matched no new row pairs with `None`. The result
-- decodes into `(Rows source, Option f)`:
--
--     users
--       |> Repo.query
--       |> Repo.joinOn     posts    (fn u p   -> u.id == p.author)
--       |> Repo.leftJoinOn comments (fn u p c -> p.id == c.post)
--       |> Repo.toList
--
-- yields `List ((User, Post), Option Comment)`.
pub opaque type LeftJoined q f a = { source: q, right: Repo f a, cond: Quote (Map Text SqlValue -> Map Text SqlValue -> Bool), where2: Quote (Map Text SqlValue -> Map Text SqlValue -> Bool), orders: List (Bool, Bool, Text), lim: Int, off: Int, dist: Bool }

-- A right outer join extending a composite of three or more tables, built by
-- chaining `rightJoinOn` past the first join. The mirror of `LeftJoined`: the
-- terminal keeps every new-table row and reads the whole accumulated composite as
-- `Option` — a new row that matched no composite row pairs with `None` on the
-- composite side, all of its leaves absent together. The result decodes into
-- `(Option (Rows source), f)`:
--
--     users
--       |> Repo.query
--       |> Repo.joinOn      posts    (fn u p   -> u.id == p.author)
--       |> Repo.rightJoinOn comments (fn u p c -> p.id == c.post)
--       |> Repo.toList
--
-- yields `List (Option (User, Post), Comment)`.
pub opaque type RightJoined q f a = { source: q, right: Repo f a, cond: Quote (Map Text SqlValue -> Map Text SqlValue -> Bool), where2: Quote (Map Text SqlValue -> Map Text SqlValue -> Bool), orders: List (Bool, Bool, Text), lim: Int, off: Int, dist: Bool }

-- A full outer join extending a composite of three or more tables, built by
-- chaining `fullJoinOn` past the first join. The union of a left and a right
-- extend: the terminal keeps every composite row and every new-table row, reading
-- whichever matched none as `None` — the composite optional as a unit, the new
-- table optional. The result decodes into `(Option (Rows source), Option f)`:
--
--     users
--       |> Repo.query
--       |> Repo.joinOn     posts    (fn u p   -> u.id == p.author)
--       |> Repo.fullJoinOn comments (fn u p c -> p.id == c.post)
--       |> Repo.toList
--
-- yields `List (Option (User, Post), Option Comment)`.
pub opaque type FullJoined q f a = { source: q, right: Repo f a, cond: Quote (Map Text SqlValue -> Map Text SqlValue -> Bool), where2: Quote (Map Text SqlValue -> Map Text SqlValue -> Bool), orders: List (Bool, Bool, Text), lim: Int, off: Int, dist: Bool }

-- Start or extend an inner join. One verb across every receiver: a query pairs
-- with the right repository into a binary `Join`, and a join (binary or nested)
-- absorbs one more table into a `Joined`. The receiver fixes both the result
-- through `JoinResult q f` — `Join e f a` from a query, `Joined q f a` from a
-- composite — and the condition's shape through `JoinCond q f`, whose arity and
-- per-leaf entities follow the receiver's leaves so a wrong-arity condition is a
-- compile-time error. The accumulated filter, ordering, and page carry forward
-- (a query's ordering lifts in as left-side keys); the join brings the new table.
pub class Joinable q =
    joinOn (right: Repo f a) (cond: Quote (Map Text SqlValue -> Map Text SqlValue -> Bool)) (x: q) -> JoinResult q f

-- A query's `joinOn`: the binary inner join, identical to the original builder.
-- It pairs the left query with the right repository, lifting the query's
-- accumulated ordering in as left-side keys, and produces a `Join e f a` that
-- keeps the whole existing two-table vocabulary.
instance Joinable (Query e a) =
    joinOn (right: Repo f a) (cond: Quote (Map Text SqlValue -> Map Text SqlValue -> Bool)) (x: Query e a) -> Join e f a =
        Join { left = x, right = right, cond = cond, where2 = keepAll2 (), orders = liftOrders x.orders, lim = x.lim, off = x.off, dist = x.dist }

-- A binary join's `joinOn`: absorb a third table. The existing two-table join
-- becomes the `source` of a `Joined`, the new repository its right, and the
-- accumulated page/ordering carry across unchanged.
instance Joinable (Join e g a) =
    joinOn (right: Repo f a) (cond: Quote (Map Text SqlValue -> Map Text SqlValue -> Bool)) (x: Join e g a) -> Joined (Join e g a) f a =
        Joined { source = x, right = right, cond = cond, where2 = keepAll2 (), orders = x.orders, lim = x.lim, off = x.off, dist = x.dist }

-- A nested join's `joinOn`: absorb one more table onto a composite already three
-- or more wide. The chain nests left another level, the new repository joining
-- onto everything accumulated so far.
instance Joinable (Joined q g a) =
    joinOn (right: Repo f a) (cond: Quote (Map Text SqlValue -> Map Text SqlValue -> Bool)) (x: Joined q g a) -> Joined (Joined q g a) f a =
        Joined { source = x, right = right, cond = cond, where2 = keepAll2 (), orders = x.orders, lim = x.lim, off = x.off, dist = x.dist }

-- The recursion a nested join's terminal stands on. `JoinShape` walks the
-- left-nested source of a `Joined` to count its leaves, rebuild its plan, and
-- decode a flat prefixed result row into the nested row. The source `q` of a
-- `Joined` is always a binary `Join` (the base) or another `Joined` (one level
-- deeper), never a bare query — a query's `joinOn` yields a binary `Join`, so a
-- `Joined` only ever forms over a join.
class JoinShape q =
    -- How many leaf tables the receiver carries: 2 for a binary join, one more
    -- per nesting level.
    joinedLeaves (w: Option q) -> Int
    -- The receiver's query plan, a left-nested `PlanJoin` over its leaves.
    joinedSourcePlan (x: q) -> QueryPlan
    -- Decode one flat result row (leaves under `t0$`, `t1$`, … prefixes) into the
    -- receiver's nested row — `(e, f)` for a binary join, `(Rows q, f)` deeper.
    decodeJoined (w: Option q) (row: Map Text SqlValue) -> Result (Rows q) Error

-- The base of the recursion: a binary join is two leaves under `t0$`/`t1$`, its
-- plan the existing binary `innerJoinPlan`, its row the pair `(e, f)`.
instance JoinShape (Join e f a) where Row f, Row e =
    joinedLeaves (w: Option (Join e f a)) -> Int = 2
    joinedSourcePlan (x: Join e f a) -> QueryPlan =
        innerJoinPlan x (0 - 1) (rowColumns (entityWitness x.left.repo)) (rowColumns (entityWitness x.right))
    -- Decode the t0$/t1$ pair by delegating to `decodePrefixedPairs` over a
    -- one-row list: a direct `fromRow` for each side would, inside an instance
    -- body, resolve both to the same `Row` dictionary (the lowering picks a
    -- context dict by class alone), so the two-row decode is threaded through the
    -- free helper whose call site distinguishes the two `Row` dicts by position —
    -- exactly as the binary `Decodable (Join e f a)` instance does.
    decodeJoined (w: Option (Join e f a)) (row: Map Text SqlValue) -> Result (e, f) Error =
        match decodePrefixedPairs [row]
            Err err     -> Err err
            Ok []       -> Err (mkError "repo.join.decode" "the join produced no row to decode")
            Ok (p :: _) -> Ok p

-- The recursive step: a nested join is its source plus one more leaf. Its leaf
-- count, plan, and row each extend the source's by one — the new table joins onto
-- the whole composite, decoded under the next `t<n>$` prefix.
instance JoinShape (Joined q f a) where JoinShape q, Row f =
    joinedLeaves (w: Option (Joined q f a)) -> Int =
        joinedLeaves (innerJoinWitness w) + 1
    joinedSourcePlan (x: Joined q f a) -> QueryPlan =
        planJoin "INNER" (joinedSourcePlan x.source) (planScan x.right.table (keepAllTree ()) [] (0 - 1) 0 false) x.cond.tree x.where2.tree x.orders (0 - 1) 0 false [] (rowColumns (entityWitness x.right))
    decodeJoined (w: Option (Joined q f a)) (row: Map Text SqlValue) -> Result (Rows q, f) Error =
        match decodeJoined (innerJoinWitness w) row
            Err err -> Err err
            Ok qr ->
                match fromRow (unprefix (leafPrefix (joinedLeaves (innerJoinWitness w))) row)
                    Err err -> Err err
                    Ok fv -> Ok (qr, fv)

-- Phantom witnesses: narrow a `Joined`'s type to its source's, so the recursion
-- can ask the source for its leaf count, plan, and decoder.
fn innerJoinWitness (w: Option (Joined q f a)) -> Option q = None
fn sourceWitness (x: Joined q f a) -> Option q = None

-- The column prefix a leaf at index `n` carries in a joined result row: `t<n>$`.
fn leafPrefix (n: Int) -> Text = Text.concat (Text.concat "t" (Int.toText n)) "$"

-- The plan of a whole `Joined`: its source's left-nested plan with the new right
-- table joined on, carrying the top-level page/ordering/distinct the terminal
-- runs it with.
fn joinedPlan (x: Joined q f a) (lim: Int) -> QueryPlan where JoinShape q, Row f =
    planJoin "INNER" (joinedSourcePlan x.source) (planScan x.right.table (keepAllTree ()) [] (0 - 1) 0 false) x.cond.tree x.where2.tree x.orders lim x.off x.dist [] (rowColumns (entityWitness x.right))

-- Decode every flat result row into the nested pair `(Rows q, f)`: the source's
-- row from `decodeJoined`, the new table from its `t<n>$` leaf where `n` is the
-- source's leaf count.
fn decodeJoinedRows (w: Option q) (n: Int) (rows: List (Map Text SqlValue)) -> Result (List (Rows q, f)) Error where JoinShape q, Row f =
    match rows
        []        -> Ok []
        r :: rest ->
            match decodeJoined w r
                Err err -> Err err
                Ok qr ->
                    match fromRow (unprefix (leafPrefix n) r)
                        Err err -> Err err
                        Ok fv ->
                            match decodeJoinedRows w n rest
                                Err err -> Err err
                                Ok more -> Ok ((qr, fv) :: more)

fn firstDecodedJoined (w: Option q) (n: Int) (rows: List (Map Text SqlValue)) -> Result (Option (Rows q, f)) Error where JoinShape q, Row f =
    match rows
        []     -> Ok None
        r :: _ ->
            match decodeJoined w r
                Err err -> Err err
                Ok qr ->
                    match fromRow (unprefix (leafPrefix n) r)
                        Err err -> Err err
                        Ok fv -> Ok (Some (qr, fv))

-- `toList`/`first` over a nested join: run the flattened plan and decode each row
-- into the nested tuple `(Rows q, f)`. The plan, decode, and row shape all come
-- from `JoinShape q`, so the same two terminals serve every depth.
instance Decodable (Joined q f a) where Adapter a, JoinShape q, Row f =
    toList (x: Joined q f a) -> Result (List (Rows q, f)) Error =
        match runPlan x.right.adapter (joinedPlan x x.lim)
            Err err -> Err err
            Ok rows -> decodeJoinedRows (sourceWitness x) (joinedLeaves (sourceWitness x)) rows
    first (x: Joined q f a) -> Result (Option (Rows q, f)) Error =
        match runPlan x.right.adapter (joinedPlan x 1)
            Err err -> Err err
            Ok rows -> firstDecodedJoined (sourceWitness x) (joinedLeaves (sourceWitness x)) rows

-- `toList` and `first` over an inner join are the `Decodable (Join e f a) …`
-- methods (instance below), so the join shares the query's decode terminals:
-- `toList` decodes every matched row pair into `(e, f)`, `first` the first pair.

-- A left (outer) join under construction. It carries the same three parts as an
-- inner `Join` — the left query, the right repository, and a quoted condition
-- over both entities — but its terminal keeps every left row: a left row that
-- matches no right row is still returned, with the right side reported as
-- `None`. Opaque and threaded from `leftJoinOn` into a decode terminal:
--   users
--     |> Repo.query
--     |> Repo.leftJoinOn posts (fn (u: User) (p: Post) -> u.id == p.authorId)
--     |> Repo.toList
pub opaque type LeftJoin e f a = { left: Query e a, right: Repo f a, cond: Quote (Map Text SqlValue -> Map Text SqlValue -> Bool), where2: Quote (Map Text SqlValue -> Map Text SqlValue -> Bool), orders: List (Bool, Bool, Text), lim: Int, off: Int, dist: Bool }

-- Start or extend a left outer join. One verb across every receiver, the LEFT
-- dual of `joinOn`: a query pairs with the right repository into a binary
-- `LeftJoin`, and a join (binary or nested) absorbs one more table into a
-- `LeftJoined`, keeping every composite row and reading the new table as `Option`.
-- The receiver fixes both the result through `LeftJoinResult q f` and the
-- condition's shape through `JoinCond q f` (the same condition an inner join takes
-- — its nullability lives in the result, not the condition). Unlike `joinOn`, a
-- composite row with no matching new row is kept, the new entity reported as
-- `None`.
pub class LeftJoinable q =
    leftJoinOn (right: Repo f a) (cond: Quote (Map Text SqlValue -> Map Text SqlValue -> Bool)) (x: q) -> LeftJoinResult q f

-- A query's `leftJoinOn`: the binary left outer join, identical to the original
-- builder. The left query's accumulated ordering lifts in as left-side keys, and
-- it produces a `LeftJoin e f a` that carries the whole left-join vocabulary.
instance LeftJoinable (Query e a) =
    leftJoinOn (right: Repo f a) (cond: Quote (Map Text SqlValue -> Map Text SqlValue -> Bool)) (x: Query e a) -> LeftJoin e f a =
        LeftJoin { left = x, right = right, cond = cond, where2 = keepAll2 (), orders = liftOrders x.orders, lim = x.lim, off = x.off, dist = x.dist }

-- A binary join's `leftJoinOn`: left-join a third table onto the inner pair. The
-- existing two-table join becomes the `source` of a `LeftJoined`, the new
-- repository its right, read optional in the result.
instance LeftJoinable (Join e g a) =
    leftJoinOn (right: Repo f a) (cond: Quote (Map Text SqlValue -> Map Text SqlValue -> Bool)) (x: Join e g a) -> LeftJoined (Join e g a) f a =
        LeftJoined { source = x, right = right, cond = cond, where2 = keepAll2 (), orders = x.orders, lim = x.lim, off = x.off, dist = x.dist }

-- A nested inner join's `leftJoinOn`: left-join one more table onto a composite
-- already three or more wide.
instance LeftJoinable (Joined q g a) =
    leftJoinOn (right: Repo f a) (cond: Quote (Map Text SqlValue -> Map Text SqlValue -> Bool)) (x: Joined q g a) -> LeftJoined (Joined q g a) f a =
        LeftJoined { source = x, right = right, cond = cond, where2 = keepAll2 (), orders = x.orders, lim = x.lim, off = x.off, dist = x.dist }

-- A nested left join's `leftJoinOn`: chain another left join onto a composite that
-- already ends in one, nesting the source one level deeper.
instance LeftJoinable (LeftJoined q g a) =
    leftJoinOn (right: Repo f a) (cond: Quote (Map Text SqlValue -> Map Text SqlValue -> Bool)) (x: LeftJoined q g a) -> LeftJoined (LeftJoined q g a) f a =
        LeftJoined { source = x, right = right, cond = cond, where2 = keepAll2 (), orders = x.orders, lim = x.lim, off = x.off, dist = x.dist }

-- The recursion a nested left join's terminal stands on. A `LeftJoined` is its
-- source plus one more leaf, read optional: its leaf count, plan, and row each
-- extend the source's by one. The source is always present (a left join keeps
-- every left row), so only the new leaf decodes through `decodeOptSide`.
instance JoinShape (LeftJoined q f a) where JoinShape q, Row f =
    joinedLeaves (w: Option (LeftJoined q f a)) -> Int =
        joinedLeaves (leftInnerWitness w) + 1
    joinedSourcePlan (x: LeftJoined q f a) -> QueryPlan =
        planJoin "LEFT" (joinedSourcePlan x.source) (planScan x.right.table (keepAllTree ()) [] (0 - 1) 0 false) x.cond.tree x.where2.tree x.orders (0 - 1) 0 false [] (rowColumns (entityWitness x.right))
    decodeJoined (w: Option (LeftJoined q f a)) (row: Map Text SqlValue) -> Result (Rows q, Option f) Error =
        match decodeJoined (leftInnerWitness w) row
            Err err -> Err err
            Ok srcRow ->
                match decodeOptSide (leafPrefix (joinedLeaves (leftInnerWitness w))) row
                    Err err  -> Err err
                    Ok optF  -> Ok (srcRow, optF)

-- Phantom witnesses: narrow a `LeftJoined`'s type to its source's, so the
-- recursion can read the source row count and decoder from the type alone.
fn leftInnerWitness (w: Option (LeftJoined q f a)) -> Option q = None
fn leftSourceWitness (x: LeftJoined q f a) -> Option q = None

-- The plan of a whole `LeftJoined`: its source's left-nested plan with the new
-- right table LEFT-joined on, carrying the top-level page/ordering/distinct the
-- terminal runs it with.
fn leftJoinedPlan (x: LeftJoined q f a) (lim: Int) -> QueryPlan where JoinShape q, Row f =
    planJoin "LEFT" (joinedSourcePlan x.source) (planScan x.right.table (keepAllTree ()) [] (0 - 1) 0 false) x.cond.tree x.where2.tree x.orders lim x.off x.dist [] (rowColumns (entityWitness x.right))

-- Decode each flat result row of a `LeftJoined` into `(Rows q, Option f)`: the
-- source row from `decodeJoined`, the new table from its `t<n>$` leaf where `n` is
-- the source's leaf count — `Some` when it matched, `None` when the composite row
-- matched no new row.
fn decodeLeftJoinedRows (w: Option q) (n: Int) (rows: List (Map Text SqlValue)) -> Result (List (Rows q, Option f)) Error where JoinShape q, Row f =
    match rows
        []        -> Ok []
        r :: rest ->
            match decodeJoined w r
                Err err -> Err err
                Ok srcRow ->
                    match decodeOptSide (leafPrefix n) r
                        Err err -> Err err
                        Ok optF ->
                            match decodeLeftJoinedRows w n rest
                                Err err -> Err err
                                Ok more -> Ok ((srcRow, optF) :: more)

fn firstDecodedLeftJoined (w: Option q) (n: Int) (rows: List (Map Text SqlValue)) -> Result (Option (Rows q, Option f)) Error where JoinShape q, Row f =
    match rows
        []     -> Ok None
        r :: _ ->
            match decodeJoined w r
                Err err -> Err err
                Ok srcRow ->
                    match decodeOptSide (leafPrefix n) r
                        Err err -> Err err
                        Ok optF -> Ok (Some (srcRow, optF))

-- `toList`/`first` over a nested left join: run the flattened LEFT plan and decode
-- each row into `(Rows q, Option f)`. The leaf count and decoder both come from
-- `JoinShape q`, so the same two terminals serve every depth.
instance Decodable (LeftJoined q f a) where Adapter a, JoinShape q, Row f =
    toList (x: LeftJoined q f a) -> Result (List (Rows q, Option f)) Error =
        match runPlan x.right.adapter (leftJoinedPlan x x.lim)
            Err err -> Err err
            Ok rows -> decodeLeftJoinedRows (leftSourceWitness x) (joinedLeaves (leftSourceWitness x)) rows
    first (x: LeftJoined q f a) -> Result (Option (Rows q, Option f)) Error =
        match runPlan x.right.adapter (leftJoinedPlan x 1)
            Err err -> Err err
            Ok rows -> firstDecodedLeftJoined (leftSourceWitness x) (joinedLeaves (leftSourceWitness x)) rows

-- `toList` and `first` over a left join are the `Decodable (LeftJoin e f a) …`
-- methods (instance below): `toList` decodes each row into the left entity
-- paired with the right entity, or with `None` where the left row matched no
-- right row; `first` keeps the first such pair.

-- A cross join: pair a query with a right repository and no condition, so every
-- left row matches every right row — the cartesian product of the two tables. A
-- cross join is just an inner join whose condition is always true, so it builds a
-- `Join e f a` with `keepAll2` for both the `ON` and the post-join `WHERE` and
-- inherits the whole join vocabulary. A later `filter` narrows the product into a
-- non-equi join, `select` projects both sides, and the terminals decode each pair
-- into `(e, f)`:
--
--     users
--       |> Repo.query
--       |> Repo.crossJoin colors
pub fn crossJoin (right: Repo f a) (q: Query e a) -> Join e f a =
    Join { left = q, right = right, cond = keepAll2 (), where2 = keepAll2 (), orders = liftOrders q.orders, lim = q.lim, off = q.off, dist = q.dist }

-- A right (outer) join under construction. The mirror of `LeftJoin`: the same left
-- query, right repository, and quoted condition over both entities, but its terminal
-- keeps every RIGHT row — a right row that matches no left row is still returned,
-- with the left side reported as `None`. Opaque and threaded from `rightJoinOn` into
-- a decode terminal:
--   users
--     |> Repo.query
--     |> Repo.rightJoinOn posts (fn (u: User) (p: Post) -> u.id == p.authorId)
--     |> Repo.toList
pub opaque type RightJoin e f a = { left: Query e a, right: Repo f a, cond: Quote (Map Text SqlValue -> Map Text SqlValue -> Bool), where2: Quote (Map Text SqlValue -> Map Text SqlValue -> Bool), orders: List (Bool, Bool, Text), lim: Int, off: Int, dist: Bool }

-- Start a right outer join from a query: pair it with a right repository on a quoted
-- Start or extend a right outer join. One verb across every receiver, the RIGHT
-- dual of `joinOn`/`leftJoinOn`: a query pairs with the right repository into a
-- binary `RightJoin`, and a composite absorbs one more table into a `RightJoined`,
-- keeping every new-table row and reading the whole composite as `Option`. The
-- receiver fixes the result through `RightJoinResult q f` and the condition's shape
-- through `JoinCond q f`. A new row that matched no composite row is kept, the whole
-- composite reported as `None`.
pub class RightJoinable q =
    rightJoinOn (right: Repo f a) (cond: Quote (Map Text SqlValue -> Map Text SqlValue -> Bool)) (x: q) -> RightJoinResult q f

-- A query's `rightJoinOn`: the binary right outer join, identical to the original
-- builder.
instance RightJoinable (Query e a) =
    rightJoinOn (right: Repo f a) (cond: Quote (Map Text SqlValue -> Map Text SqlValue -> Bool)) (x: Query e a) -> RightJoin e f a =
        RightJoin { left = x, right = right, cond = cond, where2 = keepAll2 (), orders = liftOrders x.orders, lim = x.lim, off = x.off, dist = x.dist }

-- A binary join's `rightJoinOn`: right-join a third table onto the inner pair, the
-- composite read optional in the result.
instance RightJoinable (Join e g a) =
    rightJoinOn (right: Repo f a) (cond: Quote (Map Text SqlValue -> Map Text SqlValue -> Bool)) (x: Join e g a) -> RightJoined (Join e g a) f a =
        RightJoined { source = x, right = right, cond = cond, where2 = keepAll2 (), orders = x.orders, lim = x.lim, off = x.off, dist = x.dist }

-- A nested inner join's `rightJoinOn`.
instance RightJoinable (Joined q g a) =
    rightJoinOn (right: Repo f a) (cond: Quote (Map Text SqlValue -> Map Text SqlValue -> Bool)) (x: Joined q g a) -> RightJoined (Joined q g a) f a =
        RightJoined { source = x, right = right, cond = cond, where2 = keepAll2 (), orders = x.orders, lim = x.lim, off = x.off, dist = x.dist }

-- A nested left join's `rightJoinOn`.
instance RightJoinable (LeftJoined q g a) =
    rightJoinOn (right: Repo f a) (cond: Quote (Map Text SqlValue -> Map Text SqlValue -> Bool)) (x: LeftJoined q g a) -> RightJoined (LeftJoined q g a) f a =
        RightJoined { source = x, right = right, cond = cond, where2 = keepAll2 (), orders = x.orders, lim = x.lim, off = x.off, dist = x.dist }

-- A nested right join's `rightJoinOn`: chain another right join onto a composite
-- that already ends in one.
instance RightJoinable (RightJoined q g a) =
    rightJoinOn (right: Repo f a) (cond: Quote (Map Text SqlValue -> Map Text SqlValue -> Bool)) (x: RightJoined q g a) -> RightJoined (RightJoined q g a) f a =
        RightJoined { source = x, right = right, cond = cond, where2 = keepAll2 (), orders = x.orders, lim = x.lim, off = x.off, dist = x.dist }

-- Whether a composite spanning leaves `0`..`n-1` is present in a result row: a
-- right or full step null-extends the whole composite as a unit, so it is present
-- exactly when any one of its leaves is. The dual of `sidePresent` over a span — for
-- the in-memory backend an absent composite drops every leaf's columns; for Postgres
-- each leaf carries a presence marker that null-extends with it.
fn compositePresent (n: Int) (row: Map Text SqlValue) -> Bool =
    anyLeafPresent 0 n row

fn anyLeafPresent (i: Int) (n: Int) (row: Map Text SqlValue) -> Bool =
    if i >= n then false
    else if sidePresent (leafPrefix i) row then true
    else anyLeafPresent (i + 1) n row

-- The recursion a nested right join's terminal stands on. A `RightJoined` decodes
-- the always-present new leaf first, then the whole composite source optionally: the
-- source row when any composite leaf is present, `None` when the new row matched no
-- composite row and every composite leaf is absent.
instance JoinShape (RightJoined q f a) where JoinShape q, Row f =
    joinedLeaves (w: Option (RightJoined q f a)) -> Int =
        joinedLeaves (rightInnerWitness w) + 1
    joinedSourcePlan (x: RightJoined q f a) -> QueryPlan =
        planJoin "RIGHT" (joinedSourcePlan x.source) (planScan x.right.table (keepAllTree ()) [] (0 - 1) 0 false) x.cond.tree x.where2.tree x.orders (0 - 1) 0 false [] (rowColumns (entityWitness x.right))
    decodeJoined (w: Option (RightJoined q f a)) (row: Map Text SqlValue) -> Result (Option (Rows q), f) Error =
        match fromRow (unprefix (leafPrefix (joinedLeaves (rightInnerWitness w))) row)
            Err err -> Err err
            Ok leafF ->
                match decodeRightOptComposite (rightInnerWitness w) (joinedLeaves (rightInnerWitness w)) row
                    Err err   -> Err err
                    Ok optSrc -> Ok (optSrc, leafF)

-- Phantom witnesses: narrow a `RightJoined`'s type to its source's.
fn rightInnerWitness (w: Option (RightJoined q f a)) -> Option q = None
fn rightSourceWitness (x: RightJoined q f a) -> Option q = None

-- Decode the composite source of a right join optionally: its row when present (any
-- composite leaf survives), `None` when the whole composite was null-extended.
fn decodeRightOptComposite (w: Option q) (n: Int) (r: Map Text SqlValue) -> Result (Option (Rows q)) Error where JoinShape q =
    if compositePresent n r then
        match decodeJoined w r
            Err err   -> Err err
            Ok srcRow -> Ok (Some srcRow)
    else Ok None

-- The plan of a whole `RightJoined`: its source's plan with the new right table
-- RIGHT-joined on, carrying the top-level page/ordering/distinct.
fn rightJoinedPlan (x: RightJoined q f a) (lim: Int) -> QueryPlan where JoinShape q, Row f =
    planJoin "RIGHT" (joinedSourcePlan x.source) (planScan x.right.table (keepAllTree ()) [] (0 - 1) 0 false) x.cond.tree x.where2.tree x.orders lim x.off x.dist [] (rowColumns (entityWitness x.right))

-- Decode each flat result row of a `RightJoined` into `(Option (Rows q), f)`: the
-- new table from its `t<n>$` leaf (always present), the composite source optionally.
fn decodeRightJoinedRows (w: Option q) (n: Int) (rows: List (Map Text SqlValue)) -> Result (List (Option (Rows q), f)) Error where JoinShape q, Row f =
    match rows
        []        -> Ok []
        r :: rest ->
            match fromRow (unprefix (leafPrefix n) r)
                Err err -> Err err
                Ok leafF ->
                    match decodeRightOptComposite w n r
                        Err err -> Err err
                        Ok optSrc ->
                            match decodeRightJoinedRows w n rest
                                Err err -> Err err
                                Ok more -> Ok ((optSrc, leafF) :: more)

fn firstDecodedRightJoined (w: Option q) (n: Int) (rows: List (Map Text SqlValue)) -> Result (Option (Option (Rows q), f)) Error where JoinShape q, Row f =
    match rows
        []     -> Ok None
        r :: _ ->
            match fromRow (unprefix (leafPrefix n) r)
                Err err -> Err err
                Ok leafF ->
                    match decodeRightOptComposite w n r
                        Err err   -> Err err
                        Ok optSrc -> Ok (Some (optSrc, leafF))

-- `toList`/`first` over a nested right join: run the flattened RIGHT plan and decode
-- each row into `(Option (Rows q), f)`.
instance Decodable (RightJoined q f a) where Adapter a, JoinShape q, Row f =
    toList (x: RightJoined q f a) -> Result (List (Option (Rows q), f)) Error =
        match runPlan x.right.adapter (rightJoinedPlan x x.lim)
            Err err -> Err err
            Ok rows -> decodeRightJoinedRows (rightSourceWitness x) (joinedLeaves (rightSourceWitness x)) rows
    first (x: RightJoined q f a) -> Result (Option (Option (Rows q), f)) Error =
        match runPlan x.right.adapter (rightJoinedPlan x 1)
            Err err -> Err err
            Ok rows -> firstDecodedRightJoined (rightSourceWitness x) (joinedLeaves (rightSourceWitness x)) rows

-- `toList` and `first` over a right join are the `Decodable (RightJoin e f a) …`
-- methods (instance below): `toList` decodes each row into the right entity paired
-- with the left entity, or with `None` where the right row matched no left row;
-- `first` keeps the first such pair.

-- A full (outer) join under construction. The union of a left and a right join:
-- the same left query, right repository, and quoted condition over both entities,
-- but its terminal keeps every row of BOTH tables — an unmatched left row pairs
-- with `None` on the right, an unmatched right row pairs with `None` on the left.
-- Opaque and threaded from `fullJoinOn` into a decode terminal:
--   users
--     |> Repo.query
--     |> Repo.fullJoinOn posts (fn (u: User) (p: Post) -> u.id == p.authorId)
--     |> Repo.toList
pub opaque type FullJoin e f a = { left: Query e a, right: Repo f a, cond: Quote (Map Text SqlValue -> Map Text SqlValue -> Bool), where2: Quote (Map Text SqlValue -> Map Text SqlValue -> Bool), orders: List (Bool, Bool, Text), lim: Int, off: Int, dist: Bool }

-- Start a full outer join from a query: pair it with a right repository on a quoted
-- condition over both entities. Unlike `leftJoinOn`/`rightJoinOn`, neither side is
-- dropped — every left row and every right row is kept, the missing side reported as
-- `None`. The left query's filter restricts which left rows enter the join (a left
-- row it rejects never appears, not even unmatched); its ordering and page still
-- apply.
pub class FullJoinable q =
    fullJoinOn (right: Repo f a) (cond: Quote (Map Text SqlValue -> Map Text SqlValue -> Bool)) (x: q) -> FullJoinResult q f

-- A query's `fullJoinOn`: the binary full outer join, identical to the original
-- builder.
instance FullJoinable (Query e a) =
    fullJoinOn (right: Repo f a) (cond: Quote (Map Text SqlValue -> Map Text SqlValue -> Bool)) (x: Query e a) -> FullJoin e f a =
        FullJoin { left = x, right = right, cond = cond, where2 = keepAll2 (), orders = liftOrders x.orders, lim = x.lim, off = x.off, dist = x.dist }

-- A binary join's `fullJoinOn`: full-join a third table onto the inner pair.
instance FullJoinable (Join e g a) =
    fullJoinOn (right: Repo f a) (cond: Quote (Map Text SqlValue -> Map Text SqlValue -> Bool)) (x: Join e g a) -> FullJoined (Join e g a) f a =
        FullJoined { source = x, right = right, cond = cond, where2 = keepAll2 (), orders = x.orders, lim = x.lim, off = x.off, dist = x.dist }

-- A nested inner join's `fullJoinOn`.
instance FullJoinable (Joined q g a) =
    fullJoinOn (right: Repo f a) (cond: Quote (Map Text SqlValue -> Map Text SqlValue -> Bool)) (x: Joined q g a) -> FullJoined (Joined q g a) f a =
        FullJoined { source = x, right = right, cond = cond, where2 = keepAll2 (), orders = x.orders, lim = x.lim, off = x.off, dist = x.dist }

-- A nested left join's `fullJoinOn`.
instance FullJoinable (LeftJoined q g a) =
    fullJoinOn (right: Repo f a) (cond: Quote (Map Text SqlValue -> Map Text SqlValue -> Bool)) (x: LeftJoined q g a) -> FullJoined (LeftJoined q g a) f a =
        FullJoined { source = x, right = right, cond = cond, where2 = keepAll2 (), orders = x.orders, lim = x.lim, off = x.off, dist = x.dist }

-- A nested right join's `fullJoinOn`.
instance FullJoinable (RightJoined q g a) =
    fullJoinOn (right: Repo f a) (cond: Quote (Map Text SqlValue -> Map Text SqlValue -> Bool)) (x: RightJoined q g a) -> FullJoined (RightJoined q g a) f a =
        FullJoined { source = x, right = right, cond = cond, where2 = keepAll2 (), orders = x.orders, lim = x.lim, off = x.off, dist = x.dist }

-- A nested full join's `fullJoinOn`: chain another full join onto a composite that
-- already ends in one.
instance FullJoinable (FullJoined q g a) =
    fullJoinOn (right: Repo f a) (cond: Quote (Map Text SqlValue -> Map Text SqlValue -> Bool)) (x: FullJoined q g a) -> FullJoined (FullJoined q g a) f a =
        FullJoined { source = x, right = right, cond = cond, where2 = keepAll2 (), orders = x.orders, lim = x.lim, off = x.off, dist = x.dist }

-- The recursion a nested full join's terminal stands on. A `FullJoined` decodes
-- BOTH sides optionally: the new leaf via `decodeOptSide`, and the whole composite
-- source via its presence (any composite leaf surviving).
instance JoinShape (FullJoined q f a) where JoinShape q, Row f =
    joinedLeaves (w: Option (FullJoined q f a)) -> Int =
        joinedLeaves (fullInnerWitness w) + 1
    joinedSourcePlan (x: FullJoined q f a) -> QueryPlan =
        planJoin "FULL" (joinedSourcePlan x.source) (planScan x.right.table (keepAllTree ()) [] (0 - 1) 0 false) x.cond.tree x.where2.tree x.orders (0 - 1) 0 false [] (rowColumns (entityWitness x.right))
    decodeJoined (w: Option (FullJoined q f a)) (row: Map Text SqlValue) -> Result (Option (Rows q), Option f) Error =
        match decodeOptSide (leafPrefix (joinedLeaves (fullInnerWitness w))) row
            Err err -> Err err
            Ok optF ->
                match decodeRightOptComposite (fullInnerWitness w) (joinedLeaves (fullInnerWitness w)) row
                    Err err   -> Err err
                    Ok optSrc -> Ok (optSrc, optF)

-- Phantom witnesses: narrow a `FullJoined`'s type to its source's.
fn fullInnerWitness (w: Option (FullJoined q f a)) -> Option q = None
fn fullSourceWitness (x: FullJoined q f a) -> Option q = None

-- The plan of a whole `FullJoined`: its source's plan with the new right table
-- FULL-joined on, carrying the top-level page/ordering/distinct.
fn fullJoinedPlan (x: FullJoined q f a) (lim: Int) -> QueryPlan where JoinShape q, Row f =
    planJoin "FULL" (joinedSourcePlan x.source) (planScan x.right.table (keepAllTree ()) [] (0 - 1) 0 false) x.cond.tree x.where2.tree x.orders lim x.off x.dist [] (rowColumns (entityWitness x.right))

-- Decode each flat result row of a `FullJoined` into `(Option (Rows q), Option f)`:
-- the new table optionally from its `t<n>$` leaf, the composite source optionally.
fn decodeFullJoinedRows (w: Option q) (n: Int) (rows: List (Map Text SqlValue)) -> Result (List (Option (Rows q), Option f)) Error where JoinShape q, Row f =
    match rows
        []        -> Ok []
        r :: rest ->
            match decodeOptSide (leafPrefix n) r
                Err err -> Err err
                Ok optF ->
                    match decodeRightOptComposite w n r
                        Err err -> Err err
                        Ok optSrc ->
                            match decodeFullJoinedRows w n rest
                                Err err -> Err err
                                Ok more -> Ok ((optSrc, optF) :: more)

fn firstDecodedFullJoined (w: Option q) (n: Int) (rows: List (Map Text SqlValue)) -> Result (Option (Option (Rows q), Option f)) Error where JoinShape q, Row f =
    match rows
        []     -> Ok None
        r :: _ ->
            match decodeOptSide (leafPrefix n) r
                Err err -> Err err
                Ok optF ->
                    match decodeRightOptComposite w n r
                        Err err   -> Err err
                        Ok optSrc -> Ok (Some (optSrc, optF))

-- `toList`/`first` over a nested full join: run the flattened FULL plan and decode
-- each row into `(Option (Rows q), Option f)`.
instance Decodable (FullJoined q f a) where Adapter a, JoinShape q, Row f =
    toList (x: FullJoined q f a) -> Result (List (Option (Rows q), Option f)) Error =
        match runPlan x.right.adapter (fullJoinedPlan x x.lim)
            Err err -> Err err
            Ok rows -> decodeFullJoinedRows (fullSourceWitness x) (joinedLeaves (fullSourceWitness x)) rows
    first (x: FullJoined q f a) -> Result (Option (Option (Rows q), Option f)) Error =
        match runPlan x.right.adapter (fullJoinedPlan x 1)
            Err err -> Err err
            Ok rows -> firstDecodedFullJoined (fullSourceWitness x) (joinedLeaves (fullSourceWitness x)) rows

-- `toList` and `first` over a full join are the `Decodable (FullJoin e f a) …`
-- methods (instance below): `toList` decodes each row into a pair of optionals
-- `(Option e, Option f)` — `None` on whichever side the row matched none; `first`
-- keeps the first such pair.

-- A query's `filter`: AND the one-row predicate into the query's accumulated
-- `WHERE`, exactly as the original single-receiver verb did. The predicate is
-- entity-typed (`Quote (e -> Bool)`) and the stored field row-typed; `quoteAnd`
-- folds one into the other (the captured tree is what runs).
instance Refinable (Query e a) (fn e -> Bool) =
    filter (pred: Quote (fn e -> Bool)) (x: Query e a) -> Query e a =
        Query { repo = x.repo, pred = quoteAnd x.pred pred, orders = x.orders, lim = x.lim, off = x.off, dist = x.dist, plan = x.plan }

-- An inner join's `filter`: AND the two-row predicate into the join's post-join
-- `WHERE`. The condition the join pairs rows on stays separate; the terminals
-- fold `where2` in when they run the join.
instance Refinable (Join e f a) (fn e f -> Bool) =
    filter (pred: Quote (fn e f -> Bool)) (x: Join e f a) -> Join e f a =
        Join { left = x.left, right = x.right, cond = x.cond, where2 = quoteAnd2 x.where2 pred, orders = x.orders, lim = x.lim, off = x.off, dist = x.dist }

-- A left join's `filter`: AND the two-row predicate into the post-join `WHERE`.
-- A predicate that reads a right column drops the unmatched left rows (their
-- right side is NULL, so the predicate is false), narrowing the outer join to
-- its matches — the three-valued reading SQL gives a `WHERE` after a `LEFT JOIN`.
instance Refinable (LeftJoin e f a) (fn e f -> Bool) =
    filter (pred: Quote (fn e f -> Bool)) (x: LeftJoin e f a) -> LeftJoin e f a =
        LeftJoin { left = x.left, right = x.right, cond = x.cond, where2 = quoteAnd2 x.where2 pred, orders = x.orders, lim = x.lim, off = x.off, dist = x.dist }

-- A right join's `filter`: AND the two-row predicate into the post-join `WHERE`. A
-- predicate that reads a left column drops the unmatched right rows (their left side
-- is NULL, so the predicate is false), narrowing the outer join to its matches — the
-- mirror of a left join's `filter`.
instance Refinable (RightJoin e f a) (fn e f -> Bool) =
    filter (pred: Quote (fn e f -> Bool)) (x: RightJoin e f a) -> RightJoin e f a =
        RightJoin { left = x.left, right = x.right, cond = x.cond, where2 = quoteAnd2 x.where2 pred, orders = x.orders, lim = x.lim, off = x.off, dist = x.dist }

-- A full join's `filter`: AND the two-row predicate into the post-join `WHERE`. A
-- predicate that reads either side's column drops the rows unmatched on that side
-- (their columns there are NULL, so the predicate is false), narrowing the outer
-- join toward its matches — the same three-valued `WHERE` reading a left or right
-- join's `filter` gives, here over both sides.
instance Refinable (FullJoin e f a) (fn e f -> Bool) =
    filter (pred: Quote (fn e f -> Bool)) (x: FullJoin e f a) -> FullJoin e f a =
        FullJoin { left = x.left, right = x.right, cond = x.cond, where2 = quoteAnd2 x.where2 pred, orders = x.orders, lim = x.lim, off = x.off, dist = x.dist }

-- A composite join's `filter`: AND a leaf predicate over every table joined so far
-- into the composite's post-join `WHERE`. The predicate ranges over all the
-- receiver's leaves positionally (`fn u p c -> …` for a three-table join), its arity
-- and per-leaf entities determined by the receiver — the same `JoinCond q f` shape
-- a join condition takes. The condition each step pairs on stays separate; the
-- terminals fold `where2` in when they run the join. The instance's written
-- predicate is the raw two-row form `quoteAnd2` folds; the user-facing leaf arity is
-- supplied by the determined `JoinCond q f`, so a wrong-arity predicate is a
-- compile-time error. One body serves every depth and shape (`Joined`/`LeftJoined`/
-- `RightJoined`/`FullJoined`) — an outer step's predicate reads its columns the same
-- three-valued way a binary outer join's `filter` does.
instance Refinable (Joined q f a) (Map Text SqlValue -> Map Text SqlValue -> Bool) =
    filter (pred: Quote (Map Text SqlValue -> Map Text SqlValue -> Bool)) (x: Joined q f a) -> Joined q f a =
        Joined { source = x.source, right = x.right, cond = x.cond, where2 = quoteAnd2 x.where2 pred, orders = x.orders, lim = x.lim, off = x.off, dist = x.dist }

instance Refinable (LeftJoined q f a) (Map Text SqlValue -> Map Text SqlValue -> Bool) =
    filter (pred: Quote (Map Text SqlValue -> Map Text SqlValue -> Bool)) (x: LeftJoined q f a) -> LeftJoined q f a =
        LeftJoined { source = x.source, right = x.right, cond = x.cond, where2 = quoteAnd2 x.where2 pred, orders = x.orders, lim = x.lim, off = x.off, dist = x.dist }

instance Refinable (RightJoined q f a) (Map Text SqlValue -> Map Text SqlValue -> Bool) =
    filter (pred: Quote (Map Text SqlValue -> Map Text SqlValue -> Bool)) (x: RightJoined q f a) -> RightJoined q f a =
        RightJoined { source = x.source, right = x.right, cond = x.cond, where2 = quoteAnd2 x.where2 pred, orders = x.orders, lim = x.lim, off = x.off, dist = x.dist }

instance Refinable (FullJoined q f a) (Map Text SqlValue -> Map Text SqlValue -> Bool) =
    filter (pred: Quote (Map Text SqlValue -> Map Text SqlValue -> Bool)) (x: FullJoined q f a) -> FullJoined q f a =
        FullJoined { source = x.source, right = x.right, cond = x.cond, where2 = quoteAnd2 x.where2 pred, orders = x.orders, lim = x.lim, off = x.off, dist = x.dist }

-- A query's `select`: project one entity down to the named shape `s` and decode
-- each row into it. The backend pushes the select-list down so only the named
-- columns cross, in the query's order and page; `selectFirst` adds `LIMIT 1`.
instance Projectable (Query e a) (fn e -> s) where Adapter a, Row s =
    select (proj: Quote (fn e -> s)) (x: Query e a) -> Result (List s) Error =
        match project x.repo.adapter x.repo.table x.pred x.orders x.lim x.off (projColumns proj) x.dist
            Err err -> Err err
            Ok rows -> decodeRows rows
    selectFirst (proj: Quote (fn e -> s)) (x: Query e a) -> Result (Option s) Error =
        match project x.repo.adapter x.repo.table x.pred x.orders 1 x.off (projColumns proj) x.dist
            Err err -> Err err
            Ok rows -> firstDecoded rows

-- An inner join's `select`: project across both entities into `s`. The projection
-- names columns from either row (`fn (u: User) (p: Post) -> Line { ... }`); the
-- plan pushes that select-list onto the join through `innerJoinSelectPlan` and each
-- projected row decodes into `s`.
instance Projectable (Join e f a) (fn e f -> s) where Adapter a, Row s =
    select (proj: Quote (fn e f -> s)) (x: Join e f a) -> Result (List s) Error =
        match runPlan x.left.repo.adapter (innerJoinSelectPlan x proj.tree x.lim)
            Err err  -> Err err
            Ok rows  -> decodeRows rows
    selectFirst (proj: Quote (fn e f -> s)) (x: Join e f a) -> Result (Option s) Error =
        match runPlan x.left.repo.adapter (innerJoinSelectPlan x proj.tree 1)
            Err err  -> Err err
            Ok rows  -> firstDecoded rows

-- A left join's `select`: project across both entities into `s`, the right side
-- read as `Option` (`fn (u: User) (p: Option Post) -> ...`) so an unmatched left
-- row projects its right-derived fields as `None`. Every left row is kept (a
-- `LEFT JOIN`) and only the named columns cross.
instance Projectable (LeftJoin e f a) (fn e (Option f) -> s) where Adapter a, Row s =
    select (proj: Quote (fn e (Option f) -> s)) (x: LeftJoin e f a) -> Result (List s) Error =
        match runPlan x.left.repo.adapter (leftJoinSelectPlan x proj.tree x.lim)
            Err err  -> Err err
            Ok rows  -> decodeRows rows
    selectFirst (proj: Quote (fn e (Option f) -> s)) (x: LeftJoin e f a) -> Result (Option s) Error =
        match runPlan x.left.repo.adapter (leftJoinSelectPlan x proj.tree 1)
            Err err  -> Err err
            Ok rows  -> firstDecoded rows

-- A right join's `select`: project across both entities into `s`, the LEFT side read
-- as `Option` (`fn (u: Option User) (p: Post) -> ...`) so an unmatched right row
-- projects its left-derived fields as `None`. Every right row is kept (a `RIGHT
-- JOIN`) and only the named columns cross — the mirror of a left join's `select`.
instance Projectable (RightJoin e f a) (fn (Option e) f -> s) where Adapter a, Row s =
    select (proj: Quote (fn (Option e) f -> s)) (x: RightJoin e f a) -> Result (List s) Error =
        match runPlan x.left.repo.adapter (rightJoinSelectPlan x proj.tree x.lim)
            Err err  -> Err err
            Ok rows  -> decodeRows rows
    selectFirst (proj: Quote (fn (Option e) f -> s)) (x: RightJoin e f a) -> Result (Option s) Error =
        match runPlan x.left.repo.adapter (rightJoinSelectPlan x proj.tree 1)
            Err err  -> Err err
            Ok rows  -> firstDecoded rows

-- A full join's `select`: project across both entities into `s`, BOTH sides read as
-- `Option` (`fn (u: Option User) (p: Option Post) -> ...`) so an unmatched row
-- projects the missing side's fields as `None`. Every row of both tables is kept (a
-- `FULL JOIN`) and only the named columns cross.
instance Projectable (FullJoin e f a) (fn (Option e) (Option f) -> s) where Adapter a, Row s =
    select (proj: Quote (fn (Option e) (Option f) -> s)) (x: FullJoin e f a) -> Result (List s) Error =
        match runPlan x.left.repo.adapter (fullJoinSelectPlan x proj.tree x.lim)
            Err err  -> Err err
            Ok rows  -> decodeRows rows
    selectFirst (proj: Quote (fn (Option e) (Option f) -> s)) (x: FullJoin e f a) -> Result (Option s) Error =
        match runPlan x.left.repo.adapter (fullJoinSelectPlan x proj.tree 1)
            Err err  -> Err err
            Ok rows  -> firstDecoded rows

-- A query's `orderBy`: append the one-row key as an ordering column over the
-- query's own `orders`. The key (`fn (u: User) -> u.age`) names a single column;
-- the direction rides alongside it. The behaviour the single-receiver `orderBy`
-- had before it unified with the join form.
instance Orderable (Query e a) (fn e -> k) =
    orderBy (dir: SortOrder) (key: Quote (fn e -> k)) (x: Query e a) -> Query e a =
        Query { repo = x.repo, pred = x.pred, orders = snoc x.orders (ascending dir, orderColumn key), lim = x.lim, off = x.off, dist = x.dist, plan = x.plan }

-- An inner join's `orderBy`: append a two-row key to the join's own ordering. The
-- key may name a column from either side (`fn (u: User) (p: Post) -> p.title`
-- orders by the right table); `orderEntry2` reads the column and which side it
-- belongs to so the seam qualifies it to the right table alias.
instance Orderable (Join e f a) (fn e f -> k) =
    orderBy (dir: SortOrder) (key: Quote (fn e f -> k)) (x: Join e f a) -> Join e f a =
        Join { left = x.left, right = x.right, cond = x.cond, where2 = x.where2, orders = snoc x.orders (orderEntry2 dir key), lim = x.lim, off = x.off, dist = x.dist }

-- A left join's `orderBy`: the two-row dual over a `LeftJoin`. The right side is
-- read as `Option` in the key (`fn (u: User) (p: Option Post) -> p.title`); an
-- unmatched left row has no right value, so a right-side key sorts it as a missing
-- key (it keeps its place).
instance Orderable (LeftJoin e f a) (fn e (Option f) -> k) =
    orderBy (dir: SortOrder) (key: Quote (fn e (Option f) -> k)) (x: LeftJoin e f a) -> LeftJoin e f a =
        LeftJoin { left = x.left, right = x.right, cond = x.cond, where2 = x.where2, orders = snoc x.orders (orderEntry2 dir key), lim = x.lim, off = x.off, dist = x.dist }

-- A right join's `orderBy`: the two-row dual over a `RightJoin`. The left side is
-- read as `Option` in the key (`fn (u: Option User) (p: Post) -> u.name`); an
-- unmatched right row has no left value, so a left-side key sorts it as a missing key
-- (it keeps its place).
instance Orderable (RightJoin e f a) (fn (Option e) f -> k) =
    orderBy (dir: SortOrder) (key: Quote (fn (Option e) f -> k)) (x: RightJoin e f a) -> RightJoin e f a =
        RightJoin { left = x.left, right = x.right, cond = x.cond, where2 = x.where2, orders = snoc x.orders (orderEntry2 dir key), lim = x.lim, off = x.off, dist = x.dist }

-- A full join's `orderBy`: the two-row dual over a `FullJoin`, BOTH sides read as
-- `Option` in the key (`fn (u: Option User) (p: Option Post) -> ...`). A key over a
-- side an unmatched row lacks reads that row as a missing key, so it sorts in place
-- (the backend's NULL ordering decides where).
instance Orderable (FullJoin e f a) (fn (Option e) (Option f) -> k) =
    orderBy (dir: SortOrder) (key: Quote (fn (Option e) (Option f) -> k)) (x: FullJoin e f a) -> FullJoin e f a =
        FullJoin { left = x.left, right = x.right, cond = x.cond, where2 = x.where2, orders = snoc x.orders (orderEntry2 dir key), lim = x.lim, off = x.off, dist = x.dist }

-- A query's scalar aggregates: fold the column the one-row accessor names over
-- the rows the query's filter selects, through the `aggregate` seam push-down.
-- The behaviour the single-receiver `sumOf`/`avgOf`/`minOf`/`maxOf` had before
-- they unified with the join form. `sumOf`/`minOf`/`maxOf` keep the column's own
-- type (`Ret p` = `n`); `avgOf` is always a `Float`.
instance Aggregable (Query e a) (fn e -> n) where Adapter a, SqlType n =
    sumOf (col: Quote (fn e -> n)) (x: Query e a) -> Result (Option n) Error =
        match aggregate x.repo.adapter x.repo.table x.pred "SUM" (aggColumn col)
            Err err -> Err err
            Ok v    -> decodeScalar v
    avgOf (col: Quote (fn e -> n)) (x: Query e a) -> Result (Option Float) Error =
        match aggregate x.repo.adapter x.repo.table x.pred "AVG" (aggColumn col)
            Err err -> Err err
            Ok v    -> decodeScalar v
    minOf (col: Quote (fn e -> n)) (x: Query e a) -> Result (Option n) Error =
        match aggregate x.repo.adapter x.repo.table x.pred "MIN" (aggColumn col)
            Err err -> Err err
            Ok v    -> decodeScalar v
    maxOf (col: Quote (fn e -> n)) (x: Query e a) -> Result (Option n) Error =
        match aggregate x.repo.adapter x.repo.table x.pred "MAX" (aggColumn col)
            Err err -> Err err
            Ok v    -> decodeScalar v

-- An inner join's scalar aggregates: fold a column the two-row accessor names —
-- from either side (`fn (u: User) (p: Post) -> p.amount` folds the right table) —
-- over the joined rows the condition and post-join filter keep, through a
-- `PlanAggregate` over the join plan (`scalarJoinPlan`). `aggSide` reads which side
-- the column belongs to so the fold reads it under that source's prefix; `aggColumn`
-- reads its name. The plan's lone row carries the scalar (`firstAggCell`), or no row
-- when the fold is empty, which `decodeScalar` reads as `None`.
instance Aggregable (Join e f a) (fn e f -> n) where Adapter a, SqlType n =
    sumOf (col: Quote (fn e f -> n)) (x: Join e f a) -> Result (Option n) Error =
        match runPlan x.left.repo.adapter (scalarJoinPlan x "SUM" col)
            Err err -> Err err
            Ok rows -> decodeScalar (firstAggCell rows)
    avgOf (col: Quote (fn e f -> n)) (x: Join e f a) -> Result (Option Float) Error =
        match runPlan x.left.repo.adapter (scalarJoinPlan x "AVG" col)
            Err err -> Err err
            Ok rows -> decodeScalar (firstAggCell rows)
    minOf (col: Quote (fn e f -> n)) (x: Join e f a) -> Result (Option n) Error =
        match runPlan x.left.repo.adapter (scalarJoinPlan x "MIN" col)
            Err err -> Err err
            Ok rows -> decodeScalar (firstAggCell rows)
    maxOf (col: Quote (fn e f -> n)) (x: Join e f a) -> Result (Option n) Error =
        match runPlan x.left.repo.adapter (scalarJoinPlan x "MAX" col)
            Err err -> Err err
            Ok rows -> decodeScalar (firstAggCell rows)

-- A left join's scalar aggregates: the two-row dual over a `LeftJoin`, run through
-- the `aggregateLeftJoin` seam. Unlike a left join's `select`/`orderBy` — whose
-- per-row accessor reads the right side as `Option` because an unmatched row has
-- no right value — an aggregate folds values rather than producing one per row, so
-- it reads the right side as the plain entity `f` and answers the column's own
-- type. A right-column fold skips the unmatched left rows (their right column is
-- NULL, which a SQL aggregate ignores); a left-column fold still counts them. The
-- nullability lives in the result (`Option n` is `None` over an empty fold), not
-- in the accessor.
instance Aggregable (LeftJoin e f a) (fn e f -> n) where Adapter a, SqlType n =
    sumOf (col: Quote (fn e f -> n)) (x: LeftJoin e f a) -> Result (Option n) Error =
        match runPlan x.left.repo.adapter (leftScalarPlan x "SUM" col)
            Err err -> Err err
            Ok rows -> decodeScalar (firstAggCell rows)
    avgOf (col: Quote (fn e f -> n)) (x: LeftJoin e f a) -> Result (Option Float) Error =
        match runPlan x.left.repo.adapter (leftScalarPlan x "AVG" col)
            Err err -> Err err
            Ok rows -> decodeScalar (firstAggCell rows)
    minOf (col: Quote (fn e f -> n)) (x: LeftJoin e f a) -> Result (Option n) Error =
        match runPlan x.left.repo.adapter (leftScalarPlan x "MIN" col)
            Err err -> Err err
            Ok rows -> decodeScalar (firstAggCell rows)
    maxOf (col: Quote (fn e f -> n)) (x: LeftJoin e f a) -> Result (Option n) Error =
        match runPlan x.left.repo.adapter (leftScalarPlan x "MAX" col)
            Err err -> Err err
            Ok rows -> decodeScalar (firstAggCell rows)

-- A right join's scalar aggregates: the two-row dual over a `RightJoin`, run through
-- the `aggregateRightJoin` seam. As with a left join, an aggregate folds values
-- rather than producing one per row, so it reads both sides as the plain entities
-- `e`/`f` and answers the column's own type. A left-column fold skips the unmatched
-- right rows (their left column is NULL, which a SQL aggregate ignores); a
-- right-column fold still counts them. The nullability lives in the result.
instance Aggregable (RightJoin e f a) (fn e f -> n) where Adapter a, SqlType n =
    sumOf (col: Quote (fn e f -> n)) (x: RightJoin e f a) -> Result (Option n) Error =
        match runPlan x.left.repo.adapter (rightScalarPlan x "SUM" col)
            Err err -> Err err
            Ok rows -> decodeScalar (firstAggCell rows)
    avgOf (col: Quote (fn e f -> n)) (x: RightJoin e f a) -> Result (Option Float) Error =
        match runPlan x.left.repo.adapter (rightScalarPlan x "AVG" col)
            Err err -> Err err
            Ok rows -> decodeScalar (firstAggCell rows)
    minOf (col: Quote (fn e f -> n)) (x: RightJoin e f a) -> Result (Option n) Error =
        match runPlan x.left.repo.adapter (rightScalarPlan x "MIN" col)
            Err err -> Err err
            Ok rows -> decodeScalar (firstAggCell rows)
    maxOf (col: Quote (fn e f -> n)) (x: RightJoin e f a) -> Result (Option n) Error =
        match runPlan x.left.repo.adapter (rightScalarPlan x "MAX" col)
            Err err -> Err err
            Ok rows -> decodeScalar (firstAggCell rows)

-- A full join's scalar aggregates: the two-row dual over a `FullJoin`, run through
-- the `aggregateFullJoin` seam. An aggregate folds values rather than producing one
-- per row, so it reads both sides as the plain entities `e`/`f` and answers the
-- column's own type. A fold over either side skips the rows unmatched on that side
-- (their column there is NULL, which a SQL aggregate ignores). The nullability lives
-- in the result.
instance Aggregable (FullJoin e f a) (fn e f -> n) where Adapter a, SqlType n =
    sumOf (col: Quote (fn e f -> n)) (x: FullJoin e f a) -> Result (Option n) Error =
        match runPlan x.left.repo.adapter (fullScalarPlan x "SUM" col)
            Err err -> Err err
            Ok rows -> decodeScalar (firstAggCell rows)
    avgOf (col: Quote (fn e f -> n)) (x: FullJoin e f a) -> Result (Option Float) Error =
        match runPlan x.left.repo.adapter (fullScalarPlan x "AVG" col)
            Err err -> Err err
            Ok rows -> decodeScalar (firstAggCell rows)
    minOf (col: Quote (fn e f -> n)) (x: FullJoin e f a) -> Result (Option n) Error =
        match runPlan x.left.repo.adapter (fullScalarPlan x "MIN" col)
            Err err -> Err err
            Ok rows -> decodeScalar (firstAggCell rows)
    maxOf (col: Quote (fn e f -> n)) (x: FullJoin e f a) -> Result (Option n) Error =
        match runPlan x.left.repo.adapter (fullScalarPlan x "MAX" col)
            Err err -> Err err
            Ok rows -> decodeScalar (firstAggCell rows)

-- A composite join's scalar aggregates: fold a column the leaf accessor names — from any
-- joined table (`fn u p c -> c.amount` folds the third leaf) — over the rows the
-- conditions and post-join filters keep, through a `PlanAggregate` over the composite's
-- reduction. The accessor is the positional leaf form the receiver determines; only its
-- captured column matters, so its stored single-column form folds the named leaf. One
-- shape per composite. As with the binary outer aggregates, the nullability lives in the
-- result (`Option n` over an empty fold), not the accessor — an outer shape folds a leaf
-- the same way, skipping the rows where that leaf is null-extended.
instance Aggregable (Joined q f a) (Map Text SqlValue -> n) where Adapter a, JoinShape q, Row f, SqlType n =
    sumOf (col: Quote (Map Text SqlValue -> n)) (x: Joined q f a) -> Result (Option n) Error =
        match runPlan x.right.adapter (joinedScalarPlan x "SUM" col)
            Err err -> Err err
            Ok rows -> decodeScalar (firstAggCell rows)
    avgOf (col: Quote (Map Text SqlValue -> n)) (x: Joined q f a) -> Result (Option Float) Error =
        match runPlan x.right.adapter (joinedScalarPlan x "AVG" col)
            Err err -> Err err
            Ok rows -> decodeScalar (firstAggCell rows)
    minOf (col: Quote (Map Text SqlValue -> n)) (x: Joined q f a) -> Result (Option n) Error =
        match runPlan x.right.adapter (joinedScalarPlan x "MIN" col)
            Err err -> Err err
            Ok rows -> decodeScalar (firstAggCell rows)
    maxOf (col: Quote (Map Text SqlValue -> n)) (x: Joined q f a) -> Result (Option n) Error =
        match runPlan x.right.adapter (joinedScalarPlan x "MAX" col)
            Err err -> Err err
            Ok rows -> decodeScalar (firstAggCell rows)

instance Aggregable (LeftJoined q f a) (Map Text SqlValue -> n) where Adapter a, JoinShape q, Row f, SqlType n =
    sumOf (col: Quote (Map Text SqlValue -> n)) (x: LeftJoined q f a) -> Result (Option n) Error =
        match runPlan x.right.adapter (leftScalarComposite x "SUM" col)
            Err err -> Err err
            Ok rows -> decodeScalar (firstAggCell rows)
    avgOf (col: Quote (Map Text SqlValue -> n)) (x: LeftJoined q f a) -> Result (Option Float) Error =
        match runPlan x.right.adapter (leftScalarComposite x "AVG" col)
            Err err -> Err err
            Ok rows -> decodeScalar (firstAggCell rows)
    minOf (col: Quote (Map Text SqlValue -> n)) (x: LeftJoined q f a) -> Result (Option n) Error =
        match runPlan x.right.adapter (leftScalarComposite x "MIN" col)
            Err err -> Err err
            Ok rows -> decodeScalar (firstAggCell rows)
    maxOf (col: Quote (Map Text SqlValue -> n)) (x: LeftJoined q f a) -> Result (Option n) Error =
        match runPlan x.right.adapter (leftScalarComposite x "MAX" col)
            Err err -> Err err
            Ok rows -> decodeScalar (firstAggCell rows)

instance Aggregable (RightJoined q f a) (Map Text SqlValue -> n) where Adapter a, JoinShape q, Row f, SqlType n =
    sumOf (col: Quote (Map Text SqlValue -> n)) (x: RightJoined q f a) -> Result (Option n) Error =
        match runPlan x.right.adapter (rightScalarComposite x "SUM" col)
            Err err -> Err err
            Ok rows -> decodeScalar (firstAggCell rows)
    avgOf (col: Quote (Map Text SqlValue -> n)) (x: RightJoined q f a) -> Result (Option Float) Error =
        match runPlan x.right.adapter (rightScalarComposite x "AVG" col)
            Err err -> Err err
            Ok rows -> decodeScalar (firstAggCell rows)
    minOf (col: Quote (Map Text SqlValue -> n)) (x: RightJoined q f a) -> Result (Option n) Error =
        match runPlan x.right.adapter (rightScalarComposite x "MIN" col)
            Err err -> Err err
            Ok rows -> decodeScalar (firstAggCell rows)
    maxOf (col: Quote (Map Text SqlValue -> n)) (x: RightJoined q f a) -> Result (Option n) Error =
        match runPlan x.right.adapter (rightScalarComposite x "MAX" col)
            Err err -> Err err
            Ok rows -> decodeScalar (firstAggCell rows)

instance Aggregable (FullJoined q f a) (Map Text SqlValue -> n) where Adapter a, JoinShape q, Row f, SqlType n =
    sumOf (col: Quote (Map Text SqlValue -> n)) (x: FullJoined q f a) -> Result (Option n) Error =
        match runPlan x.right.adapter (fullScalarComposite x "SUM" col)
            Err err -> Err err
            Ok rows -> decodeScalar (firstAggCell rows)
    avgOf (col: Quote (Map Text SqlValue -> n)) (x: FullJoined q f a) -> Result (Option Float) Error =
        match runPlan x.right.adapter (fullScalarComposite x "AVG" col)
            Err err -> Err err
            Ok rows -> decodeScalar (firstAggCell rows)
    minOf (col: Quote (Map Text SqlValue -> n)) (x: FullJoined q f a) -> Result (Option n) Error =
        match runPlan x.right.adapter (fullScalarComposite x "MIN" col)
            Err err -> Err err
            Ok rows -> decodeScalar (firstAggCell rows)
    maxOf (col: Quote (Map Text SqlValue -> n)) (x: FullJoined q f a) -> Result (Option n) Error =
        match runPlan x.right.adapter (fullScalarComposite x "MAX" col)
            Err err -> Err err
            Ok rows -> decodeScalar (firstAggCell rows)

-- A query's decode terminals: `toList` runs the accumulated query (a single-
-- table fetch, or the captured set-operation plan) and decodes every row into
-- the entity; `first` runs it for one row. The behaviour the single-receiver
-- `toList`/`first` had before they unified with the join form. `Rows (Query e a)`
-- reduces to the entity `e`, so the result is `List e`/`Option e`.
instance Decodable (Query e a) where Adapter a, Row e =
    toList (x: Query e a) -> Result (List e) Error =
        match queryRows x
            Err err -> Err err
            Ok rows -> decodeRows rows
    first (x: Query e a) -> Result (Option e) Error =
        match x.plan
            None ->
                match fetch x.repo.adapter x.repo.table x.pred x.orders 1 x.off x.dist
                    Err err -> Err err
                    Ok rows -> firstDecoded rows
            Some _ ->
                match runPlan x.repo.adapter (planOf x)
                    Err err -> Err err
                    Ok rows -> firstDecoded rows

-- An inner join's decode terminals: `toList` runs the join and decodes each
-- matched row pair into `(e, f)`; `first` fetches a one-row join and keeps the
-- first pair. `Rows (Join e f a)` reduces to the pair `(e, f)`, so the result is
-- `List (e, f)`/`Option (e, f)`. Both sides decode, so the instance carries
-- `Row e, Row f` alongside `Adapter a`.
-- The two `Row` constraints are written `Row f, Row e` (right before left) so the
-- instance dictionary lists them in the same order the decode helper's own scheme
-- does. A helper like `decodePrefixedPairs` constrains both entities, and a generalised
-- scheme orders its dictionary parameters by the constraint variables' inference
-- ids — the later-appearing `f` ahead of `e`. An instance method forwards its
-- incoming `Row` dictionaries into that helper by position, so matching the order
-- here threads the left entity's decoder to the left row and the right's to the
-- right. (`Adapter a` stays first; it is a different class and never collides.)
-- The query plan an inner join runs: a `PlanJoin` pairing a scan of the left table
-- (carrying the left query's filter) with a scan of the right, on the join's
-- condition and post-join `WHERE`, with the join's side-tagged ordering, page, and
-- distinct folded in. `lim` is passed explicitly so `first` can run the same plan
-- with a one-row limit. The decode terminals run it through `runPlan` and decode the
-- flat, source-prefixed rows.
-- A phantom `Option e` witness for `rowColumns`, drawn from a repository that already
-- carries the entity type. `Row.rowColumns` answers an entity's columns from the type
-- alone but needs a value to fix that type; a `Repo e a` carries `e` in its type, so this
-- projects out an ignored `Option e` to select the `Row e` instance. The join read
-- terminals call it on their left and right repositories to spell each side's columns.
fn entityWitness (_r: Repo e a) -> Option e = None

fn innerJoinPlan (x: Join e f a) (lim: Int) (leftCols: List Text) (rightCols: List Text) -> QueryPlan =
    planJoin "INNER" (planScan x.left.repo.table x.left.pred.tree [] (0 - 1) 0 false) (planScan x.right.table (keepAllTree ()) [] (0 - 1) 0 false) x.cond.tree x.where2.tree x.orders lim x.off x.dist leftCols rightCols

-- The plan a left/right/full outer-join decode runs: the same shape as
-- `innerJoinPlan` but with the join `kind` set, so the backend keeps the outer rows.
-- An unmatched side comes back with its `t0$`/`t1$` columns absent, which the outer
-- decoders read as `None`. `lim` is explicit so `first` runs the same plan with a
-- one-row limit.
fn leftJoinPlan (x: LeftJoin e f a) (lim: Int) (leftCols: List Text) (rightCols: List Text) -> QueryPlan =
    planJoin "LEFT" (planScan x.left.repo.table x.left.pred.tree [] (0 - 1) 0 false) (planScan x.right.table (keepAllTree ()) [] (0 - 1) 0 false) x.cond.tree x.where2.tree x.orders lim x.off x.dist leftCols rightCols

fn rightJoinPlan (x: RightJoin e f a) (lim: Int) (leftCols: List Text) (rightCols: List Text) -> QueryPlan =
    planJoin "RIGHT" (planScan x.left.repo.table x.left.pred.tree [] (0 - 1) 0 false) (planScan x.right.table (keepAllTree ()) [] (0 - 1) 0 false) x.cond.tree x.where2.tree x.orders lim x.off x.dist leftCols rightCols

fn fullJoinPlan (x: FullJoin e f a) (lim: Int) (leftCols: List Text) (rightCols: List Text) -> QueryPlan =
    planJoin "FULL" (planScan x.left.repo.table x.left.pred.tree [] (0 - 1) 0 false) (planScan x.right.table (keepAllTree ()) [] (0 - 1) 0 false) x.cond.tree x.where2.tree x.orders lim x.off x.dist leftCols rightCols

-- The query plan an inner-join `select` runs: a `PlanProject` over the all-pairs
-- join. The inner `PlanJoin` keeps the join's ordering but leaves its page and
-- distinct off (`(0 - 1) 0 false`) — `distinct` de-duplicates the projected columns
-- and the page bounds the projected rows, so both move onto the `PlanProject` and
-- apply after the projection, the same order the old `joinSelect` seam ran them
-- (pair, order, project, distinct, page). The projection tree is read against the
-- flat, source-prefixed join rows. `lim` is passed explicitly so `selectFirst` runs
-- the same plan with a one-row limit.
fn innerJoinSelectPlan (x: Join e f a) (proj: QExpr) (lim: Int) -> QueryPlan =
    planProject proj (planJoin "INNER" (planScan x.left.repo.table x.left.pred.tree [] (0 - 1) 0 false) (planScan x.right.table (keepAllTree ()) [] (0 - 1) 0 false) x.cond.tree x.where2.tree x.orders (0 - 1) 0 false [] []) lim x.off x.dist

-- The plan a left/right/full outer-join `select` runs: a `PlanProject` over the
-- all-rows outer join (its page and distinct deferred to the projection, as for the
-- inner join). The unmatched side comes back with its columns absent, so the
-- projection's accessors on that side read SQL NULL, decoding to `None` in the
-- projected shape's `Option` fields. `lim` is explicit so `selectFirst` runs with a
-- one-row limit.
fn leftJoinSelectPlan (x: LeftJoin e f a) (proj: QExpr) (lim: Int) -> QueryPlan =
    planProject proj (planJoin "LEFT" (planScan x.left.repo.table x.left.pred.tree [] (0 - 1) 0 false) (planScan x.right.table (keepAllTree ()) [] (0 - 1) 0 false) x.cond.tree x.where2.tree x.orders (0 - 1) 0 false [] []) lim x.off x.dist

fn rightJoinSelectPlan (x: RightJoin e f a) (proj: QExpr) (lim: Int) -> QueryPlan =
    planProject proj (planJoin "RIGHT" (planScan x.left.repo.table x.left.pred.tree [] (0 - 1) 0 false) (planScan x.right.table (keepAllTree ()) [] (0 - 1) 0 false) x.cond.tree x.where2.tree x.orders (0 - 1) 0 false [] []) lim x.off x.dist

fn fullJoinSelectPlan (x: FullJoin e f a) (proj: QExpr) (lim: Int) -> QueryPlan =
    planProject proj (planJoin "FULL" (planScan x.left.repo.table x.left.pred.tree [] (0 - 1) 0 false) (planScan x.right.table (keepAllTree ()) [] (0 - 1) 0 false) x.cond.tree x.where2.tree x.orders (0 - 1) 0 false [] []) lim x.off x.dist

-- The base inner-join plan a reduction terminal (`count`, `exists`, a scalar
-- aggregate) folds over. A reduction measures or folds the matched set rather than a
-- paged, ordered window of it, so the join carries neither ordering, offset, nor
-- distinct — only `where2` (which a join `filter`, or `every`'s extra predicate,
-- narrows) and `lim`, which `exists` sets to one to answer from a single row. Its
-- flat source-prefixed rows are what the scalar nodes fold.
fn reduceJoin (x: Join e f a) (where2: QExpr) (lim: Int) -> QueryPlan =
    reduceJoinOf "INNER" x.left.repo.table x.left.pred.tree x.right.table x.cond.tree where2 lim

-- Build the base reduction join from raw fields: all matched (or outer) rows with
-- neither ordering, offset, nor distinct. The four join receivers are distinct opaque
-- types that cannot share a typed helper, so each shape's wrapper unpacks its receiver
-- and calls this. `lim` bounds it only for `exists`.
fn reduceJoinOf (kind: Text) (leftTable: Text) (leftPred: QExpr) (rightTable: Text) (cond: QExpr) (where2: QExpr) (lim: Int) -> QueryPlan =
    planJoin kind (planScan leftTable leftPred [] (0 - 1) 0 false) (planScan rightTable (keepAllTree ()) [] (0 - 1) 0 false) cond where2 [] lim 0 false [] []

-- The outer-shape reduction-join wrappers, the duals of `reduceJoin` over a
-- `LeftJoin`/`RightJoin`/`FullJoin`. The join `kind` keeps the outer rows; an
-- unmatched side comes back with its columns absent, so a fold over that side skips
-- it and a count still counts the outer row.
fn leftReduceJoin (x: LeftJoin e f a) (where2: QExpr) (lim: Int) -> QueryPlan =
    reduceJoinOf "LEFT" x.left.repo.table x.left.pred.tree x.right.table x.cond.tree where2 lim

fn rightReduceJoin (x: RightJoin e f a) (where2: QExpr) (lim: Int) -> QueryPlan =
    reduceJoinOf "RIGHT" x.left.repo.table x.left.pred.tree x.right.table x.cond.tree where2 lim

fn fullReduceJoin (x: FullJoin e f a) (where2: QExpr) (lim: Int) -> QueryPlan =
    reduceJoinOf "FULL" x.left.repo.table x.left.pred.tree x.right.table x.cond.tree where2 lim

-- Run a `COUNT` aggregate plan over an outer join narrowed by `where2` and read the
-- count off its lone row — the outer-shape duals of `countJoinPlan`, shared by each
-- shape's `count` and `every`.
fn leftCountPlan (x: LeftJoin e f a) (where2: QExpr) -> Result Int Error where Adapter a =
    match runPlan x.left.repo.adapter (planAggregate "COUNT" "" 0 (leftReduceJoin x where2 (0 - 1)))
        Err err -> Err err
        Ok rows -> aggCount rows

fn rightCountPlan (x: RightJoin e f a) (where2: QExpr) -> Result Int Error where Adapter a =
    match runPlan x.left.repo.adapter (planAggregate "COUNT" "" 0 (rightReduceJoin x where2 (0 - 1)))
        Err err -> Err err
        Ok rows -> aggCount rows

fn fullCountPlan (x: FullJoin e f a) (where2: QExpr) -> Result Int Error where Adapter a =
    match runPlan x.left.repo.adapter (planAggregate "COUNT" "" 0 (fullReduceJoin x where2 (0 - 1)))
        Err err -> Err err
        Ok rows -> aggCount rows

-- Run a `COUNT` aggregate plan over the inner join narrowed by `where2` and read the
-- count off its lone row. Shared by the join's `count` and `every` (which counts
-- twice, once with the extra predicate folded in).
fn countJoinPlan (x: Join e f a) (where2: QExpr) -> Result Int Error where Adapter a =
    match runPlan x.left.repo.adapter (planAggregate "COUNT" "" 0 (reduceJoin x where2 (0 - 1)))
        Err err -> Err err
        Ok rows -> aggCount rows

-- The lone scalar an aggregate plan carries: its single row holds the value (under
-- the `agg` alias the backends key it by), or the plan returns no row at all when the
-- aggregate is SQL NULL (an empty fold). Reading the first row's first cell recovers
-- the scalar without naming the alias; no row reads as `None`, which `decodeScalar`
-- turns into the `None` an empty aggregate answers.
fn firstAggCell (rows: List (Map Text SqlValue)) -> Option SqlValue =
    match rows
        []       -> None
        row :: _ ->
            match toList row
                []          -> None
                (_, v) :: _ -> Some v

-- The integer a `COUNT` aggregate plan returns, decoded off its lone cell. A `COUNT`
-- is never SQL NULL (zero rows count 0), but the empty guard keeps the read total.
fn aggCount (rows: List (Map Text SqlValue)) -> Result Int Error =
    match firstAggCell rows
        None    -> Ok 0
        Some sv ->
            match fromSql sv
                Err err -> Err err
                Ok n    -> Ok n

-- The scalar-aggregate plan an inner-join `sumOf`/`avgOf`/`minOf`/`maxOf` runs: a
-- `PlanAggregate` over the all-pairs join, folding the column the two-row accessor
-- names (`aggColumn`) on whichever side it belongs to (`aggSide`). The fold ignores
-- ordering and paging, so `reduceJoin` leaves them off.
fn scalarJoinPlan (x: Join e f a) (func: Text) (col: Quote p) -> QueryPlan =
    planAggregate func (aggColumn col) (aggLeaf col) (reduceJoin x x.where2.tree (0 - 1))

-- The outer-shape scalar-aggregate plans, the duals of `scalarJoinPlan`. A fold over
-- an unmatched side reads its column as absent (SQL NULL) and skips it.
fn leftScalarPlan (x: LeftJoin e f a) (func: Text) (col: Quote p) -> QueryPlan =
    planAggregate func (aggColumn col) (aggLeaf col) (leftReduceJoin x x.where2.tree (0 - 1))

fn rightScalarPlan (x: RightJoin e f a) (func: Text) (col: Quote p) -> QueryPlan =
    planAggregate func (aggColumn col) (aggLeaf col) (rightReduceJoin x x.where2.tree (0 - 1))

fn fullScalarPlan (x: FullJoin e f a) (func: Text) (col: Quote p) -> QueryPlan =
    planAggregate func (aggColumn col) (aggLeaf col) (fullReduceJoin x x.where2.tree (0 - 1))

-- The base reduction plan a composite terminal (`count`/`exists`/`every`) folds over:
-- the whole nested join carrying its condition and post-join WHERE, with neither
-- ordering nor distinct — a reduction measures the matched set, not a window of it.
-- `lim` bounds it only for `exists`, which reads its answer from a single row. The
-- source's left-nested plan comes from `JoinShape`, the new leaf its scan and columns.
fn compositeReducePlan (kind: Text) (sourcePlan: QueryPlan) (rightTable: Text) (cond: QExpr) (where2: QExpr) (lim: Int) (rightCols: List Text) -> QueryPlan =
    planJoin kind sourcePlan (planScan rightTable (keepAllTree ()) [] (0 - 1) 0 false) cond where2 [] lim 0 false [] rightCols

-- The per-shape reduction-join wrappers, one per composite. Each unpacks its receiver
-- (the four composites are distinct opaque types that cannot share a typed helper) and
-- builds the base reduction at its own join kind, the `where2` and `lim` passed in so
-- `every` can re-count with the extra predicate folded in and `exists` can bound to one
-- row.
fn joinedReducePlan (x: Joined q f a) (where2: QExpr) (lim: Int) -> QueryPlan where JoinShape q, Row f =
    compositeReducePlan "INNER" (joinedSourcePlan x.source) x.right.table x.cond.tree where2 lim (rowColumns (entityWitness x.right))

fn leftReducePlan (x: LeftJoined q f a) (where2: QExpr) (lim: Int) -> QueryPlan where JoinShape q, Row f =
    compositeReducePlan "LEFT" (joinedSourcePlan x.source) x.right.table x.cond.tree where2 lim (rowColumns (entityWitness x.right))

fn rightReducePlan (x: RightJoined q f a) (where2: QExpr) (lim: Int) -> QueryPlan where JoinShape q, Row f =
    compositeReducePlan "RIGHT" (joinedSourcePlan x.source) x.right.table x.cond.tree where2 lim (rowColumns (entityWitness x.right))

fn fullReducePlan (x: FullJoined q f a) (where2: QExpr) (lim: Int) -> QueryPlan where JoinShape q, Row f =
    compositeReducePlan "FULL" (joinedSourcePlan x.source) x.right.table x.cond.tree where2 lim (rowColumns (entityWitness x.right))

-- Run a `COUNT(*)` aggregate over a composite reduction plan and read the count off its
-- lone row, or probe the plan for a single row. Shared by every composite's `count`,
-- `exists`, and `every` (which counts twice).
fn compositeCount (conn: a) (plan: QueryPlan) -> Result Int Error where Adapter a =
    match runPlan conn (planAggregate "COUNT" "" 0 plan)
        Err err -> Err err
        Ok rows -> aggCount rows

fn compositeExists (conn: a) (plan: QueryPlan) -> Result Bool Error where Adapter a =
    match runPlan conn plan
        Err err -> Err err
        Ok rows -> Ok (nonEmpty rows)

-- The scalar-aggregate plan a composite `sumOf`/`avgOf`/`minOf`/`maxOf` runs: a
-- `PlanAggregate` over the composite's reduction, folding the column the accessor names
-- (`aggColumn`) on whichever leaf it belongs to (`aggLeaf` — 0/1 for the first two
-- tables, higher for a deeper one). One per shape, the kind carried by the reduction.
fn joinedScalarPlan (x: Joined q f a) (func: Text) (col: Quote p) -> QueryPlan where JoinShape q, Row f =
    planAggregate func (aggColumn col) (aggLeaf col) (joinedReducePlan x x.where2.tree (0 - 1))

fn leftScalarComposite (x: LeftJoined q f a) (func: Text) (col: Quote p) -> QueryPlan where JoinShape q, Row f =
    planAggregate func (aggColumn col) (aggLeaf col) (leftReducePlan x x.where2.tree (0 - 1))

fn rightScalarComposite (x: RightJoined q f a) (func: Text) (col: Quote p) -> QueryPlan where JoinShape q, Row f =
    planAggregate func (aggColumn col) (aggLeaf col) (rightReducePlan x x.where2.tree (0 - 1))

fn fullScalarComposite (x: FullJoined q f a) (func: Text) (col: Quote p) -> QueryPlan where JoinShape q, Row f =
    planAggregate func (aggColumn col) (aggLeaf col) (fullReducePlan x x.where2.tree (0 - 1))

instance Decodable (Join e f a) where Adapter a, Row f, Row e =
    toList (x: Join e f a) -> Result (List (e, f)) Error =
        match runPlan x.left.repo.adapter (innerJoinPlan x x.lim (rowColumns (entityWitness x.left.repo)) (rowColumns (entityWitness x.right)))
            Err err  -> Err err
            Ok rows  -> decodePrefixedPairs rows
    first (x: Join e f a) -> Result (Option (e, f)) Error =
        match runPlan x.left.repo.adapter (innerJoinPlan x 1 (rowColumns (entityWitness x.left.repo)) (rowColumns (entityWitness x.right)))
            Err err  -> Err err
            Ok rows  -> firstDecodedPrefixedPair rows

-- A left join's decode terminals: `toList` keeps every left row, decoding each
-- into `(e, Option f)` — the right side `None` where the left row matched no
-- right row — and `first` keeps the first such pair. `Rows (LeftJoin e f a)`
-- reduces to the pair `(e, Option f)`, so the result is `List (e, Option f)`/
-- `Option (e, Option f)`. Like the inner join it carries `Row e, Row f`: the
-- right side is decoded only when present.
-- `Row f, Row e` order, as on the inner-join instance above: it matches the
-- order `decodeLeftPrefixed`/`firstDecodedLeftPrefixed` list their entity constraints, so
-- the forwarded dictionaries land in the right slots.
instance Decodable (LeftJoin e f a) where Adapter a, Row f, Row e =
    toList (x: LeftJoin e f a) -> Result (List (e, Option f)) Error =
        match runPlan x.left.repo.adapter (leftJoinPlan x x.lim (rowColumns (entityWitness x.left.repo)) (rowColumns (entityWitness x.right)))
            Err err  -> Err err
            Ok rows  -> decodeLeftPrefixed rows
    first (x: LeftJoin e f a) -> Result (Option (e, Option f)) Error =
        match runPlan x.left.repo.adapter (leftJoinPlan x 1 (rowColumns (entityWitness x.left.repo)) (rowColumns (entityWitness x.right)))
            Err err  -> Err err
            Ok rows  -> firstDecodedLeftPrefixed rows

-- A right join's decode terminals: `toList` keeps every right row, decoding each into
-- `(Option e, f)` — the left side `None` where the right row matched no left row —
-- and `first` keeps the first such pair. `Rows (RightJoin e f a)` reduces to the pair
-- `(Option e, f)`, so the result is `List (Option e, f)`/`Option (Option e, f)`. Like
-- the left join it carries `Row e, Row f`: the left side is decoded only when present.
-- `Row f, Row e` order, as on the left-join instance above: it matches the order
-- `decodeRightPrefixed`/`firstDecodedRightPrefixed` list their entity constraints, so the
-- forwarded dictionaries land in the right slots.
instance Decodable (RightJoin e f a) where Adapter a, Row f, Row e =
    toList (x: RightJoin e f a) -> Result (List (Option e, f)) Error =
        match runPlan x.left.repo.adapter (rightJoinPlan x x.lim (rowColumns (entityWitness x.left.repo)) (rowColumns (entityWitness x.right)))
            Err err  -> Err err
            Ok rows  -> decodeRightPrefixed rows
    first (x: RightJoin e f a) -> Result (Option (Option e, f)) Error =
        match runPlan x.left.repo.adapter (rightJoinPlan x 1 (rowColumns (entityWitness x.left.repo)) (rowColumns (entityWitness x.right)))
            Err err  -> Err err
            Ok rows  -> firstDecodedRightPrefixed rows

-- A full join's decode terminals: `toList` keeps every row of both tables, decoding
-- each into `(Option e, Option f)` — `None` on whichever side the row matched none —
-- and `first` keeps the first such pair. `Rows (FullJoin e f a)` reduces to the pair
-- `(Option e, Option f)`, so the result is `List (Option e, Option f)`/
-- `Option (Option e, Option f)`. Both sides are decoded only when present, so it
-- carries `Row e, Row f`. The `Row f, Row e` order matches the left/right instances
-- above: `decodeFullPrefixed`/`firstDecodedFullPrefixed` decode the left side first, so
-- their generalised schemes list the entity dictionaries the same way and the
-- forwarded dictionaries land in the right slots.
instance Decodable (FullJoin e f a) where Adapter a, Row f, Row e =
    toList (x: FullJoin e f a) -> Result (List (Option e, Option f)) Error =
        match runPlan x.left.repo.adapter (fullJoinPlan x x.lim (rowColumns (entityWitness x.left.repo)) (rowColumns (entityWitness x.right)))
            Err err  -> Err err
            Ok rows  -> decodeFullPrefixed rows
    first (x: FullJoin e f a) -> Result (Option (Option e, Option f)) Error =
        match runPlan x.left.repo.adapter (fullJoinPlan x 1 (rowColumns (entityWitness x.left.repo)) (rowColumns (entityWitness x.right)))
            Err err  -> Err err
            Ok rows  -> firstDecodedFullPrefixed rows

-- A query's page and distinct: set the field on the query, carrying every other
-- field through. The behaviour the single-receiver `limit`/`offset`/`distinct`
-- pub fns had before they unified with the join form.
instance Pageable (Query e a) =
    limit (n: Int) (x: Query e a) -> Query e a =
        Query { repo = x.repo, pred = x.pred, orders = x.orders, lim = n, off = x.off, dist = x.dist, plan = x.plan }
    offset (n: Int) (x: Query e a) -> Query e a =
        Query { repo = x.repo, pred = x.pred, orders = x.orders, lim = x.lim, off = n, dist = x.dist, plan = x.plan }
    distinct (x: Query e a) -> Query e a =
        Query { repo = x.repo, pred = x.pred, orders = x.orders, lim = x.lim, off = x.off, dist = true, plan = x.plan }

-- An inner join's page and distinct: set the field on the join. The join carries
-- its own `lim`/`off`/`dist` (lifted from the left query at `joinOn`), so a `limit`
-- or `distinct` on the join bounds or de-duplicates the joined rows the terminal
-- decodes, not the left table alone.
instance Pageable (Join e f a) =
    limit (n: Int) (x: Join e f a) -> Join e f a =
        Join { left = x.left, right = x.right, cond = x.cond, where2 = x.where2, orders = x.orders, lim = n, off = x.off, dist = x.dist }
    offset (n: Int) (x: Join e f a) -> Join e f a =
        Join { left = x.left, right = x.right, cond = x.cond, where2 = x.where2, orders = x.orders, lim = x.lim, off = n, dist = x.dist }
    distinct (x: Join e f a) -> Join e f a =
        Join { left = x.left, right = x.right, cond = x.cond, where2 = x.where2, orders = x.orders, lim = x.lim, off = x.off, dist = true }

-- A left join's page and distinct: the dual over a `LeftJoin`, setting the same
-- fields. `distinct` de-duplicates the `(left, right)` rows the terminal returns,
-- the unmatched-right rows (right side reported as `None`) included.
instance Pageable (LeftJoin e f a) =
    limit (n: Int) (x: LeftJoin e f a) -> LeftJoin e f a =
        LeftJoin { left = x.left, right = x.right, cond = x.cond, where2 = x.where2, orders = x.orders, lim = n, off = x.off, dist = x.dist }
    offset (n: Int) (x: LeftJoin e f a) -> LeftJoin e f a =
        LeftJoin { left = x.left, right = x.right, cond = x.cond, where2 = x.where2, orders = x.orders, lim = x.lim, off = n, dist = x.dist }
    distinct (x: LeftJoin e f a) -> LeftJoin e f a =
        LeftJoin { left = x.left, right = x.right, cond = x.cond, where2 = x.where2, orders = x.orders, lim = x.lim, off = x.off, dist = true }

-- A right join's page and distinct: the dual over a `RightJoin`, setting the same
-- fields. `distinct` de-duplicates the `(left, right)` rows the terminal returns, the
-- unmatched-left rows (left side reported as `None`) included.
instance Pageable (RightJoin e f a) =
    limit (n: Int) (x: RightJoin e f a) -> RightJoin e f a =
        RightJoin { left = x.left, right = x.right, cond = x.cond, where2 = x.where2, orders = x.orders, lim = n, off = x.off, dist = x.dist }
    offset (n: Int) (x: RightJoin e f a) -> RightJoin e f a =
        RightJoin { left = x.left, right = x.right, cond = x.cond, where2 = x.where2, orders = x.orders, lim = x.lim, off = n, dist = x.dist }
    distinct (x: RightJoin e f a) -> RightJoin e f a =
        RightJoin { left = x.left, right = x.right, cond = x.cond, where2 = x.where2, orders = x.orders, lim = x.lim, off = x.off, dist = true }

-- A full join's page and distinct: the dual over a `FullJoin`, setting the same
-- fields. `distinct` de-duplicates the `(left, right)` rows the terminal returns,
-- both the unmatched-left and unmatched-right rows (the missing side reported as
-- `None`) included.
instance Pageable (FullJoin e f a) =
    limit (n: Int) (x: FullJoin e f a) -> FullJoin e f a =
        FullJoin { left = x.left, right = x.right, cond = x.cond, where2 = x.where2, orders = x.orders, lim = n, off = x.off, dist = x.dist }
    offset (n: Int) (x: FullJoin e f a) -> FullJoin e f a =
        FullJoin { left = x.left, right = x.right, cond = x.cond, where2 = x.where2, orders = x.orders, lim = x.lim, off = n, dist = x.dist }
    distinct (x: FullJoin e f a) -> FullJoin e f a =
        FullJoin { left = x.left, right = x.right, cond = x.cond, where2 = x.where2, orders = x.orders, lim = x.lim, off = x.off, dist = true }

-- The count of a query's rows, honouring its set-operation plan. A plain query
-- counts through the backend's `COUNT(*)` over its filter (a push-down, no rows
-- fetched); a query a set operation already built counts the combined result,
-- materialised through `runPlan` and measured. The filter applies either way,
-- ordering and paging do not — a count answers the size of the matched row set,
-- not a paged window of it, the same rule the scalar aggregates follow.
fn countQuery (x: Query e a) -> Result Int Error where Adapter a =
    match x.plan
        None   -> countWhere x.repo.adapter x.repo.table x.pred
        Some p ->
            match runPlan x.repo.adapter (planRefine p x.pred.tree [] (0 - 1) 0 false)
                Err err -> Err err
                Ok rows -> Ok (lengthOf rows)

-- Whether a row list holds anything — the answer `exists` gives once the backend
-- returns a one-row probe of the query or join.
fn nonEmpty (xs: List t) -> Bool =
    match xs
        []     -> false
        _ :: _ -> true

-- The length of a row list, for measuring a materialised set-operation result.
fn lengthOf (xs: List t) -> Int =
    match xs
        []        -> 0
        _ :: rest -> 1 + lengthOf rest

-- A query's `count`/`exists`: count its filtered rows (honouring a set-operation
-- plan through `countQuery`) or probe for a single row. The behaviour the single-
-- receiver `count`/`exists` pub fns had before they unified with the join form.
instance Countable (Query e a) where Adapter a =
    count (x: Query e a) -> Result Int Error =
        countQuery x
    exists (x: Query e a) -> Result Bool Error =
        match x.plan
            None ->
                match fetch x.repo.adapter x.repo.table x.pred [] 1 0 false
                    Err err -> Err err
                    Ok rows -> Ok (nonEmpty rows)
            Some p ->
                match runPlan x.repo.adapter (planRefine p x.pred.tree [] 1 0 false)
                    Err err -> Err err
                    Ok rows -> Ok (nonEmpty rows)

-- An inner join's `count`/`exists`: count the joined pairs through a `PlanAggregate`
-- `COUNT` over the join plan (`countJoinPlan`), or probe the join plan for a single
-- row. As with the join aggregates, the join is neither ordered nor paged — these
-- answer the matched set, not a window — so `reduceJoin` leaves ordering and paging
-- off, save the one-row limit `exists` reads its answer from.
instance Countable (Join e f a) where Adapter a =
    count (x: Join e f a) -> Result Int Error =
        countJoinPlan x x.where2.tree
    exists (x: Join e f a) -> Result Bool Error =
        match runPlan x.left.repo.adapter (reduceJoin x x.where2.tree 1)
            Err err  -> Err err
            Ok rows  -> Ok (nonEmpty rows)

-- A left join's `count`/`exists`: the dual over a `LeftJoin`, counted through
-- `countLeftJoin` (a `COUNT(*)` over the left-outer join, every left row kept).
-- `exists` is true whenever the join keeps any row — a left join keeps one per left
-- row the `where2` admits.
instance Countable (LeftJoin e f a) where Adapter a =
    count (x: LeftJoin e f a) -> Result Int Error =
        leftCountPlan x x.where2.tree
    exists (x: LeftJoin e f a) -> Result Bool Error =
        match runPlan x.left.repo.adapter (leftReduceJoin x x.where2.tree 1)
            Err err  -> Err err
            Ok rows  -> Ok (nonEmpty rows)

-- A right join's `count`/`exists`: the dual over a `RightJoin`, counted through
-- `countRightJoin` (a `COUNT(*)` over the right-outer join, every right row kept).
-- `exists` is true whenever the join keeps any row — a right join keeps one per right
-- row the `where2` admits.
instance Countable (RightJoin e f a) where Adapter a =
    count (x: RightJoin e f a) -> Result Int Error =
        rightCountPlan x x.where2.tree
    exists (x: RightJoin e f a) -> Result Bool Error =
        match runPlan x.left.repo.adapter (rightReduceJoin x x.where2.tree 1)
            Err err  -> Err err
            Ok rows  -> Ok (nonEmpty rows)

-- A full join's `count`/`exists`: the dual over a `FullJoin`, counted through
-- `countFullJoin` (a `COUNT(*)` over the full-outer join, every row of both tables
-- kept). `exists` is true whenever the join keeps any row — a full join keeps one per
-- row of either table the `where2` admits.
instance Countable (FullJoin e f a) where Adapter a =
    count (x: FullJoin e f a) -> Result Int Error =
        fullCountPlan x x.where2.tree
    exists (x: FullJoin e f a) -> Result Bool Error =
        match runPlan x.left.repo.adapter (fullReduceJoin x x.where2.tree 1)
            Err err  -> Err err
            Ok rows  -> Ok (nonEmpty rows)

-- A query's `every`: compare the query's count against the count once the further
-- predicate is folded into its filter, equal exactly when no selected row fails it.
-- The predicate is AND-folded with `quoteAnd` (the same fold `filter` runs) and the
-- query re-counted through `countQuery`, so it tracks the query's own filter and a
-- set-operation plan alike. The fold is inlined rather than routed through `filter`
-- so the instance body stays a plain record reconstruction with no cross-class
-- dictionary to thread.
instance Every (Query e a) (fn e -> Bool) where Adapter a =
    every (pred: Quote (fn e -> Bool)) (x: Query e a) -> Result Bool Error =
        match countQuery x
            Err err  -> Err err
            Ok total ->
                match countQuery (Query { repo = x.repo, pred = quoteAnd x.pred pred, orders = x.orders, lim = x.lim, off = x.off, dist = x.dist, plan = x.plan })
                    Err err     -> Err err
                    Ok matching -> Ok (total == matching)

-- An inner join's `every`: compare the join's count against the count once the
-- predicate folds into the post-join `WHERE`, both counted through a `PlanAggregate`
-- `COUNT` over the join plan (`countJoinPlan`), the second narrowing `where2` with the
-- extra predicate AND-folded in.
instance Every (Join e f a) (fn e f -> Bool) where Adapter a =
    every (pred: Quote (fn e f -> Bool)) (x: Join e f a) -> Result Bool Error =
        let folded = quoteAnd2 x.where2 pred
        match countJoinPlan x x.where2.tree
            Err err  -> Err err
            Ok total ->
                match countJoinPlan x folded.tree
                    Err err     -> Err err
                    Ok matching -> Ok (total == matching)

-- A left join's `every`: the dual over a `LeftJoin`, counted through
-- `countLeftJoin`. The predicate folds into the post-join `WHERE`, where a test over
-- a right column drops the unmatched rows, so they fail `every` as SQL's three-valued
-- reading gives.
instance Every (LeftJoin e f a) (fn e f -> Bool) where Adapter a =
    every (pred: Quote (fn e f -> Bool)) (x: LeftJoin e f a) -> Result Bool Error =
        let folded = quoteAnd2 x.where2 pred
        match leftCountPlan x x.where2.tree
            Err err  -> Err err
            Ok total ->
                match leftCountPlan x folded.tree
                    Err err     -> Err err
                    Ok matching -> Ok (total == matching)

-- A right join's `every`: the dual over a `RightJoin`, counted through
-- `countRightJoin`. The predicate folds into the post-join `WHERE`, where a test over
-- a left column drops the unmatched rows, so they fail `every` as SQL's three-valued
-- reading gives.
instance Every (RightJoin e f a) (fn e f -> Bool) where Adapter a =
    every (pred: Quote (fn e f -> Bool)) (x: RightJoin e f a) -> Result Bool Error =
        let folded = quoteAnd2 x.where2 pred
        match rightCountPlan x x.where2.tree
            Err err  -> Err err
            Ok total ->
                match rightCountPlan x folded.tree
                    Err err     -> Err err
                    Ok matching -> Ok (total == matching)

-- A full join's `every`: the dual over a `FullJoin`, counted through `countFullJoin`.
-- The predicate folds into the post-join `WHERE`, where a test over a column of an
-- unmatched side drops those rows, so they fail `every` as SQL's three-valued reading
-- gives.
instance Every (FullJoin e f a) (fn e f -> Bool) where Adapter a =
    every (pred: Quote (fn e f -> Bool)) (x: FullJoin e f a) -> Result Bool Error =
        let folded = quoteAnd2 x.where2 pred
        match fullCountPlan x x.where2.tree
            Err err  -> Err err
            Ok total ->
                match fullCountPlan x folded.tree
                    Err err     -> Err err
                    Ok matching -> Ok (total == matching)

-- A composite join's `count`/`exists`: count the joined rows of a three-or-more table
-- chain through a `COUNT(*)` over its reduction plan, or probe it for one row. One pair
-- per composite shape, each folding over its own join kind — an outer shape counts its
-- kept-but-unmatched rows the same way the binary outer `count` does. Like the binary
-- counts, the reduction is neither ordered nor paged: these answer the matched set, not
-- a window of it.
instance Countable (Joined q f a) where Adapter a, JoinShape q, Row f =
    count (x: Joined q f a) -> Result Int Error =
        compositeCount x.right.adapter (joinedReducePlan x x.where2.tree (0 - 1))
    exists (x: Joined q f a) -> Result Bool Error =
        compositeExists x.right.adapter (joinedReducePlan x x.where2.tree 1)

instance Countable (LeftJoined q f a) where Adapter a, JoinShape q, Row f =
    count (x: LeftJoined q f a) -> Result Int Error =
        compositeCount x.right.adapter (leftReducePlan x x.where2.tree (0 - 1))
    exists (x: LeftJoined q f a) -> Result Bool Error =
        compositeExists x.right.adapter (leftReducePlan x x.where2.tree 1)

instance Countable (RightJoined q f a) where Adapter a, JoinShape q, Row f =
    count (x: RightJoined q f a) -> Result Int Error =
        compositeCount x.right.adapter (rightReducePlan x x.where2.tree (0 - 1))
    exists (x: RightJoined q f a) -> Result Bool Error =
        compositeExists x.right.adapter (rightReducePlan x x.where2.tree 1)

instance Countable (FullJoined q f a) where Adapter a, JoinShape q, Row f =
    count (x: FullJoined q f a) -> Result Int Error =
        compositeCount x.right.adapter (fullReducePlan x x.where2.tree (0 - 1))
    exists (x: FullJoined q f a) -> Result Bool Error =
        compositeExists x.right.adapter (fullReducePlan x x.where2.tree 1)

-- A composite join's `every`: compare the chain's count against the count once the
-- further predicate folds into the post-join `WHERE`, equal exactly when no joined row
-- fails it. The predicate is the positional leaf form the receiver determines; its
-- stored two-row form is what `quoteAnd2` folds into `where2`. One pair per composite
-- shape, each re-counting at its own kind through the shared reduction plan.
instance Every (Joined q f a) (Map Text SqlValue -> Map Text SqlValue -> Bool) where Adapter a, JoinShape q, Row f =
    every (pred: Quote (Map Text SqlValue -> Map Text SqlValue -> Bool)) (x: Joined q f a) -> Result Bool Error =
        let folded = quoteAnd2 x.where2 pred
        match compositeCount x.right.adapter (joinedReducePlan x x.where2.tree (0 - 1))
            Err err  -> Err err
            Ok total ->
                match compositeCount x.right.adapter (joinedReducePlan x folded.tree (0 - 1))
                    Err err     -> Err err
                    Ok matching -> Ok (total == matching)

instance Every (LeftJoined q f a) (Map Text SqlValue -> Map Text SqlValue -> Bool) where Adapter a, JoinShape q, Row f =
    every (pred: Quote (Map Text SqlValue -> Map Text SqlValue -> Bool)) (x: LeftJoined q f a) -> Result Bool Error =
        let folded = quoteAnd2 x.where2 pred
        match compositeCount x.right.adapter (leftReducePlan x x.where2.tree (0 - 1))
            Err err  -> Err err
            Ok total ->
                match compositeCount x.right.adapter (leftReducePlan x folded.tree (0 - 1))
                    Err err     -> Err err
                    Ok matching -> Ok (total == matching)

instance Every (RightJoined q f a) (Map Text SqlValue -> Map Text SqlValue -> Bool) where Adapter a, JoinShape q, Row f =
    every (pred: Quote (Map Text SqlValue -> Map Text SqlValue -> Bool)) (x: RightJoined q f a) -> Result Bool Error =
        let folded = quoteAnd2 x.where2 pred
        match compositeCount x.right.adapter (rightReducePlan x x.where2.tree (0 - 1))
            Err err  -> Err err
            Ok total ->
                match compositeCount x.right.adapter (rightReducePlan x folded.tree (0 - 1))
                    Err err     -> Err err
                    Ok matching -> Ok (total == matching)

instance Every (FullJoined q f a) (Map Text SqlValue -> Map Text SqlValue -> Bool) where Adapter a, JoinShape q, Row f =
    every (pred: Quote (Map Text SqlValue -> Map Text SqlValue -> Bool)) (x: FullJoined q f a) -> Result Bool Error =
        let folded = quoteAnd2 x.where2 pred
        match compositeCount x.right.adapter (fullReducePlan x x.where2.tree (0 - 1))
            Err err  -> Err err
            Ok total ->
                match compositeCount x.right.adapter (fullReducePlan x folded.tree (0 - 1))
                    Err err     -> Err err
                    Ok matching -> Ok (total == matching)

-- A query's `groupBy`: name the group-key column with a one-row accessor (`fn (u:
-- User) -> u.dept`, exactly as an `orderBy` key) and wrap the query into the unified
-- `Grouped` builder. `aggColumn`/`aggSide` read the column and its side from the
-- captured key; a query has no right table, so the side is always the left.
instance Groupable (Query e a) (fn e -> k) =
    groupBy (key: Quote (fn e -> k)) (x: Query e a) -> Grouped (Query e a) (fn e -> k) =
        Grouped { source = x, keyCol = aggColumn key, keySide = aggSide key, havingTree = keepAllTree () }

-- A query's `summarize` seam: run the `GROUP BY` (and any `HAVING`) over the query's
-- own filter through the `groupSummarize` push-down, returning one raw row per group
-- for `summarize` to decode. The key side is unused for a query (no right table).
instance Summarizable (Query e a) where Adapter a =
    runGroups (src: Query e a) (keyCol: Text) (keySide: Bool) (projTree: QExpr) (havingTree: QExpr) -> Result (List (Map Text SqlValue)) Error =
        groupSummarize src.repo.adapter src.repo.table src.pred keyCol (groupCols keyCol projTree) havingTree

-- An inner join's `groupBy`: the key is a two-row accessor naming a column from
-- either side (`fn (u: User) (p: Post) -> p.category` groups by the right table);
-- `aggColumn`/`aggSide` read the column and its side off the captured key, and the
-- join is wrapped into the unified `Grouped` builder. The right side is read as the
-- plain entity `f`, like the join aggregates — a grouped aggregate folds values, it
-- does not produce one per row.
instance Groupable (Join e f a) (fn e f -> k) =
    groupBy (key: Quote (fn e f -> k)) (x: Join e f a) -> Grouped (Join e f a) (fn e f -> k) =
        Grouped { source = x, keyCol = aggColumn key, keySide = aggSide key, havingTree = keepAllTree () }

-- A left join's `groupBy`: the two-row dual over a `LeftJoin`, the right side read as
-- the plain entity `f` as in the left-join aggregates. A right-side key groups the
-- unmatched left rows under the NULL key the backend gives them.
instance Groupable (LeftJoin e f a) (fn e f -> k) =
    groupBy (key: Quote (fn e f -> k)) (x: LeftJoin e f a) -> Grouped (LeftJoin e f a) (fn e f -> k) =
        Grouped { source = x, keyCol = aggColumn key, keySide = aggSide key, havingTree = keepAllTree () }

-- A right join's `groupBy`: the two-row dual over a `RightJoin`, both sides read as
-- the plain entities `e`/`f` as in the right-join aggregates. A left-side key groups
-- the unmatched right rows under the NULL key the backend gives them.
instance Groupable (RightJoin e f a) (fn e f -> k) =
    groupBy (key: Quote (fn e f -> k)) (x: RightJoin e f a) -> Grouped (RightJoin e f a) (fn e f -> k) =
        Grouped { source = x, keyCol = aggColumn key, keySide = aggSide key, havingTree = keepAllTree () }

-- A full join's `groupBy`: the two-row dual over a `FullJoin`, both sides read as the
-- plain entities `e`/`f` as in the full-join aggregates. A key over a side groups the
-- rows unmatched on that side under the NULL key the backend gives them.
instance Groupable (FullJoin e f a) (fn e f -> k) =
    groupBy (key: Quote (fn e f -> k)) (x: FullJoin e f a) -> Grouped (FullJoin e f a) (fn e f -> k) =
        Grouped { source = x, keyCol = aggColumn key, keySide = aggSide key, havingTree = keepAllTree () }

-- An inner join's `summarize` seam: run the `GROUP BY` (and any `HAVING`) over the
-- joined rows through a `PlanGroup` over the all-pairs join plan, side-qualifying the
-- key and each aggregate column to its table. Returns one raw row per group for
-- `summarize` to decode.
instance Summarizable (Join e f a) where Adapter a =
    runGroups (src: Join e f a) (keyCol: Text) (keySide: Bool) (projTree: QExpr) (havingTree: QExpr) -> Result (List (Map Text SqlValue)) Error =
        runPlan src.left.repo.adapter (planGroup keyCol keySide (groupCols keyCol projTree) havingTree (reduceJoin src src.where2.tree (0 - 1)))

-- A left join's `summarize` seam: the dual over a `LeftJoin`, run through the
-- `groupSummarizeLeftJoin` push-down. Every left row the post-join `WHERE` admits
-- joins a group; an unmatched one contributes its left columns and a NULL right side.
instance Summarizable (LeftJoin e f a) where Adapter a =
    runGroups (src: LeftJoin e f a) (keyCol: Text) (keySide: Bool) (projTree: QExpr) (havingTree: QExpr) -> Result (List (Map Text SqlValue)) Error =
        runPlan src.left.repo.adapter (planGroup keyCol keySide (groupCols keyCol projTree) havingTree (leftReduceJoin src src.where2.tree (0 - 1)))

-- A right join's `summarize` seam: the dual over a `RightJoin`, run through the
-- `groupSummarizeRightJoin` push-down. Every right row the post-join `WHERE` admits
-- joins a group; an unmatched one contributes its right columns and a NULL left side.
instance Summarizable (RightJoin e f a) where Adapter a =
    runGroups (src: RightJoin e f a) (keyCol: Text) (keySide: Bool) (projTree: QExpr) (havingTree: QExpr) -> Result (List (Map Text SqlValue)) Error =
        runPlan src.left.repo.adapter (planGroup keyCol keySide (groupCols keyCol projTree) havingTree (rightReduceJoin src src.where2.tree (0 - 1)))

-- A full join's `summarize` seam: the dual over a `FullJoin`, run through the
-- `groupSummarizeFullJoin` push-down. Every row of both tables the post-join `WHERE`
-- admits joins a group; an unmatched one contributes its present side's columns and a
-- NULL on the missing side, grouping under the NULL key for a key over that side.
instance Summarizable (FullJoin e f a) where Adapter a =
    runGroups (src: FullJoin e f a) (keyCol: Text) (keySide: Bool) (projTree: QExpr) (havingTree: QExpr) -> Result (List (Map Text SqlValue)) Error =
        runPlan src.left.repo.adapter (planGroup keyCol keySide (groupCols keyCol projTree) havingTree (fullReduceJoin src src.where2.tree (0 - 1)))

-- Strip a source prefix (`t0$`/`t1$`) from the keys of a flat joined row, keeping
-- only the columns of that source and re-keying them by their bare column name. A
-- `PlanJoin` returns each pair flattened with the two sides' columns prefixed so they
-- never collide; this recovers one side's row map for `fromRow` to decode.
fn unprefix (prefix: Text) (row: Map Text SqlValue) -> Map Text SqlValue =
    fromList (unprefixPairs prefix (Text.length prefix) (toList row))

fn unprefixPairs (prefix: Text) (plen: Int) (kvs: List (Text, SqlValue)) -> List (Text, SqlValue) =
    match kvs
        []             -> []
        (k, v) :: rest ->
            if Text.startsWith prefix k then (Text.slice plen (Text.length k - plen) k, v) :: unprefixPairs prefix plen rest
            else unprefixPairs prefix plen rest

-- Decode the flat, source-prefixed rows a `PlanJoin` returns into entity pairs: the
-- `t0$`-prefixed columns decode the left entity and the `t1$`-prefixed the right. The
-- prefixed dual of `decodePairs`. Stops at the first decode failure on either side.
fn decodePrefixedPairs (rows: List (Map Text SqlValue)) -> Result (List (e, f)) Error where Row e, Row f =
    match rows
        []          -> Ok []
        row :: rest ->
            match fromRow (unprefix "t0$" row)
                Err err -> Err err
                Ok x    ->
                    match fromRow (unprefix "t1$" row)
                        Err err -> Err err
                        Ok y    ->
                            match decodePrefixedPairs rest
                                Err err -> Err err
                                Ok xs   -> Ok ((x, y) :: xs)

-- The head of a flat source-prefixed join row list, decoded into an entity pair;
-- `None` when empty. The prefixed dual of `firstDecodedPair`, for `first` over a
-- `Join` run through the plan.
fn firstDecodedPrefixedPair (rows: List (Map Text SqlValue)) -> Result (Option (e, f)) Error where Row e, Row f =
    match rows
        []       -> Ok None
        row :: _ ->
            match fromRow (unprefix "t0$" row)
                Err err -> Err err
                Ok x    ->
                    match fromRow (unprefix "t1$" row)
                        Err err -> Err err
                        Ok y    -> Ok (Some (x, y))

-- Whether an outer-join row carries any column of the source under `prefix`. An
-- unmatched side contributes no prefixed columns, so a missing prefix means that
-- side matched no row — the presence marker the outer-join plan uses in place of the
-- inner join's always-both-sides flat row.
fn hasPrefix (prefix: Text) (row: Map Text SqlValue) -> Bool =
    anyKeyHasPrefix prefix (toList row)

fn anyKeyHasPrefix (prefix: Text) (kvs: List (Text, SqlValue)) -> Bool =
    match kvs
        []             -> false
        (k, _) :: rest -> if Text.startsWith prefix k then true else anyKeyHasPrefix prefix rest

-- Decode one optional side of an outer-join row: `None` when the side matched no
-- row, else `Some` of the entity decoded from the un-prefixed side.
fn decodeOptSide (prefix: Text) (row: Map Text SqlValue) -> Result (Option g) Error where Row g =
    if sidePresent prefix row then
        match fromRow (unprefix prefix row)
            Err err -> Err err
            Ok y    -> Ok (Some y)
    else Ok None

-- Whether an outer-join row's `prefix` side matched a row. The Postgres renderer tags
-- each null-extendable side with a presence marker column (`<prefix>__present__`): a
-- non-null value (`TRUE`) means the side matched, SQL NULL means it did not — needed
-- because Postgres returns an unmatched side's real columns as NULL rather than
-- omitting them. The in-memory backend emits no marker and instead drops an unmatched
-- side's columns, so when the marker is absent the side is present exactly when it
-- still carries any prefixed column.
fn sidePresent (prefix: Text) (row: Map Text SqlValue) -> Bool =
    match markerValue (Text.concat prefix "__present__") (toList row)
        Some v -> markerTrue v
        None   -> hasPrefix prefix row

fn markerValue (key: Text) (kvs: List (Text, SqlValue)) -> Option SqlValue =
    match kvs
        []             -> None
        (k, v) :: rest -> if k == key then Some v else markerValue key rest

-- A presence marker is `TRUE` when its side matched and SQL NULL when it did not, so
-- decoding it as a `Bool` answers presence: `TRUE` decodes to `true`, while SQL NULL
-- (or anything unexpected) fails the base decode and reads as absent.
fn markerTrue (v: SqlValue) -> Bool =
    match fromSql v
        Ok b  -> b
        Err _ -> false

-- Decode the flat, source-prefixed rows a `LEFT` join plan returns into `(e, Option f)`
-- pairs: the left side (`t0$`) is always present and decoded; the right (`t1$`) decodes
-- to `Some` when present and `None` when the left row matched no right row. The
-- prefixed dual of `decodeLeftPairs`; the left entity decodes first so the instance's
-- `Row f, Row e` dictionary order threads to the right slots.
fn decodeLeftPrefixed (rows: List (Map Text SqlValue)) -> Result (List (e, Option f)) Error where Row e, Row f =
    match rows
        []          -> Ok []
        row :: rest ->
            match fromRow (unprefix "t0$" row)
                Err err -> Err err
                Ok x    ->
                    match decodeOptSide "t1$" row
                        Err err -> Err err
                        Ok optY ->
                            match decodeLeftPrefixed rest
                                Err err -> Err err
                                Ok xs   -> Ok ((x, optY) :: xs)

fn firstDecodedLeftPrefixed (rows: List (Map Text SqlValue)) -> Result (Option (e, Option f)) Error where Row e, Row f =
    match rows
        []       -> Ok None
        row :: _ ->
            match fromRow (unprefix "t0$" row)
                Err err -> Err err
                Ok x    ->
                    match decodeOptSide "t1$" row
                        Err err -> Err err
                        Ok optY -> Ok (Some (x, optY))

-- Decode the flat, source-prefixed rows a `RIGHT` join plan returns into
-- `(Option e, f)` pairs: the right side (`t1$`) is always present, the left (`t0$`)
-- decodes to `None` when the right row matched no left row. The left entity decodes
-- first (its optional side), as in `decodeRightPairs`, to keep the dictionary order.
fn decodeRightPrefixed (rows: List (Map Text SqlValue)) -> Result (List (Option e, f)) Error where Row e, Row f =
    match rows
        []          -> Ok []
        row :: rest ->
            match decodeOptSide "t0$" row
                Err err -> Err err
                Ok optX ->
                    match fromRow (unprefix "t1$" row)
                        Err err -> Err err
                        Ok y    ->
                            match decodeRightPrefixed rest
                                Err err -> Err err
                                Ok xs   -> Ok ((optX, y) :: xs)

fn firstDecodedRightPrefixed (rows: List (Map Text SqlValue)) -> Result (Option (Option e, f)) Error where Row e, Row f =
    match rows
        []       -> Ok None
        row :: _ ->
            match decodeOptSide "t0$" row
                Err err -> Err err
                Ok optX ->
                    match fromRow (unprefix "t1$" row)
                        Err err -> Err err
                        Ok y    -> Ok (Some (optX, y))

-- Decode the flat, source-prefixed rows a `FULL` join plan returns into
-- `(Option e, Option f)` pairs: each side decodes to `Some` when present and `None`
-- when that side matched none. The left entity decodes first, as in `decodeFullPairs`.
fn decodeFullPrefixed (rows: List (Map Text SqlValue)) -> Result (List (Option e, Option f)) Error where Row e, Row f =
    match rows
        []          -> Ok []
        row :: rest ->
            match decodeOptSide "t0$" row
                Err err -> Err err
                Ok optX ->
                    match decodeOptSide "t1$" row
                        Err err -> Err err
                        Ok optY ->
                            match decodeFullPrefixed rest
                                Err err -> Err err
                                Ok xs   -> Ok ((optX, optY) :: xs)

fn firstDecodedFullPrefixed (rows: List (Map Text SqlValue)) -> Result (Option (Option e, Option f)) Error where Row e, Row f =
    match rows
        []       -> Ok None
        row :: _ ->
            match decodeOptSide "t0$" row
                Err err -> Err err
                Ok optX ->
                    match decodeOptSide "t1$" row
                        Err err -> Err err
                        Ok optY -> Ok (Some (optX, optY))

-- The `(alias, column)` pairs a projection names. The projection quote captures
-- a `QProj` whose select-list is a list of `(alias, QCol column)`; anything else
-- contributes no columns. Generic over the quote's function type so it reads an
-- entity-typed projection (`fn e -> s`) and a row-map one alike — only the
-- captured `tree` matters.
fn projColumns (proj: Quote p) -> List (Text, Text) =
    match proj.tree
        QProj cols -> projPairs cols
        _          -> []

fn projPairs (cols: List (Text, QExpr)) -> List (Text, Text) =
    match cols
        []                   -> []
        (alias, col) :: rest -> (alias, qcolName col) :: projPairs rest

fn qcolName (e: QExpr) -> Text =
    match e
        QCol c  -> c
        QColR c -> c
        _       -> ""

-- The column an ordering key names. The key quote captures a single column, so
-- its tree is a `QCol`; anything else contributes an empty key name. Generic over
-- the quote's function type (like `projColumns`) so it reads an entity-typed key
-- (`fn (u: User) -> u.age`, the unified `orderBy`'s shape) and a row-map one alike
-- — only the captured `tree` matters.
fn orderColumn (key: Quote p) -> Text =
    match key.tree
        QCol c -> c
        _      -> ""

-- Append one element to the end of a list. The ordering builders add each new key
-- after the keys already accumulated, so the keys sort major-to-minor in the order
-- written.
fn snoc (xs: List a) (x: a) -> List a =
    xs ++ [x]

-- Lift a query's one-row ordering keys into a join's side-tagged ordering: a
-- query's keys all range over its (left) entity, so each `(ascending?, column)`
-- becomes `(ascending?, false, column)`. The ordering a query accumulated before
-- it was joined carries into the join as left-side keys.
fn liftOrders (os: List (Bool, Text)) -> List (Bool, Bool, Text) =
    match os
        []               -> []
        (asc, c) :: rest -> (asc, false, c) :: liftOrders rest

-- A join ordering entry from a quoted key: the direction, which side the column
-- belongs to (a `QColR` names the right table), and the column name. A key that
-- does not name a single column contributes an empty left-side entry — the inert
-- shape `orderColumn` also falls back to.
fn orderEntry2 (dir: SortOrder) (key: Quote p) -> (Bool, Bool, Text) =
    match key.tree
        QCol c  -> (ascending dir, false, c)
        QColR c -> (ascending dir, true, c)
        _       -> (ascending dir, false, "")

-- The column an aggregate accessor names. Like an ordering key, the accessor
-- quote captures a single column — a `QCol` on the left/single table or a `QColR`
-- on a join's right table — and anything else contributes an empty column name.
-- Generic over the quote's function type (like `orderColumn`) so it reads a
-- query's `fn e -> n` accessor and a join's `fn e f -> n` accessor alike — only
-- the captured `tree` matters.
fn aggColumn (col: Quote p) -> Text =
    match col.tree
        QCol c      -> c
        QColR c     -> c
        QColAt _ c  -> c
        _           -> ""

-- Which join leaf an aggregate accessor names: a `QCol` is the first leaf (0, the
-- left/single table), a `QColR` the second (1, a binary join's right), and a
-- `QColAt i` the `i`-th leaf of a deeper composite. The seam qualifies the column to
-- that leaf's alias — the aggregate dual of how `orderEntry2` tags an ordering key's
-- side, generalised from two sides to an unbounded number of leaves.
fn aggLeaf (col: Quote p) -> Int =
    match col.tree
        QColR _    -> 1
        QColAt i _ -> i
        _          -> 0

-- Which side of a binary join an aggregate or group key names: a `QColR` tree is the
-- right table, anything else the left (or single) table. The two-table form `aggLeaf`
-- generalises; this stays for the group key's `keySide`, still a left/right boolean.
fn aggSide (col: Quote p) -> Bool =
    match col.tree
        QColR _ -> true
        _       -> false

-- An always-true `HAVING` tree — the group default before `having` narrows it. A
-- `Quote`/`QExpr` literal cannot be written in Ridge source, so the always-true
-- tree is taken from `keepAll`'s captured tree, the same one the query builder
-- seeds an unfiltered query with.
fn keepAllTree (_u: Unit) -> QExpr = (keepAll ()).tree

-- The `(alias, func, column)` triples a grouped projection names. The projection
-- tree is a `QProj` whose every entry pairs an output alias with a group aggregate
-- node; each maps to its SQL aggregate keyword and the column it folds — the key
-- column for `g.key`, none for `g.count`. Anything else contributes no columns.
fn groupCols (keyCol: Text) (tree: QExpr) -> List (Text, Text, Text, Bool) =
    match tree
        QProj cols -> groupColPairs keyCol cols
        _          -> []

fn groupColPairs (keyCol: Text) (cols: List (Text, QExpr)) -> List (Text, Text, Text, Bool) =
    match cols
        []                  -> []
        (alias, ex) :: rest -> (alias, aggFunc ex, aggCol keyCol ex, aggColSide ex) :: groupColPairs keyCol rest

-- Which side of a join a group aggregate folds: a right-side column (`QColR`) inside
-- a `g.sum`/`avg`/`min`/`max` node folds the right table. `g.key` and `g.count` fold
-- no column of their own — the key column is side-tagged on the grouped builder
-- (`keySide`) and a count names no column — so they default to the left.
fn aggColSide (ex: QExpr) -> Bool =
    match ex
        QAggSum c -> aggNodeSide c
        QAggAvg c -> aggNodeSide c
        QAggMin c -> aggNodeSide c
        QAggMax c -> aggNodeSide c
        _         -> false

fn aggNodeSide (c: QExpr) -> Bool =
    match c
        QColR _ -> true
        _       -> false

-- The SQL aggregate keyword a group aggregate node names.
fn aggFunc (ex: QExpr) -> Text =
    match ex
        QGroupKey -> "KEY"
        QAggCount -> "COUNT"
        QAggSum _ -> "SUM"
        QAggAvg _ -> "AVG"
        QAggMin _ -> "MIN"
        QAggMax _ -> "MAX"
        _         -> ""

-- The column a group aggregate node folds: the key column for `g.key`, the named
-- column for the scalar aggregates, and none for `g.count`.
fn aggCol (keyCol: Text) (ex: QExpr) -> Text =
    match ex
        QGroupKey -> keyCol
        QAggSum c -> qcolName c
        QAggAvg c -> qcolName c
        QAggMin c -> qcolName c
        QAggMax c -> qcolName c
        _         -> ""
