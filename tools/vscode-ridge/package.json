{
  "name": "vscode-ridge",
  "displayName": "Ridge",
  "description": "Ridge language support for VS Code: syntax and semantic highlighting, diagnostics, hover, go-to-definition, find-references, rename, signature help, formatting, and completion from ridge-lsp.",
  "version": "0.2.1",
  "publisher": "ridge-lang",
  "icon": "images/icon.png",
  "license": "Apache-2.0",
  "homepage": "https://github.com/ridge-lang/ridge#readme",
  "bugs": {
    "url": "https://github.com/ridge-lang/ridge/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ridge-lang/ridge"
  },
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "keywords": [
    "ridge",
    "ridge-lang",
    "beam",
    "erlang",
    "functional"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "activationEvents": [
    "onLanguage:ridge"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "ridge",
        "aliases": [
          "Ridge",
          "ridge"
        ],
        "extensions": [
          ".ridge"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "configuration": {
      "title": "Ridge",
      "properties": {
        "ridge.lspPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the ridge-lsp binary. Leave empty to auto-resolve (tries `~/.cargo/bin/ridge-lsp` first, then walks PATH). Set this when the binary lives in a non-standard location."
        }
      }
    },
    "grammars": [
      {
        "language": "ridge",
        "scopeName": "source.ridge",
        "path": "./syntaxes/ridge.tmLanguage.json"
      }
    ],
    "semanticTokenTypes": [
      {
        "id": "capability",
        "superType": "modifier",
        "description": "An effect capability annotation (io, fs, net, db, ...)."
      }
    ],
    "semanticTokenScopes": [
      {
        "scopes": {
          "capability": [
            "storage.modifier.capability.ridge",
            "storage.modifier"
          ]
        }
      }
    ],
    "configurationDefaults": {
      "[ridge]": {
        "editor.semanticHighlighting.enabled": true
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "bundle": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --target=node18",
    "test": "node test/indentation.test.mjs",
    "vscode:prepublish": "pnpm run bundle"
  },
  "packageManager": "pnpm@11.1.1",
  "dependencies": {
    "vscode-languageclient": "~9.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "esbuild-wasm": "^0.21.0",
    "typescript": "^5.3.0"
  }
}
