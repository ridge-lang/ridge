-- std.query — the runtime side of quotation.
--
-- When a lambda is passed where a `Quote` is expected, the compiler does not
-- lower it to a closure. It captures the body as a `QExpr` tree and wraps it in
-- a `Quote`. This is the same idea as C#'s `Expression<Func<>>`: the predicate
-- becomes data a later pass walks, rather than a function that runs.
--
-- `QExpr` and `Quote` are prelude builtins (like `JsonValue`), so they are in
-- scope here without an import. The compiler builds the tree directly; this
-- module walks it back, either rendering it to a readable string (`debugShow`)
-- or compiling it to parameterized SQL plus its bind values (`toSql`).

import std.sql (Sql, sql, SqlValue, sqlInt, sqlText, sqlBool, sqlFloat)
import std.int as Int

-- Sort direction for query ordering. A plain union declared in Ridge: importing
-- modules can name `SortOrder` and build/match `Asc`/`Desc` directly.
pub type SortOrder = Asc | Desc

-- A sort direction as the `ascending?` boolean a backend (or the query builder)
-- reads. Defined here, where `Asc`/`Desc` are declared, so the match is over the
-- module's own constructors.
pub fn ascending (dir: SortOrder) -> Bool =
    match dir
        Asc  -> true
        Desc -> false

-- A query plan: the captured tree the set-operation terminals run, the dual at the
-- plan layer of what `QExpr` is at the predicate layer. A plan node is an ordinary
-- Ridge value, built here and threaded through the query builder; a backend then
-- interprets it (the in-memory store walks the tree) or compiles it to nested SQL
-- (Postgres). Declared in this module, where the `QExpr` compiler lives, so the
-- renderer that turns a plan into SQL sits beside the predicate compiler it reuses.
--
-- `PlanScan` is a single-table read with its filter, ordering, page, and distinct
-- folded in — the plan form of a `fetch`: the table, its filter tree, the ordering
-- keys, the limit (negative for none) and offset (non-positive for none), and the
-- distinct flag. `PlanCombine` joins two plans with a set operation — `op` is the
-- SQL keyword `UNION`/`UNION ALL`/`INTERSECT`/`EXCEPT`. `PlanRefine` re-applies an
-- outer filter, ordering, page, and distinct on top of a plan's result — the
-- wrapper a combined query's own builder steps compile to. A combined query nests
-- the plans, so `(a ∪ b) ∪ c` runs as nested operations. `PlanJoin` pairs two
-- sub-plans on a join condition (`kind` is `INNER`/`LEFT`/`RIGHT`/`FULL`) with the
-- two-row post-join `WHERE`, ordering, page, and distinct folded in; its rows come
-- back flat with each source's columns prefixed (`t0$col`/`t1$col`) so the columns of
-- the two sides never collide and the result stays a single row map per pair. The two
-- trailing `List Text` carry each source entity's column names (`leftCols`/`rightCols`,
-- from `Row.rowColumns`): the SQL renderer needs them to spell the prefixed select list
-- (`t0."col" AS "t0$col"`) before any row exists, since the node itself knows only the
-- table names. The in-memory backend ignores them — it prefixes the row keys it holds.
-- `PlanProject` projects a sub-plan's rows through a projection tree (a `QProj`)
-- into rows keyed by the projection's output aliases, then de-duplicates and pages
-- — the plan form of a join `select`. It wraps a `PlanJoin`, whose flat
-- source-prefixed rows it reads (`QCol` names a left-source column, `QColR` a
-- right-source one); the join itself leaves its page and distinct off, since
-- `distinct` de-duplicates the projected columns and the page bounds the projected
-- rows, so both belong on the projection.
-- `PlanAggregate` reduces a sub-plan to a single scalar: `func` is the SQL aggregate
-- keyword (`COUNT`/`SUM`/`AVG`/`MIN`/`MAX`), `column` the column it folds (empty for
-- `COUNT`, which counts rows) and `isRight` which join source the column belongs to
-- (`t0$`/`t1$` over a `PlanJoin`'s prefixed rows). It yields exactly one row carrying
-- the scalar, or no row at all when the aggregate is SQL NULL (an empty fold) — so a
-- reader takes the lone cell as the value and an empty result as "none". A `COUNT` is
-- never NULL, so it always yields its row.
-- `PlanGroup` groups a sub-plan's rows by `keyCol` (qualified to the join leaf
-- `keyLeaf` selects — `t0`/`t1` for a binary join's two sides, higher for a deeper
-- composite) and summarises each group into the `(alias, func, column, leaf)`
-- aggregate columns, keeping the groups the `HAVING` tree admits; it yields one row
-- per group, keyed by alias and ordered by the key — the plan form of a grouped
-- join `summarize`. It wraps a `PlanJoin`, reading each group key and folded column
-- off the flat source-prefixed rows by their leaf's `t<leaf>$` prefix.
-- `PlanExists` wraps a sub-plan in an existence probe: it asks only whether the plan
-- yields any row, compiling to `SELECT 1 FROM … LIMIT 1` — the short-circuiting form an
-- `exists` terminal needs, leaner than fetching every column of a row it never reads. The
-- backend returns one trivial row when the sub-plan matches and none when it does not, so
-- the caller's emptiness check answers the same Bool as before.
pub type QueryPlan = PlanScan Text QExpr (List (Bool, QExpr)) Int Int Bool | PlanCombine Text QueryPlan QueryPlan | PlanRefine QueryPlan QExpr (List (Bool, QExpr)) Int Int Bool | PlanJoin Text QueryPlan QueryPlan QExpr QExpr (List (Bool, Int, QExpr)) Int Int Bool (List Text) (List Text) | PlanProject QExpr QueryPlan Int Int Bool | PlanAggregate Text QExpr Int QueryPlan |PlanGroup Text Int (List (Text, Text, QExpr, Int)) QExpr QueryPlan | PlanExists QueryPlan | PlanList (List (Map Text SqlValue))

-- A single-table scan plan — the plan form of `fetch`.
pub fn planScan (table: Text) (pred: QExpr) (orders: List (Bool, QExpr)) (lim: Int) (off: Int) (dist: Bool) -> QueryPlan =
    PlanScan table pred orders lim off dist

-- Combine two plans with a set operation. `op` is the SQL keyword the backend runs.
pub fn planCombine (op: Text) (left: QueryPlan) (right: QueryPlan) -> QueryPlan =
    PlanCombine op left right

-- Wrap a plan in an outer filter, ordering, page, and distinct — the refinement a
-- combined query's own builder steps apply on top of the combination.
pub fn planRefine (inner: QueryPlan) (pred: QExpr) (orders: List (Bool, QExpr)) (lim: Int) (off: Int) (dist: Bool) -> QueryPlan =
    PlanRefine inner pred orders lim off dist

-- Pair two sub-plans on a join. `kind` is the join shape (`INNER`/`LEFT`/`RIGHT`/
-- `FULL`), `cond` the join condition and `where2` the post-join `WHERE` (both two-row
-- trees over the left and right rows), and `orders` the side-tagged ordering keys.
-- `leftCols`/`rightCols` are each source entity's column names (from `Row.rowColumns`),
-- which the SQL renderer spells into the prefixed select list; the in-memory backend
-- ignores them. The result rows are flat with each side's columns prefixed (`t0$`/`t1$`).
pub fn planJoin (kind: Text) (left: QueryPlan) (right: QueryPlan) (cond: QExpr) (where2: QExpr) (orders: List (Bool, Int, QExpr)) (lim: Int) (off: Int) (dist: Bool) (leftCols: List Text) (rightCols: List Text) -> QueryPlan =
    PlanJoin kind left right cond where2 orders lim off dist leftCols rightCols

-- Project a sub-plan's rows through the projection tree `proj` (a `QProj`), then
-- de-duplicate (when `dist`) and page. Wraps a `PlanJoin`, projecting its flat
-- source-prefixed rows into rows keyed by the projection's output aliases.
pub fn planProject (proj: QExpr) (child: QueryPlan) (lim: Int) (off: Int) (dist: Bool) -> QueryPlan =
    PlanProject proj child lim off dist

-- Reduce a sub-plan to a single scalar through the aggregate `func` over `column`
-- (`leaf` is the index of the join leaf the column belongs to — 0/1 for a binary
-- join's two sides, higher for a deeper composite; `column` is unused for `COUNT`).
-- The result is one row carrying the scalar, or no row when the aggregate is SQL NULL.
pub fn planAggregate (func: Text) (column: QExpr) (leaf: Int) (child: QueryPlan) -> QueryPlan =
    PlanAggregate func column leaf child

-- Group a sub-plan's rows by `keyCol` (on the join leaf `keyLeaf`), summarise each
-- group into the `(alias, func, column, leaf)` aggregate columns — where `column`
-- is the folded value, a column or a computed expression over the leaves — and keep
-- the groups the `having` tree admits. The result is one row per group keyed by
-- alias, ordered by the key.
pub fn planGroup (keyCol: Text) (keyLeaf: Int) (cols: List (Text, Text, QExpr, Int)) (having: QExpr) (child: QueryPlan) -> QueryPlan =
    PlanGroup keyCol keyLeaf cols having child

-- Wrap a plan in an existence probe — the plan form of `exists`. It compiles to a
-- single-row `SELECT 1 FROM … LIMIT 1` that short-circuits at the first match, rather
-- than fetching every column of a row whose contents the caller discards.
pub fn planExists (child: QueryPlan) -> QueryPlan =
    PlanExists child

-- `PlanList` is the in-memory query source: the rows `from` snapshotted, carried
-- inline in the plan. The interpreter returns them as-is; the query verbs wrap this
-- leaf (in a `PlanRefine`, `PlanProject`, …) to refine it, exactly as they wrap a
-- table scan on the database path. Mem-only — it never reaches the SQL renderer.
pub fn planList (rows: List (Map Text SqlValue)) -> QueryPlan =
    PlanList rows

-- ── Plan optimization ─────────────────────────────────────────────────────────
--
-- A plan-to-plan rewrite run before the SQL renderer: it rewrites a `QueryPlan` into
-- an equivalent one that compiles to tighter SQL. Every rewrite is a semantic
-- identity, so a backend reads back the same rows — just reached through cleaner SQL.
-- The first rule folds the boolean constants out of every captured predicate, so the
-- always-true filter a builder step leaves behind (an unrefined query's `WHERE`, a
-- join with no extra condition) collapses to a bare `TRUE` the renderer then drops,
-- and a compound predicate carrying a constant (`p AND TRUE`, `p OR FALSE`) reduces to
-- `p`. The in-memory backend walks the plan tree directly and does not run this; it is
-- the Postgres renderer's pre-pass, applied once in `planToSql`.
pub fn optimize (plan: QueryPlan) -> QueryPlan =
    match plan
        PlanScan table pred orders lim off dist ->
            PlanScan table (simplifyPred pred) orders lim off dist
        PlanCombine op left right ->
            PlanCombine op (optimize left) (optimize right)
        PlanRefine inner pred orders lim off dist ->
            PlanRefine (optimize inner) (simplifyPred pred) orders lim off dist
        PlanJoin kind left right cond where2 orders lim off dist leftCols rightCols ->
            PlanJoin kind (optimize left) (optimize right) (simplifyPred cond) (simplifyPred where2) orders lim off dist leftCols rightCols
        PlanProject proj child lim off dist ->
            PlanProject proj (optimize child) lim off dist
        PlanAggregate func column leaf child ->
            PlanAggregate func column leaf (optimize child)
        PlanGroup keyCol keyLeaf cols having child ->
            PlanGroup keyCol keyLeaf cols (simplifyPred having) (optimize child)
        PlanExists child ->
            PlanExists (optimize child)
        PlanList rows ->
            PlanList rows

-- Fold the boolean constants out of a captured predicate, bottom-up: a conjunction
-- with a `TRUE` arm drops it and with a `FALSE` arm collapses to `FALSE`; a disjunction
-- is the dual; a negated literal flips and a double negation cancels. A comparison or
-- column leaf has nothing to fold and returns unchanged.
fn simplifyPred (e: QExpr) -> QExpr =
    match e
        QAnd l r -> andOf (simplifyPred l) (simplifyPred r)
        QOr l r  -> orOf (simplifyPred l) (simplifyPred r)
        QNot x   -> notOf (simplifyPred x)
        _        -> e

fn andOf (l: QExpr) (r: QExpr) -> QExpr =
    if isFalse l then QLitBool false
    else if isFalse r then QLitBool false
    else if isAlwaysTrue l then r
    else if isAlwaysTrue r then l
    else QAnd l r

fn orOf (l: QExpr) (r: QExpr) -> QExpr =
    if isAlwaysTrue l then QLitBool true
    else if isAlwaysTrue r then QLitBool true
    else if isFalse l then r
    else if isFalse r then l
    else QOr l r

fn notOf (x: QExpr) -> QExpr =
    match x
        QLitBool b -> if b then QLitBool false else QLitBool true
        QNot y     -> y
        _          -> QNot x

fn isFalse (e: QExpr) -> Bool =
    match e
        QLitBool b -> if b then false else true
        _          -> false

-- Render a captured tree to a readable, SQL-shaped string. Literals show as `?`
-- placeholders — binding parameters is the SQL-compilation pass's job; this is
-- here to confirm a quoted body round-trips to a tree.
pub fn debugShow (q: Quote f) -> Text = showExpr q.tree

fn showExpr (e: QExpr) -> Text =
    match e
        QCol c      -> c
        QColR c     -> c
        QColAt _ c  -> c
        QLitInt _   -> "?"
        QLitText _  -> "?"
        QLitBool _  -> "?"
        QLitFloat _ -> "?"
        QNot x      -> Text.concat "(NOT " (Text.concat (showExpr x) ")")
        QNotTrue x  -> Text.concat "(" (Text.concat (showExpr x) " IS NOT TRUE)")
        QAnd l r    -> binNode l " AND " r
        QOr l r     -> binNode l " OR " r
        QEq l r     -> binNode l " = " r
        QNe l r     -> binNode l " <> " r
        QLt l r     -> binNode l " < " r
        QGt l r     -> binNode l " > " r
        QLe l r     -> binNode l " <= " r
        QGe l r     -> binNode l " >= " r
        QProj cols  -> Text.join ", " (showProjCols cols)
        QGroupKey   -> "key"
        QAggCount   -> "count(*)"
        QAggSum c   -> aggShow "sum" c
        QAggAvg c   -> aggShow "avg" c
        QAggMin c   -> aggShow "min" c
        QAggMax c   -> aggShow "max" c
        QLike v p   -> binNode v " LIKE " p
        QIn v items -> Text.join "" ["(", showExpr v, " IN (", Text.join ", " (showInList items), "))"]
        QAdd l r    -> binNode l " + " r
        QSub l r    -> binNode l " - " r
        QMul l r    -> binNode l " * " r
        QDiv l r    -> binNode l " / " r
        QMod l r    -> binNode l " % " r
        QCase c t e -> Text.join "" ["(CASE WHEN ", showExpr c, " THEN ", showExpr t, " ELSE ", showExpr e, " END)"]
        QExists t corr -> Text.join "" ["EXISTS (SELECT 1 FROM ", t, " WHERE ", showExpr corr, ")"]

fn binNode (l: QExpr) (op: Text) (r: QExpr) -> Text =
    Text.concat "(" (Text.concat (showExpr l) (Text.concat op (Text.concat (showExpr r) ")")))

fn showInList (items: List QExpr) -> List Text =
    match items
        []          -> []
        x :: rest   -> showExpr x :: showInList rest

fn aggShow (fnName: Text) (c: QExpr) -> Text =
    Text.concat fnName (Text.concat "(" (Text.concat (showExpr c) ")"))

fn showProjCols (cols: List (Text, QExpr)) -> List Text =
    match cols
        []                   -> []
        (alias, col) :: rest -> aliasedCol alias (showExpr col) :: showProjCols rest

-- Compile a quoted predicate to parameterized SQL and its ordered bind values.
-- Each literal becomes a `?` placeholder and its value is collected, left to
-- right, into the bind list — so the pair is safe to hand to a parameterized
-- query adapter without ever interpolating a value into the statement.
pub fn toSql (q: Quote f) -> (Sql, List SqlValue) =
    let r = compileExpr q.tree
    (sql r.text, r.binds)

fn compileExpr (e: QExpr) -> { text: Text, binds: List SqlValue } =
    match e
        QCol c      -> { text = c, binds = [] }
        QColR c     -> { text = c, binds = [] }
        QColAt _ c  -> { text = c, binds = [] }
        QLitInt n   -> { text = "?", binds = [sqlInt n] }
        QLitText s  -> { text = "?", binds = [sqlText s] }
        QLitBool b  -> { text = "?", binds = [sqlBool b] }
        QLitFloat x -> { text = "?", binds = [sqlFloat x] }
        QNot x      -> unaryNode "(NOT " x ")"
        QNotTrue x  -> unaryNode "(" x " IS NOT TRUE)"
        QAnd l r -> binNodeSql l " AND " r
        QOr l r  -> binNodeSql l " OR " r
        QEq l r  -> binNodeSql l " = " r
        QNe l r  -> binNodeSql l " <> " r
        QLt l r  -> binNodeSql l " < " r
        QGt l r  -> binNodeSql l " > " r
        QLe l r  -> binNodeSql l " <= " r
        QGe l r  -> binNodeSql l " >= " r
        QProj cols ->
            let r = projCols cols
            { text = Text.join ", " r.texts, binds = r.binds }
        QGroupKey  -> { text = "", binds = [] }
        QAggCount  -> { text = "COUNT(*)", binds = [] }
        QAggSum c  -> aggSql "SUM" c
        QAggAvg c  -> aggSql "AVG" c
        QAggMin c  -> aggSql "MIN" c
        QAggMax c  -> aggSql "MAX" c
        QLike v p  ->
            let lv = compileExpr v
            let lp = compileExpr p
            { text = Text.join "" ["(", lv.text, " LIKE ", lp.text, ")"], binds = lv.binds ++ lp.binds }
        QIn v items ->
            match items
                [] -> { text = "FALSE", binds = [] }
                _  ->
                    let lv = compileExpr v
                    let inner = compileInList items
                    { text = Text.join "" ["(", lv.text, " IN (", inner.text, "))"], binds = lv.binds ++ inner.binds }
        QAdd l r -> binNodeSql l " + " r
        QSub l r -> binNodeSql l " - " r
        QMul l r -> binNodeSql l " * " r
        QDiv l r -> binNodeSql l " / " r
        QMod l r -> binNodeSql l " % " r
        QCase c t e ->
            let cc = compileExpr c
            let ct = compileExpr t
            let ce = compileExpr e
            { text = Text.join "" ["CASE WHEN ", cc.text, " THEN ", ct.text, " ELSE ", ce.text, " END"], binds = cc.binds ++ ct.binds ++ ce.binds }
        QExists t corr ->
            -- `toSql` compiles a single-table predicate fragment; an `EXISTS` over a
            -- captured table has no outer alias here, so the correlated columns read
            -- bare. The parameterized plan path (`planToSql`) is the one that renders
            -- the correlation with `l`/`r` aliases.
            let cr = compileExpr corr
            { text = Text.join "" ["EXISTS (SELECT 1 FROM ", quoteIdent t, " WHERE ", cr.text, ")"], binds = cr.binds }

fn aggSql (fnName: Text) (c: QExpr) -> { text: Text, binds: List SqlValue } =
    let r = compileExpr c
    { text = Text.concat fnName (Text.concat "(" (Text.concat r.text ")")), binds = r.binds }

fn compileInList (items: List QExpr) -> { text: Text, binds: List SqlValue } =
    match items
        []        -> { text = "", binds = [] }
        x :: []   -> compileExpr x
        x :: rest ->
            let r1 = compileExpr x
            let r2 = compileInList rest
            { text = Text.join "" [r1.text, ", ", r2.text], binds = r1.binds ++ r2.binds }

fn unaryNode (pre: Text) (x: QExpr) (post: Text) -> { text: Text, binds: List SqlValue } =
    let r = compileExpr x
    let t = Text.concat pre (Text.concat r.text post)
    { text = t, binds = r.binds }

fn binNodeSql (l: QExpr) (op: Text) (r: QExpr) -> { text: Text, binds: List SqlValue } =
    let lr = compileExpr l
    let rr = compileExpr r
    let t = Text.concat "(" (Text.concat lr.text (Text.concat op (Text.concat rr.text ")")))
    { text = t, binds = lr.binds ++ rr.binds }

-- Compile a quoted ordering key plus a direction into an `ORDER BY` fragment and
-- its ordered bind values, e.g. `created_at DESC` or `(price * ?) DESC`. A plain
-- column carries no binds; a computed key (arithmetic, a CASE) collects each
-- literal as a `?` placeholder, left to right, never interpolated.
pub fn orderSql (dir: SortOrder) (q: Quote f) -> (Sql, List SqlValue) =
    let r = compileExpr q.tree
    (sql (Text.concat r.text (Text.concat " " (dirKeyword dir))), r.binds)

fn dirKeyword (dir: SortOrder) -> Text =
    match dir
        Asc  -> "ASC"
        Desc -> "DESC"

-- Compile a quoted projection into a SQL select-list and its ordered bind
-- values, e.g. `id, signup_year` or `(price * qty) AS total`. A field whose
-- name differs from its source column is emitted as `column AS alias`; a
-- computed field (arithmetic, a CASE) compiles to its expression with each
-- literal collected as a `?` placeholder, left to right.
pub fn selectSql (q: Quote f) -> (Sql, List SqlValue) =
    let r = compileExpr q.tree
    (sql r.text, r.binds)

fn projCols (cols: List (Text, QExpr)) -> { texts: List Text, binds: List SqlValue } =
    match cols
        []                   -> { texts = [], binds = [] }
        (alias, col) :: rest ->
            let r = compileExpr col
            let more = projCols rest
            { texts = aliasedCol alias r.text :: more.texts, binds = r.binds ++ more.binds }

fn aliasedCol (alias: Text) (colSql: Text) -> Text =
    if alias == colSql then colSql
    else Text.concat colSql (Text.concat " AS " alias)

-- ── Plan → SQL renderer ───────────────────────────────────────────────────────
--
-- Compile a whole query plan to one parameterized SQL statement plus its ordered
-- bind values — the Postgres dual of the in-memory tree-walk. Every literal in a
-- captured predicate becomes a positional `$N` placeholder and its value is
-- collected, left to right, so the statement is safe to hand to a parameterized
-- adapter without ever interpolating a value. Identifiers (tables, columns) are
-- double-quoted, with any embedded quote doubled.
--
-- A join renders its rows flat with each source's columns prefixed
-- (`l."col" AS "t0$col"` / `r."col" AS "t1$col"`), spelled from the `leftCols` and
-- `rightCols` the plan carries, so the two sides never collide and the decoder
-- recovers each entity by its prefix. An outer join also selects a presence marker
-- (`TRUE AS "__present"` off the null-extended side, aliased `t0$__present__` /
-- `t1$__present__`): the unmatched side's real columns all read NULL, so the marker
-- is what tells a matched-but-all-NULL row from an absent one. A projection,
-- aggregate, or group over a join reads those NULLs directly and needs no marker.
pub fn planToSql (plan: QueryPlan) -> (Sql, List SqlValue) =
    let r = renderPlan (optimize plan) 1
    (sql r.text, r.binds)

-- Whether a predicate tree carries a correlated `EXISTS` anywhere under its boolean
-- connectives. A scan whose WHERE does is aliased (`FROM "t" AS l`) so the subquery's
-- correlated columns can name the outer row as `l."col"` and stay apart from the
-- inner table's own columns. An `EXISTS` only ever sits under `AND`/`OR`/`NOT`/`CASE`,
-- never inside a comparison operand, so the walk stops at the leaves.
pub fn containsExists (e: QExpr) -> Bool =
    match e
        QExists _ _ -> true
        QAnd l r    -> containsExists l || containsExists r
        QOr l r     -> containsExists l || containsExists r
        QNot x      -> containsExists x
        QNotTrue x  -> containsExists x
        QCase c t e -> containsExists c || containsExists t || containsExists e
        _           -> false

fn renderPlan (plan: QueryPlan) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    match plan
        PlanScan table pred orders lim off dist ->
            if containsExists pred then
                -- The WHERE carries a correlated `EXISTS`: alias the table `l` so each
                -- subquery can name the outer row as `l."col"`, and qualify the whole
                -- predicate to that single base leaf (its inner tables aliased `x<i>`).
                let w = whereExistsClause true 1 pred n
                let ob = orderByClause orders w.next
                { text = Text.join "" ["SELECT ", distinctKw dist, "* FROM ", quoteIdent table, " AS l", w.text, ob.text, limitClause lim, offsetClause off], binds = w.binds ++ ob.binds, next = ob.next }
            else
                let w = whereClause false pred n
                let ob = orderByClause orders w.next
                { text = Text.join "" ["SELECT ", distinctKw dist, "* FROM ", quoteIdent table, w.text, ob.text, limitClause lim, offsetClause off], binds = w.binds ++ ob.binds, next = ob.next }
        PlanCombine op left right ->
            let l = renderPlan left n
            let r = renderPlan right l.next
            { text = Text.join "" ["(", l.text, ") ", op, " (", r.text, ")"], binds = l.binds ++ r.binds, next = r.next }
        PlanRefine inner pred orders lim off dist ->
            let i = renderPlan inner n
            if containsExists pred then
                -- Alias the sub-select `l` (rather than `ridge_sub`) when the refinement's
                -- WHERE carries an `EXISTS`, so each subquery correlates to the outer row.
                let w = whereExistsClause true 1 pred i.next
                let ob = orderByClause orders w.next
                { text = Text.join "" ["SELECT ", distinctKw dist, "* FROM (", i.text, ") AS l", w.text, ob.text, limitClause lim, offsetClause off], binds = i.binds ++ w.binds ++ ob.binds, next = ob.next }
            else
                let w = whereClause false pred i.next
                let ob = orderByClause orders w.next
                { text = Text.join "" ["SELECT ", distinctKw dist, "* FROM (", i.text, ") AS ridge_sub", w.text, ob.text, limitClause lim, offsetClause off], binds = i.binds ++ w.binds ++ ob.binds, next = ob.next }
        PlanJoin kind left right cond where2 orders lim off dist leftCols rightCols ->
            renderBareJoin kind left right cond where2 orders lim off dist leftCols rightCols n
        PlanProject proj child lim off dist ->
            renderProject proj child lim off dist n
        PlanAggregate func column leaf child ->
            renderAggregate func column leaf child n
        PlanGroup keyCol keyLeaf cols having child ->
            renderGroup keyCol keyLeaf cols having child n
        PlanExists child ->
            renderExists child n
        PlanList _ ->
            -- Mem-only: the in-memory `Seq` source never reaches the SQL renderer,
            -- which only sees plans rooted at a table scan. Present for exhaustiveness.
            { text = "", binds = [], next = n }

-- An existence probe: `SELECT 1 FROM <child's FROM/WHERE> LIMIT 1`, which short-circuits
-- at the first matching row and transfers one trivial column rather than every column of a
-- row the caller never reads. The child is the reduction join an `exists` terminal builds,
-- so the probe reuses its FROM/JOIN/WHERE with no presence markers (existence needs none).
-- A non-join child (a set-operation query) falls back to probing it as a subquery.
fn renderExists (child: QueryPlan) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    match child
        PlanJoin kind left right cond where2 _ _ _ _ _ _ ->
            match left
                PlanScan lt lp _ _ _ _ ->
                    match right
                        PlanScan rt _ _ _ _ _ ->
                            let sk = joinSkeleton kind lt lp rt cond where2 false n
                            { text = Text.join "" ["SELECT 1 FROM ", sk.text, " LIMIT 1"], binds = sk.binds, next = sk.next }
                        _ -> existsNary child n
                _ -> existsNary child n
        _ ->
            let r = renderPlan child n
            { text = Text.join "" ["SELECT 1 FROM (", r.text, ") AS ridge_exists LIMIT 1"], binds = r.binds, next = r.next }

-- The existence probe over a composite (three-or-more table) reduction join: the flattened
-- spine's FROM/WHERE with `SELECT 1 … LIMIT 1`, the all-inner and mixed-shape paths the
-- bare terminal renders but with no select-list and no markers — existence reads neither.
fn existsNary (plan: QueryPlan) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    let f = flattenJoin plan
    match f.leaves
        [] -> emptyRender n
        _  ->
            if allInnerSteps f.steps then
                let from = naryFrom f.leaves f.steps n
                let wh = naryWhere f.leaves f.steps from.next
                { text = Text.join "" ["SELECT 1 FROM ", from.text, wh.text, " LIMIT 1"], binds = from.binds ++ wh.binds, next = wh.next }
            else
                let nulls = nullableLeaves f.steps
                let from = mixedFrom f.leaves f.steps nulls false n
                let wh = mixedWhere f.leaves f.steps nulls from.next
                { text = Text.join "" ["SELECT 1 FROM ", from.text, wh.text, " LIMIT 1"], binds = from.binds ++ wh.binds, next = wh.next }

-- A captured predicate to a parameterized fragment. `qualified` picks how a column
-- reads: bare (`"col"`) for a single-table scan, or qualified to its join side
-- (`l."col"` / `r."col"`) for a join's ON/WHERE. A boolean column stands alone as a
-- predicate; a comparison's literal binds as a `$N` placeholder.
fn renderPred (qualified: Bool) (e: QExpr) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    match e
        QAnd l r -> binPred qualified l " AND " r n
        QOr l r  -> binPred qualified l " OR " r n
        QNot x   ->
            let r = renderPred qualified x n
            { text = Text.join "" ["(NOT ", r.text, ")"], binds = r.binds, next = r.next }
        QNotTrue x ->
            let r = renderPred qualified x n
            { text = Text.join "" ["(", r.text, " IS NOT TRUE)"], binds = r.binds, next = r.next }
        QEq l r -> cmpPred qualified l " = " r n
        QNe l r -> cmpPred qualified l " <> " r n
        QLt l r -> cmpPred qualified l " < " r n
        QGt l r -> cmpPred qualified l " > " r n
        QLe l r -> cmpPred qualified l " <= " r n
        QGe l r -> cmpPred qualified l " >= " r n
        QLike v p ->
            let lv = renderOperand qualified v n
            let lp = renderOperand qualified p lv.next
            { text = Text.join "" [lv.text, " LIKE ", lp.text], binds = lv.binds ++ lp.binds, next = lp.next }
        QIn v items ->
            match items
                [] -> { text = "FALSE", binds = [], next = n }
                _  ->
                    let lv = renderOperand qualified v n
                    let inner = renderInList qualified items lv.next
                    { text = Text.join "" [lv.text, " IN (", inner.text, ")"], binds = lv.binds ++ inner.binds, next = inner.next }
        QCol c  -> { text = renderColRef qualified false c, binds = [], next = n }
        QColR c -> { text = renderColRef qualified true c, binds = [], next = n }
        QLitBool b -> { text = boolLit b, binds = [], next = n }
        QCase c t e ->
            let cc = renderPred qualified c n
            let ct = renderPred qualified t cc.next
            let ce = renderPred qualified e ct.next
            { text = Text.join "" ["CASE WHEN ", cc.text, " THEN ", ct.text, " ELSE ", ce.text, " END"], binds = cc.binds ++ ct.binds ++ ce.binds, next = ce.next }
        -- A correlated `EXISTS` subquery: probe the inner table for a row the
        -- correlated predicate admits. The inner table is aliased `r` and the
        -- predicate renders qualified, so the outer row's columns read `l."col"`
        -- (the outer scan is aliased `l` whenever its WHERE carries an EXISTS) and
        -- the inner row's `r."col"` — the same two sides a join condition names.
        QExists t corr ->
            let inner = renderPred true corr n
            { text = Text.join "" ["EXISTS (SELECT 1 FROM ", quoteIdent t, " AS r WHERE ", inner.text, ")"], binds = inner.binds, next = inner.next }
        _ -> renderOperand qualified e n

fn cmpPred (qualified: Bool) (l: QExpr) (op: Text) (r: QExpr) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    let lr = renderOperand qualified l n
    let rr = renderOperand qualified r lr.next
    { text = Text.join "" [lr.text, op, rr.text], binds = lr.binds ++ rr.binds, next = rr.next }

fn binPred (qualified: Bool) (l: QExpr) (op: Text) (r: QExpr) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    let lr = renderPred qualified l n
    let rr = renderPred qualified r lr.next
    { text = Text.join "" ["(", lr.text, op, rr.text, ")"], binds = lr.binds ++ rr.binds, next = rr.next }

-- A comparison operand: a column reads by name (qualified to its side in a join), a
-- literal binds as a `$N` placeholder pushing its value, anything else is `NULL`.
fn renderOperand (qualified: Bool) (e: QExpr) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    match e
        QCol c      -> { text = renderColRef qualified false c, binds = [], next = n }
        QColR c     -> { text = renderColRef qualified true c, binds = [], next = n }
        QLitInt v   -> { text = placeholder n, binds = [sqlInt v], next = n + 1 }
        QLitText v  -> { text = placeholder n, binds = [sqlText v], next = n + 1 }
        QLitBool v  -> { text = placeholder n, binds = [sqlBool v], next = n + 1 }
        QLitFloat v -> { text = placeholder n, binds = [sqlFloat v], next = n + 1 }
        QAdd l r    -> arithOperand qualified l " + " r n
        QSub l r    -> arithOperand qualified l " - " r n
        QMul l r    -> arithOperand qualified l " * " r n
        QDiv l r    -> arithOperand qualified l " / " r n
        QMod l r    -> arithOperand qualified l " % " r n
        QCase c t e ->
            let cc = renderPred qualified c n
            let ct = renderOperand qualified t cc.next
            let ce = renderOperand qualified e ct.next
            { text = Text.join "" ["CASE WHEN ", cc.text, " THEN ", ct.text, " ELSE ", ce.text, " END"], binds = cc.binds ++ ct.binds ++ ce.binds, next = ce.next }
        _           -> { text = "NULL", binds = [], next = n }

-- An arithmetic operand: `(lhs OP rhs)`, each side rendered as an operand and
-- wrapped in parentheses so the operator precedence is explicit. The placeholder
-- counter threads left to right through both sides, so a literal in either side
-- binds in source order.
fn arithOperand (qualified: Bool) (l: QExpr) (op: Text) (r: QExpr) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    let lr = renderOperand qualified l n
    let rr = renderOperand qualified r lr.next
    { text = Text.join "" ["(", lr.text, op, rr.text, ")"], binds = lr.binds ++ rr.binds, next = rr.next }

-- The comma-separated operands of an `IN (…)` list, each a `$N` placeholder
-- binding its value, threaded left to right so the placeholders stay in order.
fn renderInList (qualified: Bool) (items: List QExpr) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    match items
        []        -> { text = "", binds = [], next = n }
        x :: []   -> renderOperand qualified x n
        x :: rest ->
            let r1 = renderOperand qualified x n
            let r2 = renderInList qualified rest r1.next
            { text = Text.join "" [r1.text, ", ", r2.text], binds = r1.binds ++ r2.binds, next = r2.next }

fn renderColRef (qualified: Bool) (isRight: Bool) (c: Text) -> Text =
    if qualified then
        if isRight then Text.concat "r." (quoteIdent c) else Text.concat "l." (quoteIdent c)
    else quoteIdent c

fn boolLit (b: Bool) -> Text = if b then "TRUE" else "FALSE"

fn placeholder (n: Int) -> Text = Text.concat "$" (Int.toText n)

-- Double-quote an identifier, doubling any embedded quote — the SQL escape for a
-- delimited identifier, matching the backend's own `quote_ident`.
fn quoteIdent (name: Text) -> Text = Text.join "" ["\"", Text.replace "\"" "\"\"" name, "\""]

fn distinctKw (dist: Bool) -> Text = if dist then "DISTINCT " else ""

fn limitClause (lim: Int) -> Text = if lim >= 0 then Text.concat " LIMIT " (Int.toText lim) else ""

fn offsetClause (off: Int) -> Text = if off > 0 then Text.concat " OFFSET " (Int.toText off) else ""

fn dirKw (asc: Bool) -> Text = if asc then "ASC" else "DESC"

-- ORDER BY for a single-table scan: each `(ascending?, key)` rendered with its
-- direction, the key a column or a computed expression over the columns (a literal
-- in it binding as a `$N` placeholder, threaded left to right after the WHERE). An
-- empty list contributes nothing and leaves the counter untouched.
fn orderByClause (orders: List (Bool, QExpr)) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    match orders
        [] -> { text = "", binds = [], next = n }
        _  ->
            let r = orderTerms orders n
            { text = Text.concat " ORDER BY " (Text.join ", " r.texts), binds = r.binds, next = r.next }

fn orderTerms (orders: List (Bool, QExpr)) (n: Int) -> { texts: List Text, binds: List SqlValue, next: Int } =
    match orders
        []                 -> { texts = [], binds = [], next = n }
        (asc, key) :: rest ->
            let k = renderOperand false key n
            let more = orderTerms rest k.next
            { texts = Text.join "" [k.text, " ", dirKw asc] :: more.texts, binds = k.binds ++ more.binds, next = more.next }

-- ORDER BY for a binary join: each `(ascending?, leaf, key)` rendered with its
-- direction, the key's columns qualified to their source side (`l.`/`r.`) and a
-- computed key carrying its placeholders threaded after the join's own binds.
fn orderByClauseJoin (orders: List (Bool, Int, QExpr)) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    match orders
        [] -> { text = "", binds = [], next = n }
        _  ->
            let r = orderTermsJoin orders n
            { text = Text.concat " ORDER BY " (Text.join ", " r.texts), binds = r.binds, next = r.next }

fn orderTermsJoin (orders: List (Bool, Int, QExpr)) (n: Int) -> { texts: List Text, binds: List SqlValue, next: Int } =
    match orders
        []                        -> { texts = [], binds = [], next = n }
        (asc, _leaf, key) :: rest ->
            let k = renderOperand true key n
            let more = orderTermsJoin rest k.next
            { texts = Text.join "" [k.text, " ", dirKw asc] :: more.texts, binds = k.binds ++ more.binds, next = more.next }

-- The FROM/JOIN/ON/WHERE core of a join, per kind, with the left filter `lp` placed
-- where the kind needs it (the inner/left join's post-join WHERE, the right join's
-- ON, the full join's left subquery) and the `$N` counter threaded in the order the
-- backend binds: cond, where2, pred for inner/left; cond, pred, where2 for right;
-- pred, cond, where2 for full. `marker` wraps the null-extended side in a
-- `TRUE AS "__present"` subquery so a bare join can tell an absent outer side from a
-- matched one; a projection/aggregate/group reads the NULLs directly and passes false.
fn joinSkeleton (kind: Text) (lt: Text) (lp: QExpr) (rt: Text) (cond: QExpr) (where2: QExpr) (marker: Bool) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    if kind == "RIGHT" then
        let c = renderPred true cond n
        let pOn = andClause true lp c.next
        let w = joinWhereTerms [(2, where2)] pOn.next
        let lexpr = if marker then markerSub lt else quoteIdent lt
        { text = Text.join "" [lexpr, " AS l RIGHT JOIN ", quoteIdent rt, " AS r ON (", c.text, ")", pOn.text, w.text], binds = c.binds ++ pOn.binds ++ w.binds, next = w.next }
    else if kind == "FULL" then
        let ls = fullLeftSource lt lp marker n
        let c = renderPred true cond ls.next
        let w = joinWhereTerms [(2, where2)] c.next
        let rexpr = if marker then markerSub rt else quoteIdent rt
        { text = Text.join "" [ls.text, " AS l FULL JOIN ", rexpr, " AS r ON (", c.text, ")", w.text], binds = ls.binds ++ c.binds ++ w.binds, next = w.next }
    else if kind == "LEFT" then
        let c = renderPred true cond n
        let rexpr = if marker then markerSub rt else quoteIdent rt
        let w = joinWhereTerms [(1, lp), (2, where2)] c.next
        { text = Text.join "" [quoteIdent lt, " AS l LEFT JOIN ", rexpr, " AS r ON ", c.text, w.text], binds = c.binds ++ w.binds, next = w.next }
    else
        let c = renderPred true cond n
        let w = joinWhereTerms [(1, lp), (2, where2)] c.next
        { text = Text.join "" [quoteIdent lt, " AS l JOIN ", quoteIdent rt, " AS r ON ", c.text, w.text], binds = c.binds ++ w.binds, next = w.next }

fn markerSub (table: Text) -> Text = Text.join "" ["(SELECT *, TRUE AS \"__present\" FROM ", quoteIdent table, ")"]

-- The left operand of a binary FULL join: its scan filter pushed into a subquery (bare
-- columns, evaluated before the join), wrapping the presence marker too when a bare
-- terminal needs it. An always-true filter drops the subquery's WHERE — the optimizer
-- folds an unrefined left side to bare TRUE, so a FULL join with no left filter reads
-- the table cleanly.
fn fullLeftSource (table: Text) (pred: QExpr) (marker: Bool) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    if isAlwaysTrue pred then
        if marker then { text = Text.join "" ["(SELECT *, TRUE AS \"__present\" FROM ", quoteIdent table, ")"], binds = [], next = n }
        else { text = Text.join "" ["(SELECT * FROM ", quoteIdent table, ")"], binds = [], next = n }
    else
        let w = renderPred false pred n
        if marker then { text = Text.join "" ["(SELECT *, TRUE AS \"__present\" FROM ", quoteIdent table, " WHERE (", w.text, "))"], binds = w.binds, next = w.next }
        else { text = Text.join "" ["(SELECT * FROM ", quoteIdent table, " WHERE (", w.text, "))"], binds = w.binds, next = w.next }

-- A trailing `WHERE` clause from a single predicate, or nothing when the predicate is
-- the always-true default a builder step leaves behind. The `$N` counter only advances
-- when a real clause renders.
fn whereClause (qualified: Bool) (pred: QExpr) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    if isAlwaysTrue pred then { text = "", binds = [], next = n }
    else
        let w = renderPred qualified pred n
        { text = Text.concat " WHERE " w.text, binds = w.binds, next = w.next }

-- ── Correlated EXISTS rendering ───────────────────────────────────────────────
--
-- A WHERE that carries a correlated `EXISTS` qualifies every column to a leaf so the
-- subquery can name the outer row, and gives each inner table its own alias. One
-- renderer covers a single-table filter, a binary join's WHERE, an N-ary spine's
-- WHERE, and any depth of nesting: a column's leaf index (the position the reifier
-- tagged it with — `QCol` leaf 0, `QColR` leaf 1, `QColAt i` leaf i) decides its
-- alias, and each `EXISTS` introduces its inner table at the leaf one past the base.

-- The alias a leaf reads inside an EXISTS-bearing WHERE. A base outer leaf keeps its
-- join alias — `l`/`r` for a binary join or single scan, `t<i>` for an N-ary spine;
-- a leaf at or past `nBase` is an EXISTS inner table, aliased `x<leaf>` in a namespace
-- that never collides with the outer aliases.
fn qualLeafRef (binaryOuter: Bool) (nBase: Int) (leaf: Int) (c: Text) -> Text =
    if leaf >= nBase then Text.join "" [xAlias leaf, ".", quoteIdent c]
    else if binaryOuter then
        if leaf == 0 then Text.concat "l." (quoteIdent c) else Text.concat "r." (quoteIdent c)
    else naryColRef leaf c

fn xAlias (i: Int) -> Text = Text.concat "x" (Int.toText i)

-- Render a captured predicate that may carry a correlated `EXISTS`, over a fixed base
-- of `nBase` outer leaves. `binaryOuter` and `nBase` decide how a column qualifies
-- (see qualLeafRef); `depth` counts the EXISTS subqueries currently open, so the next
-- inner table takes leaf `nBase + depth`. For an EXISTS-free predicate the output
-- matches the plain renderPred (`binaryOuter`, nBase ≤ 2) or renderQual (N-ary spine)
-- byte for byte. An `EXISTS` aliases its inner table `x<leaf>`, renders the correlated
-- predicate one leaf deeper, and emits a `SELECT 1` probe.
fn renderExistsPred (binaryOuter: Bool) (nBase: Int) (depth: Int) (e: QExpr) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    match e
        QAnd l r -> existsBin binaryOuter nBase depth l " AND " r n
        QOr l r  -> existsBin binaryOuter nBase depth l " OR " r n
        QNot x   ->
            let r = renderExistsPred binaryOuter nBase depth x n
            { text = Text.join "" ["(NOT ", r.text, ")"], binds = r.binds, next = r.next }
        QNotTrue x ->
            let r = renderExistsPred binaryOuter nBase depth x n
            { text = Text.join "" ["(", r.text, " IS NOT TRUE)"], binds = r.binds, next = r.next }
        QEq l r -> existsCmp binaryOuter nBase depth l " = " r n
        QNe l r -> existsCmp binaryOuter nBase depth l " <> " r n
        QLt l r -> existsCmp binaryOuter nBase depth l " < " r n
        QGt l r -> existsCmp binaryOuter nBase depth l " > " r n
        QLe l r -> existsCmp binaryOuter nBase depth l " <= " r n
        QGe l r -> existsCmp binaryOuter nBase depth l " >= " r n
        QLike v p ->
            let lv = renderExistsOperand binaryOuter nBase depth v n
            let lp = renderExistsOperand binaryOuter nBase depth p lv.next
            { text = Text.join "" [lv.text, " LIKE ", lp.text], binds = lv.binds ++ lp.binds, next = lp.next }
        QIn v items ->
            match items
                [] -> { text = "FALSE", binds = [], next = n }
                _  ->
                    let lv = renderExistsOperand binaryOuter nBase depth v n
                    let inner = existsInList binaryOuter nBase depth items lv.next
                    { text = Text.join "" [lv.text, " IN (", inner.text, ")"], binds = lv.binds ++ inner.binds, next = inner.next }
        QCol c     -> { text = qualLeafRef binaryOuter nBase 0 c, binds = [], next = n }
        QColR c    -> { text = qualLeafRef binaryOuter nBase 1 c, binds = [], next = n }
        QColAt i c -> { text = qualLeafRef binaryOuter nBase i c, binds = [], next = n }
        QLitBool b -> { text = boolLit b, binds = [], next = n }
        QCase c t e ->
            let cc = renderExistsPred binaryOuter nBase depth c n
            let ct = renderExistsPred binaryOuter nBase depth t cc.next
            let ce = renderExistsPred binaryOuter nBase depth e ct.next
            { text = Text.join "" ["CASE WHEN ", cc.text, " THEN ", ct.text, " ELSE ", ce.text, " END"], binds = cc.binds ++ ct.binds ++ ce.binds, next = ce.next }
        QExists t corr ->
            let innerLeaf = nBase + depth
            let inner = renderExistsPred binaryOuter nBase (depth + 1) corr n
            { text = Text.join "" ["EXISTS (SELECT 1 FROM ", quoteIdent t, " AS ", xAlias innerLeaf, " WHERE ", inner.text, ")"], binds = inner.binds, next = inner.next }
        _ -> renderExistsOperand binaryOuter nBase depth e n

fn existsCmp (binaryOuter: Bool) (nBase: Int) (depth: Int) (l: QExpr) (op: Text) (r: QExpr) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    let lr = renderExistsOperand binaryOuter nBase depth l n
    let rr = renderExistsOperand binaryOuter nBase depth r lr.next
    { text = Text.join "" [lr.text, op, rr.text], binds = lr.binds ++ rr.binds, next = rr.next }

fn existsBin (binaryOuter: Bool) (nBase: Int) (depth: Int) (l: QExpr) (op: Text) (r: QExpr) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    let lr = renderExistsPred binaryOuter nBase depth l n
    let rr = renderExistsPred binaryOuter nBase depth r lr.next
    { text = Text.join "" ["(", lr.text, op, rr.text, ")"], binds = lr.binds ++ rr.binds, next = rr.next }

fn renderExistsOperand (binaryOuter: Bool) (nBase: Int) (depth: Int) (e: QExpr) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    match e
        QCol c      -> { text = qualLeafRef binaryOuter nBase 0 c, binds = [], next = n }
        QColR c     -> { text = qualLeafRef binaryOuter nBase 1 c, binds = [], next = n }
        QColAt i c  -> { text = qualLeafRef binaryOuter nBase i c, binds = [], next = n }
        QLitInt v   -> { text = placeholder n, binds = [sqlInt v], next = n + 1 }
        QLitText v  -> { text = placeholder n, binds = [sqlText v], next = n + 1 }
        QLitBool v  -> { text = placeholder n, binds = [sqlBool v], next = n + 1 }
        QLitFloat v -> { text = placeholder n, binds = [sqlFloat v], next = n + 1 }
        QAdd l r    -> existsArith binaryOuter nBase depth l " + " r n
        QSub l r    -> existsArith binaryOuter nBase depth l " - " r n
        QMul l r    -> existsArith binaryOuter nBase depth l " * " r n
        QDiv l r    -> existsArith binaryOuter nBase depth l " / " r n
        QMod l r    -> existsArith binaryOuter nBase depth l " % " r n
        QCase c t e ->
            let cc = renderExistsPred binaryOuter nBase depth c n
            let ct = renderExistsOperand binaryOuter nBase depth t cc.next
            let ce = renderExistsOperand binaryOuter nBase depth e ct.next
            { text = Text.join "" ["CASE WHEN ", cc.text, " THEN ", ct.text, " ELSE ", ce.text, " END"], binds = cc.binds ++ ct.binds ++ ce.binds, next = ce.next }
        _           -> { text = "NULL", binds = [], next = n }

fn existsArith (binaryOuter: Bool) (nBase: Int) (depth: Int) (l: QExpr) (op: Text) (r: QExpr) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    let lr = renderExistsOperand binaryOuter nBase depth l n
    let rr = renderExistsOperand binaryOuter nBase depth r lr.next
    { text = Text.join "" ["(", lr.text, op, rr.text, ")"], binds = lr.binds ++ rr.binds, next = rr.next }

fn existsInList (binaryOuter: Bool) (nBase: Int) (depth: Int) (items: List QExpr) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    match items
        []        -> { text = "", binds = [], next = n }
        x :: []   -> renderExistsOperand binaryOuter nBase depth x n
        x :: rest ->
            let r1 = renderExistsOperand binaryOuter nBase depth x n
            let r2 = existsInList binaryOuter nBase depth rest r1.next
            { text = Text.join "" [r1.text, ", ", r2.text], binds = r1.binds ++ r2.binds, next = r2.next }

-- A WHERE clause for a predicate carrying a correlated EXISTS, qualified over `nBase`
-- base outer leaves. Empty when the predicate is the always-true default a builder
-- step leaves behind.
fn whereExistsClause (binaryOuter: Bool) (nBase: Int) (pred: QExpr) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    if isAlwaysTrue pred then { text = "", binds = [], next = n }
    else
        let w = renderExistsPred binaryOuter nBase 0 pred n
        { text = Text.concat " WHERE " w.text, binds = w.binds, next = w.next }

-- A binary join's post-join WHERE built from `(nBase, predicate)` conjuncts: the left
-- scan's pre-join filter is a single-table leaf (nBase 1, its EXISTS correlates to
-- leaf 0), the post-join filter ranges over both join leaves (nBase 2). Each conjunct
-- renders EXISTS-aware at its own base arity, an always-true default contributing
-- nothing — so a join with no real filters carries no WHERE.
fn joinWhereTerms (terms: List (Int, QExpr)) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    let r = existsConjList terms n
    match r.texts
        []    -> { text = "", binds = r.binds, next = r.next }
        terms -> { text = Text.concat " WHERE " (Text.join " AND " terms), binds = r.binds, next = r.next }

fn existsConjList (terms: List (Int, QExpr)) (n: Int) -> { texts: List Text, binds: List SqlValue, next: Int } =
    match terms
        [] -> { texts = [], binds = [], next = n }
        (nBase, pred) :: rest ->
            if isAlwaysTrue pred then existsConjList rest n
            else
                let r = renderExistsPred true nBase 0 pred n
                let more = existsConjList rest r.next
                { texts = Text.join "" ["(", r.text, ")"] :: more.texts, binds = r.binds ++ more.binds, next = more.next }

-- An ` AND (<pred>)` segment appended to a join's `ON`, or nothing when the predicate is
-- the always-true default — a RIGHT join folds its left filter into the `ON`, and an
-- unrefined left side adds nothing.
fn andClause (qualified: Bool) (pred: QExpr) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    if isAlwaysTrue pred then { text = "", binds = [], next = n }
    else
        let r = renderPred qualified pred n
        { text = Text.join "" [" AND (", r.text, ")"], binds = r.binds, next = r.next }

-- A bare join terminal (`toList`/`first` over a join): the join's flat rows with each
-- source's columns prefixed, plus a presence marker on each outer side, decoded back
-- into entity pairs. The sub-plans are the two single-table scans the join pairs.
fn renderBareJoin (kind: Text) (left: QueryPlan) (right: QueryPlan) (cond: QExpr) (where2: QExpr) (orders: List (Bool, Int, QExpr)) (lim: Int) (off: Int) (dist: Bool) (leftCols: List Text) (rightCols: List Text) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    match left
        PlanScan lt lp _ _ _ _ ->
            match right
                PlanScan rt _ _ _ _ _ ->
                    let sk = joinSkeleton kind lt lp rt cond where2 true n
                    let sel = prefixedSelect leftCols rightCols (leftCanBeAbsent kind) (rightCanBeAbsent kind)
                    let ob = orderByClauseJoin orders sk.next
                    { text = Text.join "" ["SELECT ", distinctKw dist, sel, " FROM ", sk.text, ob.text, limitClause lim, offsetClause off], binds = sk.binds ++ ob.binds, next = ob.next }
                _ -> emptyRender n
        _ ->
            -- A nested left child is a join of three or more tables. An all-inner spine
            -- flattens into one flat multi-way INNER join; a spine with any outer step
            -- renders each step by its own kind, with a presence marker on every leaf a
            -- left, right, or full step can null-extend (the whole composite as a unit
            -- for a right or full step).
            let plan = PlanJoin kind left right cond where2 orders lim off dist leftCols rightCols
            if allInnerSteps (flattenJoin plan).steps then
                renderNaryInner plan orders lim off dist n
            else
                renderNaryMixed plan orders lim off dist n

fn emptyRender (n: Int) -> { text: Text, binds: List SqlValue, next: Int } = { text = "", binds = [], next = n }

fn leftCanBeAbsent (kind: Text) -> Bool = if kind == "RIGHT" then true else kind == "FULL"

fn rightCanBeAbsent (kind: Text) -> Bool = if kind == "LEFT" then true else kind == "FULL"

-- The prefixed select-list a bare join decodes from: each left column as
-- `l."col" AS "t0$col"` and each right as `r."col" AS "t1$col"`, plus a presence
-- marker column on whichever side can be null-extended.
fn prefixedSelect (leftCols: List Text) (rightCols: List Text) (leftMarker: Bool) (rightMarker: Bool) -> Text =
    Text.join ", " ((prefixCols "l." "t0$" leftCols) ++ (markerCol "l." "t0$" leftMarker) ++ (prefixCols "r." "t1$" rightCols) ++ (markerCol "r." "t1$" rightMarker))

fn prefixCols (alias: Text) (prefix: Text) (cols: List Text) -> List Text =
    match cols
        []        -> []
        c :: rest -> prefixOne alias prefix c :: prefixCols alias prefix rest

fn prefixOne (alias: Text) (prefix: Text) (c: Text) -> Text =
    Text.join "" [alias, quoteIdent c, " AS ", quoteIdent (Text.concat prefix c)]

fn markerCol (alias: Text) (prefix: Text) (present: Bool) -> List Text =
    if present then [markerTerm alias prefix] else []

fn markerTerm (alias: Text) (prefix: Text) -> Text =
    Text.join "" [alias, "\"__present\" AS ", quoteIdent (Text.concat prefix "__present__")]

-- ── N-ary (3+ table) inner join rendering ─────────────────────────────────────
--
-- A join of three or more tables arrives as a left-nested `PlanJoin` whose left
-- child is itself a `PlanJoin`. It renders to one flat multi-way join over leaf
-- aliases `t0`..`tN` — `FROM t0 JOIN t1 ON … JOIN t2 ON …` — with every leaf's
-- columns selected prefixed (`t<i>."col" AS "t<i>$col"`), the same flat row shape a
-- binary join produces, so the decoder recovers each entity by its prefix. A column
-- in a join condition names its source by leaf index: `QCol` is leaf 0, `QColR` leaf
-- 1, `QColAt i` leaf i. A leaf's own scan filter names only that leaf, so its bare
-- columns qualify to that leaf's alias.

-- The alias of leaf `i` in the flattened join — `t0`, `t1`, ….
fn tAlias (i: Int) -> Text = Text.concat "t" (Int.toText i)

-- A column reference qualified to its leaf alias (`t<i>."col"`).
fn naryColRef (leaf: Int) (c: Text) -> Text = Text.concat (Text.concat (tAlias leaf) ".") (quoteIdent c)

-- Render a captured predicate with each column qualified to its leaf alias. `q0` is
-- the leaf a bare `QCol` names — 0 in a join condition (the left source), or the
-- leaf's own index in a single-table scan filter, whose columns are all that leaf's.
fn renderQual (q0: Int) (e: QExpr) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    match e
        QAnd l r -> qualBin q0 l " AND " r n
        QOr l r  -> qualBin q0 l " OR " r n
        QNot x   ->
            let r = renderQual q0 x n
            { text = Text.join "" ["(NOT ", r.text, ")"], binds = r.binds, next = r.next }
        QNotTrue x ->
            let r = renderQual q0 x n
            { text = Text.join "" ["(", r.text, " IS NOT TRUE)"], binds = r.binds, next = r.next }
        QEq l r -> qualCmp q0 l " = " r n
        QNe l r -> qualCmp q0 l " <> " r n
        QLt l r -> qualCmp q0 l " < " r n
        QGt l r -> qualCmp q0 l " > " r n
        QLe l r -> qualCmp q0 l " <= " r n
        QGe l r -> qualCmp q0 l " >= " r n
        QLike v p ->
            let lv = qualOperand q0 v n
            let lp = qualOperand q0 p lv.next
            { text = Text.join "" [lv.text, " LIKE ", lp.text], binds = lv.binds ++ lp.binds, next = lp.next }
        QIn v items ->
            match items
                [] -> { text = "FALSE", binds = [], next = n }
                _  ->
                    let lv = qualOperand q0 v n
                    let inner = qualInList q0 items lv.next
                    { text = Text.join "" [lv.text, " IN (", inner.text, ")"], binds = lv.binds ++ inner.binds, next = inner.next }
        QCol c     -> { text = naryColRef q0 c, binds = [], next = n }
        QColR c    -> { text = naryColRef 1 c, binds = [], next = n }
        QColAt i c -> { text = naryColRef i c, binds = [], next = n }
        QLitBool b -> { text = boolLit b, binds = [], next = n }
        QCase c t e ->
            let cc = renderQual q0 c n
            let ct = renderQual q0 t cc.next
            let ce = renderQual q0 e ct.next
            { text = Text.join "" ["CASE WHEN ", cc.text, " THEN ", ct.text, " ELSE ", ce.text, " END"], binds = cc.binds ++ ct.binds ++ ce.binds, next = ce.next }
        _ -> qualOperand q0 e n

fn qualCmp (q0: Int) (l: QExpr) (op: Text) (r: QExpr) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    let lr = qualOperand q0 l n
    let rr = qualOperand q0 r lr.next
    { text = Text.join "" [lr.text, op, rr.text], binds = lr.binds ++ rr.binds, next = rr.next }

fn qualBin (q0: Int) (l: QExpr) (op: Text) (r: QExpr) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    let lr = renderQual q0 l n
    let rr = renderQual q0 r lr.next
    { text = Text.join "" ["(", lr.text, op, rr.text, ")"], binds = lr.binds ++ rr.binds, next = rr.next }

fn qualOperand (q0: Int) (e: QExpr) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    match e
        QCol c      -> { text = naryColRef q0 c, binds = [], next = n }
        QColR c     -> { text = naryColRef 1 c, binds = [], next = n }
        QColAt i c  -> { text = naryColRef i c, binds = [], next = n }
        QLitInt v   -> { text = placeholder n, binds = [sqlInt v], next = n + 1 }
        QLitText v  -> { text = placeholder n, binds = [sqlText v], next = n + 1 }
        QLitBool v  -> { text = placeholder n, binds = [sqlBool v], next = n + 1 }
        QLitFloat v -> { text = placeholder n, binds = [sqlFloat v], next = n + 1 }
        QAdd l r    -> arithQual q0 l " + " r n
        QSub l r    -> arithQual q0 l " - " r n
        QMul l r    -> arithQual q0 l " * " r n
        QDiv l r    -> arithQual q0 l " / " r n
        QMod l r    -> arithQual q0 l " % " r n
        QCase c t e ->
            let cc = renderQual q0 c n
            let ct = qualOperand q0 t cc.next
            let ce = qualOperand q0 e ct.next
            { text = Text.join "" ["CASE WHEN ", cc.text, " THEN ", ct.text, " ELSE ", ce.text, " END"], binds = cc.binds ++ ct.binds ++ ce.binds, next = ce.next }
        _           -> { text = "NULL", binds = [], next = n }

-- The leaf-qualified dual of `arithOperand`: `(lhs OP rhs)` with each side a
-- leaf-qualified operand, threaded left to right.
fn arithQual (q0: Int) (l: QExpr) (op: Text) (r: QExpr) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    let lr = qualOperand q0 l n
    let rr = qualOperand q0 r lr.next
    { text = Text.join "" ["(", lr.text, op, rr.text, ")"], binds = lr.binds ++ rr.binds, next = rr.next }

-- The leaf-qualified dual of `renderInList`: an `IN (…)` list inside a composite
-- join's WHERE, each element a `$N` placeholder threaded left to right.
fn qualInList (q0: Int) (items: List QExpr) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    match items
        []        -> { text = "", binds = [], next = n }
        x :: []   -> qualOperand q0 x n
        x :: rest ->
            let r1 = qualOperand q0 x n
            let r2 = qualInList q0 rest r1.next
            { text = Text.join "" [r1.text, ", ", r2.text], binds = r1.binds ++ r2.binds, next = r2.next }

-- The flattened join spine: each leaf's (table, scan filter, columns) left to right,
-- and the (kind, condition, post-join WHERE) that joins each leaf after the first.
-- Walking the left spine, the innermost `PlanJoin`'s two scans are leaves 0 and 1, and
-- each enclosing `PlanJoin` adds its right scan as the next leaf, carrying that node's
-- join kind so a mixed-shape spine can render each step by its own kind.
fn flattenJoin (plan: QueryPlan) -> { leaves: List (Text, QExpr, List Text), steps: List (Text, QExpr, QExpr) } =
    match plan
        PlanJoin kind left right cond where2 _ _ _ _ leftCols rightCols ->
            match right
                PlanScan rt rp _ _ _ _ ->
                    match left
                        PlanScan lt lp _ _ _ _ ->
                            { leaves = [(lt, lp, leftCols), (rt, rp, rightCols)], steps = [(kind, cond, where2)] }
                        _ ->
                            let inner = flattenJoin left
                            { leaves = inner.leaves ++ [(rt, rp, rightCols)], steps = inner.steps ++ [(kind, cond, where2)] }
                _ -> { leaves = [], steps = [] }
        _ -> { leaves = [], steps = [] }

-- The prefixed select-list over every leaf: leaf `i`'s columns as `t<i>."col" AS
-- "t<i>$col"`, so the flat row carries each source's columns under its own prefix.
fn narySelect (leaves: List (Text, QExpr, List Text)) -> Text =
    Text.join ", " (narySelectCols leaves 0)

fn narySelectCols (leaves: List (Text, QExpr, List Text)) (idx: Int) -> List Text =
    match leaves
        [] -> []
        (_, _, cols) :: rest ->
            (prefixCols (Text.concat (tAlias idx) ".") (Text.concat (tAlias idx) "$") cols) ++ narySelectCols rest (idx + 1)

-- The `FROM t0 AS … JOIN t1 AS … ON … JOIN t2 …` text. The first leaf is the base
-- table; each later leaf is joined on its step condition, the bind counter threaded
-- so the `$N` placeholders stay sequential.
fn naryFrom (leaves: List (Text, QExpr, List Text)) (steps: List (Text, QExpr, QExpr)) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    match leaves
        [] -> { text = "", binds = [], next = n }
        (t0, _, _) :: rest ->
            naryFromRest rest steps 1 (Text.join "" [quoteIdent t0, " AS ", tAlias 0]) [] n

fn naryFromRest (leaves: List (Text, QExpr, List Text)) (steps: List (Text, QExpr, QExpr)) (idx: Int) (acc: Text) (binds: List SqlValue) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    match leaves
        [] -> { text = acc, binds = binds, next = n }
        (tk, _, _) :: restLeaves ->
            match steps
                [] -> { text = acc, binds = binds, next = n }
                (_, cond, _) :: restSteps ->
                    let c = renderQual 0 cond n
                    naryFromRest restLeaves restSteps (idx + 1) (Text.join "" [acc, " JOIN ", quoteIdent tk, " AS ", tAlias idx, " ON ", c.text]) (binds ++ c.binds) c.next

-- The WHERE conjuncts: each leaf's own scan filter (qualified to its leaf) and each
-- step's post-join filter, dropping the always-true defaults so the clause stays
-- clean — an empty result omits the WHERE entirely.
fn naryWhere (leaves: List (Text, QExpr, List Text)) (steps: List (Text, QExpr, QExpr)) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    let lp = leafConds leaves 0 n
    let sp = stepConds steps 1 lp.next
    let conds = lp.texts ++ sp.texts
    match conds
        [] -> { text = "", binds = lp.binds ++ sp.binds, next = sp.next }
        _  -> { text = Text.concat " WHERE " (Text.join " AND " conds), binds = lp.binds ++ sp.binds, next = sp.next }

-- A leaf's own scan filter, qualified to its leaf alias. Only the base leaf (idx 0,
-- the spine's left-most table) can carry a pre-join filter — a later leaf is a bare
-- `joinOn` repo — and that base filter, reified single-table, names its entity at leaf
-- 0 and any correlated EXISTS inner table at the leaf after, so an EXISTS-bearing base
-- filter renders over one base leaf (its inner tables aliased `x<i>`).
fn leafConds (leaves: List (Text, QExpr, List Text)) (idx: Int) (n: Int) -> { texts: List Text, binds: List SqlValue, next: Int } =
    match leaves
        [] -> { texts = [], binds = [], next = n }
        (_, pred, _) :: rest ->
            if isAlwaysTrue pred then
                leafConds rest (idx + 1) n
            else
                let r = if containsExists pred then renderExistsPred false 1 0 pred n else renderQual idx pred n
                let more = leafConds rest (idx + 1) r.next
                { texts = Text.join "" ["(", r.text, ")"] :: more.texts, binds = r.binds ++ more.binds, next = more.next }

-- Each step's post-join filter, qualified over the leaves joined so far. The step that
-- adds leaf `idx` ranges over leaves 0..idx, so a correlated EXISTS in its filter
-- correlates against those `idx + 1` base leaves and joins its inner table at the leaf
-- after. An always-true default contributes nothing.
fn stepConds (steps: List (Text, QExpr, QExpr)) (idx: Int) (n: Int) -> { texts: List Text, binds: List SqlValue, next: Int } =
    match steps
        [] -> { texts = [], binds = [], next = n }
        (_, _, where2) :: rest ->
            if isAlwaysTrue where2 then
                stepConds rest (idx + 1) n
            else
                let r = renderExistsPred false (idx + 1) 0 where2 n
                let more = stepConds rest (idx + 1) r.next
                { texts = Text.join "" ["(", r.text, ")"] :: more.texts, binds = r.binds ++ more.binds, next = more.next }

fn isAlwaysTrue (e: QExpr) -> Bool =
    match e
        QLitBool b -> b
        _          -> false

-- ORDER BY for an N-ary join: each leaf-tagged key qualified to its leaf alias on the
-- flattened spine. The keys carried in from the binary base range over leaves 0 and 1;
-- a key added on the composite names whichever deeper leaf it reads.
fn naryOrderBy (orders: List (Bool, Int, QExpr)) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    match orders
        [] -> { text = "", binds = [], next = n }
        _  ->
            let r = naryOrderTerms orders n
            { text = Text.concat " ORDER BY " (Text.join ", " r.texts), binds = r.binds, next = r.next }

fn naryOrderTerms (orders: List (Bool, Int, QExpr)) (n: Int) -> { texts: List Text, binds: List SqlValue, next: Int } =
    match orders
        []                       -> { texts = [], binds = [], next = n }
        (asc, leaf, key) :: rest ->
            let k = qualOperand leaf key n
            let more = naryOrderTerms rest k.next
            { texts = Text.join "" [k.text, " ", dirKw asc] :: more.texts, binds = k.binds ++ more.binds, next = more.next }

-- A bare N-ary inner join terminal (`toList`/`first`): the flattened multi-way join's
-- flat prefixed rows, which the decoder reads back into the nested entity tuple.
fn renderNaryInner (plan: QueryPlan) (orders: List (Bool, Int, QExpr)) (lim: Int) (off: Int) (dist: Bool) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    let f = flattenJoin plan
    match f.leaves
        [] -> emptyRender n
        _  ->
            let from = naryFrom f.leaves f.steps n
            let wh = naryWhere f.leaves f.steps from.next
            let ob = naryOrderBy orders wh.next
            { text = Text.join "" ["SELECT ", distinctKw dist, narySelect f.leaves, " FROM ", from.text, wh.text, ob.text, limitClause lim, offsetClause off], binds = from.binds ++ wh.binds ++ ob.binds, next = ob.next }

-- ── Mixed-shape (3+ table) join rendering ─────────────────────────────────────
--
-- A join chain that mixes inner with left, right, or full steps renders each step by
-- its own kind: `FROM t0 JOIN t1 ON … LEFT JOIN t2 ON … RIGHT JOIN t3 ON …`. SQL's
-- left-associative nesting gives the locked "composite as a unit" semantics for free —
-- a right or full step's left operand is the whole accumulated `(… JOIN …)`, so an
-- unmatched new row null-extends every composite leaf together. Each leaf a step can
-- null-extend carries a presence marker (`TRUE AS "__present"`, selected as
-- `t<i>$__present__`): the backend returns a null-extended leaf's real columns as NULL
-- rather than omitting them, so the decoder reads the marker — present when the leaf
-- matched, absent (NULL) when it did not — to tell an absent entity from a present one
-- whose own columns are NULL. A null-extendable leaf's scan filter rides inside its
-- subquery so it restricts which rows enter the join before the step null-extends them
-- (correct under a right or full step that a top-level WHERE would otherwise break by
-- rejecting a null-extended row); a leaf no step null-extends needs no such guard, so its
-- filter lifts to the flat top-level WHERE and the leaf reads its table directly.

-- Whether every join step is inner — an all-inner spine takes the marker-free
-- `renderNaryInner` path; any outer step falls to `renderNaryMixed`.
fn allInnerSteps (steps: List (Text, QExpr, QExpr)) -> Bool =
    match steps
        []                -> true
        (kind, _, _) :: rest -> if kind == "INNER" then allInnerSteps rest else false

-- The leaf indices a left, right, or full step can null-extend, so the renderer marks
-- them and the decoder reads them as optional. A left or full step makes its new leaf
-- optional; a right or full step makes every prior composite leaf optional as a unit.
fn nullableLeaves (steps: List (Text, QExpr, QExpr)) -> List Int =
    nullableFold steps 1 []

fn nullableFold (steps: List (Text, QExpr, QExpr)) (idx: Int) (acc: List Int) -> List Int =
    match steps
        []                   -> acc
        (kind, _, _) :: rest ->
            let acc2 =
                if kind == "LEFT" then addLeaf idx acc
                else if kind == "RIGHT" then addRange 0 idx acc
                else if kind == "FULL" then addLeaf idx (addRange 0 idx acc)
                else acc
            nullableFold rest (idx + 1) acc2

fn addLeaf (i: Int) (acc: List Int) -> List Int =
    if leafMember i acc then acc else i :: acc

fn addRange (lo: Int) (hi: Int) (acc: List Int) -> List Int =
    if lo >= hi then acc else addRange (lo + 1) hi (addLeaf lo acc)

fn leafMember (i: Int) (xs: List Int) -> Bool =
    match xs
        []        -> false
        x :: rest -> if x == i then true else leafMember i rest

-- The SQL join keyword for a step's kind.
fn joinKeyword (kind: Text) -> Text =
    if kind == "LEFT" then "LEFT JOIN"
    else if kind == "RIGHT" then "RIGHT JOIN"
    else if kind == "FULL" then "FULL JOIN"
    else "JOIN"

-- A mixed-shape join terminal: the flattened spine rendered with per-kind joins and a
-- presence marker on every null-extendable leaf, so the decoder reads each entity (and
-- each composite) as present or absent.
fn renderNaryMixed (plan: QueryPlan) (orders: List (Bool, Int, QExpr)) (lim: Int) (off: Int) (dist: Bool) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    let f = flattenJoin plan
    match f.leaves
        [] -> emptyRender n
        _  ->
            let nulls = nullableLeaves f.steps
            let from = mixedFrom f.leaves f.steps nulls true n
            let wh = mixedWhere f.leaves f.steps nulls from.next
            let ob = naryOrderBy orders wh.next
            { text = Text.join "" ["SELECT ", distinctKw dist, mixedSelect f.leaves nulls, " FROM ", from.text, wh.text, ob.text, limitClause lim, offsetClause off], binds = from.binds ++ wh.binds ++ ob.binds, next = ob.next }

-- The prefixed select-list over every leaf, plus a `t<i>$__present__` marker for each
-- null-extendable leaf.
fn mixedSelect (leaves: List (Text, QExpr, List Text)) (nulls: List Int) -> Text =
    Text.join ", " (mixedSelectCols leaves nulls 0)

fn mixedSelectCols (leaves: List (Text, QExpr, List Text)) (nulls: List Int) (idx: Int) -> List Text =
    match leaves
        [] -> []
        (_, _, cols) :: rest ->
            let alias = Text.concat (tAlias idx) "."
            let prefix = Text.concat (tAlias idx) "$"
            let base = prefixCols alias prefix cols
            let marked = if leafMember idx nulls then base ++ [markerTerm alias prefix] else base
            marked ++ mixedSelectCols rest nulls (idx + 1)

-- The `FROM <leaf0> AS t0 <KIND> JOIN <leaf1> AS t1 ON … …` text. `nulls` is the genuine
-- set of leaves a later step null-extends; `marks` says whether this render path emits
-- presence markers (a bare terminal does, a projection/aggregate/group reads the NULLs
-- directly and does not). A leaf gets a marker only when both hold; either way its FROM
-- term comes from `leafSource`.
fn mixedFrom (leaves: List (Text, QExpr, List Text)) (steps: List (Text, QExpr, QExpr)) (nulls: List Int) (marks: Bool) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    match leaves
        [] -> { text = "", binds = [], next = n }
        (t0, p0, _) :: rest ->
            let ext0 = leafMember 0 nulls
            let mk0 = if marks then ext0 else false
            let src0 = leafSource 0 t0 p0 mk0 ext0 n
            mixedFromRest rest steps 1 nulls marks src0.text src0.binds src0.next

fn mixedFromRest (leaves: List (Text, QExpr, List Text)) (steps: List (Text, QExpr, QExpr)) (idx: Int) (nulls: List Int) (marks: Bool) (acc: Text) (binds: List SqlValue) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    match leaves
        [] -> { text = acc, binds = binds, next = n }
        (tk, pk, _) :: restLeaves ->
            match steps
                [] -> { text = acc, binds = binds, next = n }
                (kind, cond, _) :: restSteps ->
                    let ext = leafMember idx nulls
                    let mk = if marks then ext else false
                    let src = leafSource idx tk pk mk ext n
                    let c = renderQual 0 cond src.next
                    let seg = Text.join "" [acc, " ", joinKeyword kind, " ", src.text, " ON ", c.text]
                    mixedFromRest restLeaves restSteps (idx + 1) nulls marks seg (binds ++ src.binds ++ c.binds) c.next

-- One leaf's FROM term, given whether the leaf emits a presence marker and whether a later
-- step null-extends it. A marker forces a `(SELECT *, TRUE AS "__present" FROM "table"
-- [WHERE filter]) AS t<i>` subquery so the marker — and any scan filter — rides with the
-- leaf. With no marker, a null-extended leaf still wraps a filtered scan in a plain `(SELECT
-- * FROM "table" WHERE filter) AS t<i>` so the filter applies before the outer step (a
-- top-level WHERE would reject its null-extended rows); every other leaf is the bare
-- `"table" AS t<i>`, its scan filter lifted to the flat top-level WHERE instead.
fn leafSource (idx: Int) (table: Text) (pred: QExpr) (marker: Bool) (nullExtended: Bool) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    let alias = tAlias idx
    if marker then
        if isAlwaysTrue pred then
            { text = Text.join "" ["(SELECT *, TRUE AS \"__present\" FROM ", quoteIdent table, ") AS ", alias], binds = [], next = n }
        else
            let w = renderPred false pred n
            { text = Text.join "" ["(SELECT *, TRUE AS \"__present\" FROM ", quoteIdent table, " WHERE ", w.text, ") AS ", alias], binds = w.binds, next = w.next }
    else if nullExtended then
        if isAlwaysTrue pred then
            { text = Text.join "" [quoteIdent table, " AS ", alias], binds = [], next = n }
        else
            let w = renderPred false pred n
            { text = Text.join "" ["(SELECT * FROM ", quoteIdent table, " WHERE ", w.text, ") AS ", alias], binds = w.binds, next = w.next }
    else
        { text = Text.join "" [quoteIdent table, " AS ", alias], binds = [], next = n }

-- The WHERE conjuncts of a mixed join: each non-null-extendable leaf's own scan filter
-- (qualified to its leaf) first, then every step's post-join filter qualified to its
-- leaves — an inner step's narrowing and an outer step's three-valued post-join filter
-- alike (a `filter` over an outer composite ANDs into that step's `where2`, dropping the
-- rows its predicate rejects the way a binary outer join's post-join WHERE does). A
-- null-extendable leaf's scan filter rides inside its subquery instead, so only the
-- leaves no step null-extends contribute their filter to this clause.
fn mixedWhere (leaves: List (Text, QExpr, List Text)) (steps: List (Text, QExpr, QExpr)) (nulls: List Int) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    let lp = mixedLeafConds leaves nulls 0 n
    let sp = mixedStepConds steps lp.next
    let conds = lp.texts ++ sp.texts
    match conds
        [] -> { text = "", binds = lp.binds ++ sp.binds, next = sp.next }
        _  -> { text = Text.concat " WHERE " (Text.join " AND " conds), binds = lp.binds ++ sp.binds, next = sp.next }

-- Each non-null-extendable leaf's own scan filter, qualified to its leaf alias and
-- dropping the always-true default. A null-extendable leaf is skipped — its filter rides
-- inside the subquery that carries its presence marker, where it must apply before the
-- outer step null-extends the leaf rather than after.
fn mixedLeafConds (leaves: List (Text, QExpr, List Text)) (nulls: List Int) (idx: Int) (n: Int) -> { texts: List Text, binds: List SqlValue, next: Int } =
    match leaves
        [] -> { texts = [], binds = [], next = n }
        (_, pred, _) :: rest ->
            if leafMember idx nulls then
                mixedLeafConds rest nulls (idx + 1) n
            else if isAlwaysTrue pred then
                mixedLeafConds rest nulls (idx + 1) n
            else
                let r = renderQual idx pred n
                let more = mixedLeafConds rest nulls (idx + 1) r.next
                { texts = Text.join "" ["(", r.text, ")"] :: more.texts, binds = r.binds ++ more.binds, next = more.next }

fn mixedStepConds (steps: List (Text, QExpr, QExpr)) (n: Int) -> { texts: List Text, binds: List SqlValue, next: Int } =
    match steps
        [] -> { texts = [], binds = [], next = n }
        (_, _, where2) :: rest ->
            if isAlwaysTrue where2 then
                mixedStepConds rest n
            else
                let r = renderQual 0 where2 n
                let more = mixedStepConds rest r.next
                { texts = Text.join "" ["(", r.text, ")"] :: more.texts, binds = r.binds ++ more.binds, next = more.next }

-- A projected join (`select` over a join): the projection's own select-list over the
-- joined tables, paged and de-duplicated by the projection. An unmatched outer column
-- projects NULL, decoded as the projected shape's `Option` field, so no marker is
-- needed; the ORDER BY keys come from the join the projection wraps.
fn renderProject (proj: QExpr) (child: QueryPlan) (lim: Int) (off: Int) (dist: Bool) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    match child
        PlanJoin kind left right cond where2 joinOrders _ _ _ _ _ ->
            match left
                PlanScan lt lp _ _ _ _ ->
                    match right
                        PlanScan rt _ _ _ _ _ ->
                            let sel = joinSelectList proj n
                            let sk = joinSkeleton kind lt lp rt cond where2 false sel.next
                            let ob = orderByClauseJoin joinOrders sk.next
                            { text = Text.join "" ["SELECT ", distinctKw dist, sel.text, " FROM ", sk.text, ob.text, limitClause lim, offsetClause off], binds = sel.binds ++ sk.binds ++ ob.binds, next = ob.next }
                        _ -> naryProject proj child joinOrders lim off dist n
                _ -> naryProject proj child joinOrders lim off dist n
        _ -> emptyRender n

-- A projected composite (`select` over a three-or-more table join): the projection's
-- own select-list over the flattened spine, paged and de-duplicated by the projection.
-- An all-inner spine renders its plain multi-way join; a mixed-shape spine renders each
-- step by its own kind, with no presence markers — a projection reads a null-extended
-- leaf's column as NULL directly, decoding it into the projected shape's `Option` field.
-- The ORDER BY keys ride on the join the projection wraps, qualified to their leaf alias.
fn naryProject (proj: QExpr) (child: QueryPlan) (orders: List (Bool, Int, QExpr)) (lim: Int) (off: Int) (dist: Bool) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    let f = flattenJoin child
    match f.leaves
        [] -> emptyRender n
        _  ->
            if allInnerSteps f.steps then
                let sel = naryProjectList proj n
                let from = naryFrom f.leaves f.steps sel.next
                let wh = naryWhere f.leaves f.steps from.next
                let ob = naryOrderBy orders wh.next
                { text = Text.join "" ["SELECT ", distinctKw dist, sel.text, " FROM ", from.text, wh.text, ob.text, limitClause lim, offsetClause off], binds = sel.binds ++ from.binds ++ wh.binds ++ ob.binds, next = ob.next }
            else
                let nulls = nullableLeaves f.steps
                let sel = naryProjectList proj n
                let from = mixedFrom f.leaves f.steps nulls false sel.next
                let wh = mixedWhere f.leaves f.steps nulls from.next
                let ob = naryOrderBy orders wh.next
                { text = Text.join "" ["SELECT ", distinctKw dist, sel.text, " FROM ", from.text, wh.text, ob.text, limitClause lim, offsetClause off], binds = sel.binds ++ from.binds ++ wh.binds ++ ob.binds, next = ob.next }

-- The projection's select-list over a flattened composite: each named column qualified
-- to its leaf alias (`t<i>."col" AS "alias"`). A `QCol` names leaf 0, a `QColR` leaf 1,
-- a `QColAt i` the i-th leaf of a deeper composite; a cell naming no column reads NULL.
fn naryProjectList (proj: QExpr) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    match proj
        QProj cols -> naryProjectTerms cols n
        _          -> { text = "*", binds = [], next = n }

fn naryProjectTerms (cols: List (Text, QExpr)) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    match cols
        []                 -> { text = "", binds = [], next = n }
        (alias, col) :: [] -> naryProjectTerm alias col n
        (alias, col) :: rest ->
            let h = naryProjectTerm alias col n
            let t = naryProjectTerms rest h.next
            { text = Text.join "" [h.text, ", ", t.text], binds = h.binds ++ t.binds, next = t.next }

fn naryProjectTerm (alias: Text) (col: QExpr) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    match col
        QCol c     -> { text = Text.join "" [naryColRef 0 c, " AS ", quoteIdent alias], binds = [], next = n }
        QColR c    -> { text = Text.join "" [naryColRef 1 c, " AS ", quoteIdent alias], binds = [], next = n }
        QColAt i c -> { text = Text.join "" [naryColRef i c, " AS ", quoteIdent alias], binds = [], next = n }
        _          ->
            let r = qualOperand 0 col n
            { text = Text.join "" [r.text, " AS ", quoteIdent alias], binds = r.binds, next = r.next }

-- The binary-join projection select-list, threading the `$N` counter so a
-- literal in a computed column binds in source order ahead of the join's own
-- ON/WHERE binds. A bare column reads side-qualified (`l."col"` / `r."col"`);
-- a computed cell (arithmetic, a CASE) renders through `renderOperand`, which
-- side-qualifies its own columns the same way.
fn joinSelectList (proj: QExpr) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    match proj
        QProj cols -> joinSelectTerms cols n
        _          -> { text = "*", binds = [], next = n }

fn joinSelectTerms (cols: List (Text, QExpr)) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    match cols
        []                 -> { text = "", binds = [], next = n }
        (alias, col) :: [] -> joinSelectTerm alias col n
        (alias, col) :: rest ->
            let h = joinSelectTerm alias col n
            let t = joinSelectTerms rest h.next
            { text = Text.join "" [h.text, ", ", t.text], binds = h.binds ++ t.binds, next = t.next }

fn joinSelectTerm (alias: Text) (col: QExpr) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    match col
        QCol c  -> { text = Text.join "" ["l.", quoteIdent c, " AS ", quoteIdent alias], binds = [], next = n }
        QColR c -> { text = Text.join "" ["r.", quoteIdent c, " AS ", quoteIdent alias], binds = [], next = n }
        _       ->
            let r = renderOperand true col n
            { text = Text.join "" [r.text, " AS ", quoteIdent alias], binds = r.binds, next = r.next }

-- A scalar aggregate over a join: the lone folded value, read off the first cell. A
-- `COUNT` counts rows; the others fold a side-qualified column (`AVG` casts to
-- `float8`, as the single-table aggregate does). No ordering or paging — an aggregate
-- folds every joined row.
fn renderAggregate (func: Text) (column: QExpr) (leaf: Int) (child: QueryPlan) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    match child
        PlanJoin kind left right cond where2 _ _ _ _ _ _ ->
            match left
                PlanScan lt lp _ _ _ _ ->
                    match right
                        PlanScan rt _ _ _ _ _ ->
                            let ax = aggExprJoinE func column n
                            let sk = joinSkeleton kind lt lp rt cond where2 false ax.next
                            { text = Text.join "" ["SELECT ", ax.text, " FROM ", sk.text], binds = ax.binds ++ sk.binds, next = sk.next }
                        _ -> naryAggregate func leaf column child n
                _ -> naryAggregate func leaf column child n
        _ -> emptyRender n

-- A scalar aggregate over a composite (three-or-more table) join: the flattened spine
-- as the `FROM`, folding the aggregate over its joined rows. A reduction is neither
-- ordered nor paged, so only the leaves' scan filters and the steps' post-join WHEREs
-- bound the fold. An all-inner spine renders its plain multi-way join; a mixed-shape
-- spine renders each step by its own kind, the presence markers a bare terminal needs
-- left off (an aggregate reads the null-extended NULLs directly). `COUNT(*)` counts the
-- joined rows; a column-folding aggregate folds `column` on its leaf alias `t<leaf>`.
fn naryAggregate (func: Text) (leaf: Int) (column: QExpr) (child: QueryPlan) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    let f = flattenJoin child
    match f.leaves
        [] -> emptyRender n
        _  ->
            if allInnerSteps f.steps then
                let ax = naryAggExprE func leaf column n
                let from = naryFrom f.leaves f.steps ax.next
                let wh = naryWhere f.leaves f.steps from.next
                { text = Text.join "" ["SELECT ", ax.text, " FROM ", from.text, wh.text], binds = ax.binds ++ from.binds ++ wh.binds, next = wh.next }
            else
                -- A reduction reads the null-extended NULLs directly, so it emits no presence
                -- markers (`marks = false`); a genuinely null-extended leaf still wraps a
                -- filtered scan in a subquery so the filter applies before the outer step,
                -- while every other leaf's filter lifts to the flat top-level WHERE.
                let nulls = nullableLeaves f.steps
                let ax = naryAggExprE func leaf column n
                let from = mixedFrom f.leaves f.steps nulls false ax.next
                let wh = mixedWhere f.leaves f.steps nulls from.next
                { text = Text.join "" ["SELECT ", ax.text, " FROM ", from.text, wh.text], binds = ax.binds ++ from.binds ++ wh.binds, next = wh.next }

-- The aggregate expression over a composite join: `COUNT(*)` counts the joined rows;
-- a column-folding aggregate folds its captured value (a column or a computed
-- expression over the leaves) rendered leaf-qualified (`t<leaf>`), its literals
-- threaded as `$N` placeholders. `AVG` casts to `float8`, as the single-table and
-- binary-join aggregates do. `leaf` is the default leaf a bare `QCol` qualifies to;
-- a `QColR`/`QColAt` inside the value names its own.
fn naryAggExprE (func: Text) (leaf: Int) (column: QExpr) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    if func == "COUNT" then { text = "COUNT(*)", binds = [], next = n }
    else
        let c = qualOperand leaf column n
        { text = Text.join "" [func, "(", c.text, ")", avgCast func], binds = c.binds, next = c.next }

-- The `::float8` cast an `AVG` carries so an integer column averages to a float, matching
-- the single-table and binary-join aggregate renderers; the other folds add nothing.
fn avgCast (func: Text) -> Text = if func == "AVG" then "::float8" else ""

-- The scalar-aggregate expression over a binary join: `COUNT(*)`, or `FUNC(<expr>)`
-- folding its captured value (a column or a computed expression over the two sides)
-- rendered side-qualified (`l.`/`r.`), its literals threaded as `$N` placeholders.
-- `AVG` casts to float8.
fn aggExprJoinE (func: Text) (column: QExpr) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    if func == "COUNT" then { text = "COUNT(*)", binds = [], next = n }
    else
        let c = renderOperand true column n
        { text = Text.join "" [func, "(", c.text, ")", avgCast func], binds = c.binds, next = c.next }

-- A grouped join (`groupBy` + `summarize`): one row per group, keyed by the
-- side-qualified group key and summarised into the aggregate columns, keeping the
-- groups the HAVING admits, ordered by the key.
fn renderGroup (keyCol: Text) (keyLeaf: Int) (cols: List (Text, Text, QExpr, Int)) (having: QExpr) (child: QueryPlan) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    match child
        PlanJoin kind left right cond where2 _ _ _ _ _ _ ->
            match left
                PlanScan lt lp _ _ _ _ ->
                    match right
                        PlanScan rt _ _ _ _ _ ->
                            let keyExpr = renderColRef true (keyLeaf == 1) keyCol
                            let cs = groupSelectTerms cols keyExpr n
                            let sk = joinSkeleton kind lt lp rt cond where2 false cs.next
                            let h = renderHaving having (keyLeaf == 1) keyCol sk.next
                            { text = Text.join "" ["SELECT ", cs.text, " FROM ", sk.text, " GROUP BY ", keyExpr, h.text, " ORDER BY ", keyExpr], binds = cs.binds ++ sk.binds ++ h.binds, next = h.next }
                        _ -> naryGroup keyCol keyLeaf cols having child n
                _ -> naryGroup keyCol keyLeaf cols having child n
        _ -> emptyRender n

-- The grouped SELECT list of a binary join, the aggregate terms threaded left to
-- right so a computed fold's literals bind in source order. Each term is the group
-- key, or a scalar aggregate folding its captured value — a side-qualified column or
-- a computed expression over the two sides (`COUNT(*)` carries no value).
fn groupSelectTerms (cols: List (Text, Text, QExpr, Int)) (keyExpr: Text) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    match cols
        []                               -> { text = "", binds = [], next = n }
        (alias, func, col, leaf) :: []   -> groupSelectTerm alias func col leaf keyExpr n
        (alias, func, col, leaf) :: rest ->
            let h = groupSelectTerm alias func col leaf keyExpr n
            let t = groupSelectTerms rest keyExpr h.next
            { text = Text.join "" [h.text, ", ", t.text], binds = h.binds ++ t.binds, next = t.next }

fn groupSelectTerm (alias: Text) (func: Text) (col: QExpr) (leaf: Int) (keyExpr: Text) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    if func == "KEY" then { text = Text.join "" [keyExpr, " AS ", quoteIdent alias], binds = [], next = n }
    else
        let a = aggExprJoinE func col n
        { text = Text.join "" [a.text, " AS ", quoteIdent alias], binds = a.binds, next = a.next }

-- A grouped composite (three-or-more table) join: the flattened spine as the `FROM`,
-- one row per group keyed by the leaf-qualified group key and summarised into the
-- aggregate columns, keeping the groups the HAVING admits, ordered by the key. The
-- mirror of `naryAggregate` for a grouped fold: an all-inner spine renders its plain
-- multi-way join, a mixed-shape spine each step by its own kind with the presence
-- markers a bare terminal needs left off (a grouped fold reads the null-extended NULLs
-- directly). Each aggregate column folds `column` on its leaf alias `t<leaf>`.
fn naryGroup (keyCol: Text) (keyLeaf: Int) (cols: List (Text, Text, QExpr, Int)) (having: QExpr) (child: QueryPlan) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    let f = flattenJoin child
    match f.leaves
        [] -> emptyRender n
        _  ->
            let keyExpr = naryColRef keyLeaf keyCol
            let cs = naryGroupSelectTerms cols keyExpr n
            if allInnerSteps f.steps then
                let from = naryFrom f.leaves f.steps cs.next
                let wh = naryWhere f.leaves f.steps from.next
                let h = naryHaving having keyLeaf keyCol wh.next
                { text = Text.join "" ["SELECT ", cs.text, " FROM ", from.text, wh.text, " GROUP BY ", keyExpr, h.text, " ORDER BY ", keyExpr], binds = cs.binds ++ from.binds ++ wh.binds ++ h.binds, next = h.next }
            else
                let nulls = nullableLeaves f.steps
                let from = mixedFrom f.leaves f.steps nulls false cs.next
                let wh = mixedWhere f.leaves f.steps nulls from.next
                let h = naryHaving having keyLeaf keyCol wh.next
                { text = Text.join "" ["SELECT ", cs.text, " FROM ", from.text, wh.text, " GROUP BY ", keyExpr, h.text, " ORDER BY ", keyExpr], binds = cs.binds ++ from.binds ++ wh.binds ++ h.binds, next = h.next }

-- The grouped SELECT list of a composite (three-or-more table) join, threaded left
-- to right. Each term folds its captured value leaf-qualified (`t<leaf>`), a column
-- or a computed expression over the leaves, its literals bound as `$N`.
fn naryGroupSelectTerms (cols: List (Text, Text, QExpr, Int)) (keyExpr: Text) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    match cols
        []                               -> { text = "", binds = [], next = n }
        (alias, func, col, leaf) :: []   -> naryGroupSelectTerm alias func col leaf keyExpr n
        (alias, func, col, leaf) :: rest ->
            let h = naryGroupSelectTerm alias func col leaf keyExpr n
            let t = naryGroupSelectTerms rest keyExpr h.next
            { text = Text.join "" [h.text, ", ", t.text], binds = h.binds ++ t.binds, next = t.next }

fn naryGroupSelectTerm (alias: Text) (func: Text) (col: QExpr) (leaf: Int) (keyExpr: Text) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    if func == "KEY" then { text = Text.join "" [keyExpr, " AS ", quoteIdent alias], binds = [], next = n }
    else
        let a = naryAggExprE func leaf col n
        { text = Text.join "" [a.text, " AS ", quoteIdent alias], binds = a.binds, next = a.next }

-- A composite-join HAVING fragment, the leaf-qualified dual of `renderHaving`: its
-- aggregate operands fold a leaf-qualified column (`t<leaf>`) and its group-key
-- operand reads the key off its leaf, where the binary form reads the left/right
-- side. Empty for the always-true default, so the clause is omitted.
fn naryHaving (having: QExpr) (keyLeaf: Int) (keyCol: Text) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    match having
        QLitBool b -> if b then { text = "", binds = [], next = n } else naryHavingClause having keyLeaf keyCol n
        _          -> naryHavingClause having keyLeaf keyCol n

fn naryHavingClause (having: QExpr) (keyLeaf: Int) (keyCol: Text) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    let h = naryHavingExpr having keyLeaf keyCol n
    { text = Text.concat " HAVING " h.text, binds = h.binds, next = h.next }

fn naryHavingExpr (e: QExpr) (keyLeaf: Int) (keyCol: Text) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    match e
        QAnd l r -> naryHavingBin l " AND " r keyLeaf keyCol n
        QOr l r  -> naryHavingBin l " OR " r keyLeaf keyCol n
        QNot x   ->
            let r = naryHavingExpr x keyLeaf keyCol n
            { text = Text.join "" ["(NOT ", r.text, ")"], binds = r.binds, next = r.next }
        QEq l r -> naryHavingCmp l " = " r keyLeaf keyCol n
        QNe l r -> naryHavingCmp l " <> " r keyLeaf keyCol n
        QLt l r -> naryHavingCmp l " < " r keyLeaf keyCol n
        QGt l r -> naryHavingCmp l " > " r keyLeaf keyCol n
        QLe l r -> naryHavingCmp l " <= " r keyLeaf keyCol n
        QGe l r -> naryHavingCmp l " >= " r keyLeaf keyCol n
        _       -> naryHavingOperand e keyLeaf keyCol n

fn naryHavingCmp (l: QExpr) (op: Text) (r: QExpr) (keyLeaf: Int) (keyCol: Text) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    let lr = naryHavingOperand l keyLeaf keyCol n
    let rr = naryHavingOperand r keyLeaf keyCol lr.next
    { text = Text.join "" [lr.text, op, rr.text], binds = lr.binds ++ rr.binds, next = rr.next }

fn naryHavingBin (l: QExpr) (op: Text) (r: QExpr) (keyLeaf: Int) (keyCol: Text) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    let lr = naryHavingExpr l keyLeaf keyCol n
    let rr = naryHavingExpr r keyLeaf keyCol lr.next
    { text = Text.join "" ["(", lr.text, op, rr.text, ")"], binds = lr.binds ++ rr.binds, next = rr.next }

fn naryHavingOperand (e: QExpr) (keyLeaf: Int) (keyCol: Text) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    match e
        QAggCount    -> { text = "COUNT(*)", binds = [], next = n }
        QGroupKey    -> { text = naryColRef keyLeaf keyCol, binds = [], next = n }
        QAggSum node -> naryAggExprE "SUM" 0 node n
        QAggAvg node -> naryAggExprE "AVG" 0 node n
        QAggMin node -> naryAggExprE "MIN" 0 node n
        QAggMax node -> naryAggExprE "MAX" 0 node n
        QLitInt v    -> { text = placeholder n, binds = [sqlInt v], next = n + 1 }
        QLitText v   -> { text = placeholder n, binds = [sqlText v], next = n + 1 }
        QLitBool v   -> { text = placeholder n, binds = [sqlBool v], next = n + 1 }
        QLitFloat v  -> { text = placeholder n, binds = [sqlFloat v], next = n + 1 }
        _            -> { text = "NULL", binds = [], next = n }

-- A join HAVING fragment, with the leading ` HAVING ` folded in — empty for the
-- always-true default, so the clause is omitted. Structurally a predicate, but its
-- operands are group aggregates (`COUNT(*)`, `SUM(col)`, …) and the side-qualified
-- group key rather than plain columns; Postgres rejects an output alias in HAVING, so
-- each aggregate is re-rendered from its node.
fn renderHaving (having: QExpr) (keySide: Bool) (keyCol: Text) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    match having
        QLitBool b -> if b then { text = "", binds = [], next = n } else havingClause having keySide keyCol n
        _          -> havingClause having keySide keyCol n

fn havingClause (having: QExpr) (keySide: Bool) (keyCol: Text) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    let h = renderHavingExpr having keySide keyCol n
    { text = Text.concat " HAVING " h.text, binds = h.binds, next = h.next }

fn renderHavingExpr (e: QExpr) (keySide: Bool) (keyCol: Text) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    match e
        QAnd l r -> havingBin l " AND " r keySide keyCol n
        QOr l r  -> havingBin l " OR " r keySide keyCol n
        QNot x   ->
            let r = renderHavingExpr x keySide keyCol n
            { text = Text.join "" ["(NOT ", r.text, ")"], binds = r.binds, next = r.next }
        QEq l r -> havingCmp l " = " r keySide keyCol n
        QNe l r -> havingCmp l " <> " r keySide keyCol n
        QLt l r -> havingCmp l " < " r keySide keyCol n
        QGt l r -> havingCmp l " > " r keySide keyCol n
        QLe l r -> havingCmp l " <= " r keySide keyCol n
        QGe l r -> havingCmp l " >= " r keySide keyCol n
        _       -> renderHavingOperand e keySide keyCol n

fn havingCmp (l: QExpr) (op: Text) (r: QExpr) (keySide: Bool) (keyCol: Text) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    let lr = renderHavingOperand l keySide keyCol n
    let rr = renderHavingOperand r keySide keyCol lr.next
    { text = Text.join "" [lr.text, op, rr.text], binds = lr.binds ++ rr.binds, next = rr.next }

fn havingBin (l: QExpr) (op: Text) (r: QExpr) (keySide: Bool) (keyCol: Text) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    let lr = renderHavingExpr l keySide keyCol n
    let rr = renderHavingExpr r keySide keyCol lr.next
    { text = Text.join "" ["(", lr.text, op, rr.text, ")"], binds = lr.binds ++ rr.binds, next = rr.next }

fn renderHavingOperand (e: QExpr) (keySide: Bool) (keyCol: Text) (n: Int) -> { text: Text, binds: List SqlValue, next: Int } =
    match e
        QAggCount    -> { text = "COUNT(*)", binds = [], next = n }
        QGroupKey    -> { text = renderColRef true keySide keyCol, binds = [], next = n }
        QAggSum node -> aggExprJoinE "SUM" node n
        QAggAvg node -> aggExprJoinE "AVG" node n
        QAggMin node -> aggExprJoinE "MIN" node n
        QAggMax node -> aggExprJoinE "MAX" node n
        QLitInt v    -> { text = placeholder n, binds = [sqlInt v], next = n + 1 }
        QLitText v   -> { text = placeholder n, binds = [sqlText v], next = n + 1 }
        QLitBool v   -> { text = placeholder n, binds = [sqlBool v], next = n + 1 }
        QLitFloat v  -> { text = placeholder n, binds = [sqlFloat v], next = n + 1 }
        _            -> { text = "NULL", binds = [], next = n }
