-- Private FFI bridge for the std.actor test suite.
-- Replicates actor.ridge in local scope so test functions can call the FFI
-- without a cross-module qualified reference (T17+ deferred per
-- crates/ridge-typecheck/src/stdlib_env.rs:87-92).
@ffi("ridge_rt", "mailbox_size", 1)
fn _mailboxSize (h: Handle a) -> Option Int

-- Exercise the `_mailboxSize` FFI binding at the type level: a test takes no
-- arguments, and a live `Handle` cannot be constructed without the runtime, so
-- the call is wrapped in a zero-arity function the runner does not execute.
-- Functional validation (live → Some, dead → None) lives in the BEAM
-- end-to-end suite under crates/ridge-codegen-erl/tests/.
fn _probeMailboxSize (h: Handle a) -> Option Int = _mailboxSize h

-- Smoke: the module compiles end to end through the build pipeline.
@test "mailbox_size_compiles"
pub fn test_mailbox_size_compiles () -> Result Unit Text = Ok ()
