{
  "comments": {
    "lineComment": "--"
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"]
  ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "{", "close": "}" },
    { "open": "\"", "close": "\"" }
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"],
    ["\"", "\""]
  ],
  "indentationRules": {
    "increaseIndentPattern": "(^|[^=!<>])=\\s*(--.*)?$|(->|<-)\\s*(--.*)?$|\\b(then|else|try)\\b\\s*(--.*)?$|(^|=)\\s*match\\b[^>]*$",
    "decreaseIndentPattern": "^\\s*else\\s*(--.*)?$"
  }
}
